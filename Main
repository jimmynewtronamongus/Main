local CONFIG_FILE = "gag-main-config.json"
local configLoaded = false
local configSaveQueued = false

function mergeSavedConfig(target, source)
    if type(target) ~= "table" or type(source) ~= "table" then
        return
    end

    for key, value in pairs(source) do
        local current = target[key]
        if current == nil then
            target[key] = value
        else
            if type(current) == "table" and type(value) == "table" then
                mergeSavedConfig(current, value)
            elseif type(current) == type(value) then
                target[key] = value
            end
        end
    end
end

function loadConfig()
    if type(readfile) ~= "function" or type(isfile) ~= "function" or not isfile(CONFIG_FILE) then
        configLoaded = true
        return false
    end

    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_FILE))
    end)

    if ok and type(data) == "table" then
        mergeSavedConfig(Config, type(data.Config) == "table" and data.Config or data)
        configLoaded = true
        return true
    end

    configLoaded = true
    return false
end

function saveConfig()
    if type(writefile) ~= "function" then
        return false
    end

    local ok, encoded = pcall(function()
        return HttpService:JSONEncode({
            Version = 1,
            Config = Config,
        })
    end)

    if not ok then
        return false
    end

    return pcall(function()
        writefile(CONFIG_FILE, encoded)
    end)
end

function scheduleSaveConfig()
    if not configLoaded or configSaveQueued then
        return
    end

    configSaveQueued = true
    task.delay(0.35, function()
        configSaveQueued = false
        saveConfig()
    end)
end

