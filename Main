function fireBuyVariants(remoteName, itemName, index)
    local argSets = {}

    if itemName and itemName ~= "" then
        argSets[#argSets + 1] = {itemName}
        argSets[#argSets + 1] = {itemName, 1}
        argSets[#argSets + 1] = {itemName, true}
        argSets[#argSets + 1] = {"Buy", itemName}
        argSets[#argSets + 1] = {"Purchase", itemName}
    end

    if index then
        argSets[#argSets + 1] = {index}
        argSets[#argSets + 1] = {index, 1}
        if itemName and itemName ~= "" then
            argSets[#argSets + 1] = {index, itemName}
            argSets[#argSets + 1] = {itemName, index}
        end
    end

    if #argSets == 0 then
        argSets[#argSets + 1] = {}
    end

    return fireGameEventAll(remoteName, argSets, 0.02)
end

function Actions.AutoBuySelectedShopsOnce()
    local firedCount = 0
    local selectedSeeds = getSelectedNames(Config.Misc.SeedsToPlace)
    local seedBuyNames = #selectedSeeds > 0 and selectedSeeds or DEFAULT_SEED_BUY_NAMES
    local selectedEggs = selectedToPriority(Config.Hatch.SelectedEggs)
    if #selectedEggs == 0 then
        selectedEggs = #OPTIONS.Eggs > 0 and OPTIONS.Eggs or DEFAULT_EGG_BUY_NAMES
    end
    local shopsToBuy = getSelectedNames(Config.Misc.ShopsToBuy)
    if #shopsToBuy == 0 then
        shopsToBuy = OPTIONS.Shops
    end

    for _, shopName in ipairs(shopsToBuy) do
        if shopName == "Seed Shop" then
            for index, seedName in ipairs(seedBuyNames) do
                firedCount = firedCount + fireBuyVariants("BuySeedStock", seedName, index)
                firedCount = firedCount + fireBuyVariants("BuyDailySeedShopStock", seedName, index)
            end
        elseif shopName == "Gear Shop" then
            for index, gearName in ipairs(DEFAULT_GEAR_BUY_NAMES) do
                firedCount = firedCount + fireBuyVariants("BuyGearStock", gearName, index)
            end
        elseif shopName == "Egg Shop" then
            for index, eggName in ipairs(selectedEggs) do
                firedCount = firedCount + fireBuyVariants("BuyPetEgg", eggName, index)
            end
            for slot = 1, MAX_EGGS_PLACED do
                firedCount = firedCount + fireBuyVariants("BuyPetEgg", nil, slot)
            end
        elseif shopName == "Cosmetic Shop" then
            firedCount = firedCount + fireBuyVariants("BuyCosmeticItem")
        elseif shopName == "Event Merchant" or shopName == "Honey Merchant" or shopName == "Traveling Merchant" then
            for index, itemName in ipairs(DEFAULT_EVENT_BUY_NAMES) do
                firedCount = firedCount + fireBuyVariants("BuyEventShopStock", itemName, index)
            end
            if tryFireGameEvent("BuyEventShopRestock") then firedCount = firedCount + 1 end
        end
    end

    log(("Auto Buy fired %d shop request(s)."):format(firedCount))
    return firedCount
end

function plantSeedAt(seedName, cframe)
    local position = cframe.Position
    return tryFireGameEventAny("Plant", {
        {position, seedName},
        {seedName, position},
        {cframe, seedName},
        {seedName, cframe},
        {seedName},
    })
end

function Actions.PlaceSelectedSeedsOnce()
    local placedCount = 0

    for _, entry in ipairs(selectedSeedEntries(Config.Misc.SeedsToPlace)) do
        local seedName = entry.Name
        local tool = firstToolInstance(entry)
        if tool then
            equipToolInstance(tool)
            task.wait(0.03)
        end

        local cframe = getPlacementCFrame(placedCount + 1)
        if plantSeedAt(seedName, cframe) then
            placedCount = placedCount + 1
            task.wait(0.02)
        end
    end

    if placedCount == 0 then
        log("Auto Place Seeds skipped: no selected seed tools found or Plant_RE did not fire.")
    else
        log(("Auto Place Seeds fired Plant_RE for %d seed(s)."):format(placedCount))
    end

    return placedCount
end

function Actions.RebirthOnce()
    if tryFireGameEvent("BuyRebirth") then
        log("BuyRebirth fired.")
        return true
    end

    log("Auto Rebirth skipped: BuyRebirth remote not found.")
    return false
end

function Actions.AutoKgBoost(enabled)
    log("Auto KG Boost " .. (enabled and "enabled" or "disabled") .. " | max equipped " .. tostring(MAX_PETS_EQUIPPED) .. " | target " .. tostring(KG_BOOST_TARGET_KG) .. " KG")
end

function installHatchActions()
    local BUFF_KEYWORDS = {
        "egg",
        "hatch",
        "refund",
        "size",
        "seal",
        "sell",
        "reduce",
        "reduction",
        "cooldown",
        "boost",
    }

    local function readEntryMutationNames(entry)
        local found = {}
        local ordered = {}

        local function addMutation(value)
            local text = stripStackData(value)
            if text == "" then
                return
            end

            for _, mutationName in ipairs(OPTIONS.Mutations or {}) do
                if mutationName ~= "Mutation Machine"
                    and tostring(text):lower():find(tostring(mutationName):lower(), 1, true)
                    and not found[mutationName]
                then
                    found[mutationName] = true
                    ordered[#ordered + 1] = mutationName
                end
            end
        end

        for _, instance in ipairs(entry and entry.Instances or {}) do
            local ok, attributes = pcall(function()
                return instance:GetAttributes()
            end)
            if ok and type(attributes) == "table" then
                for key, value in pairs(attributes) do
                    local keyText = tostring(key or ""):lower()
                    if keyText:find("mutation", 1, true) or keyText:find("variant", 1, true) then
                        addMutation(value)
                    end
                    if type(value) == "boolean" and value == true then
                        addMutation(key)
                    elseif type(value) == "string" then
                        addMutation(value)
                    end
                end
            end

            for _, descendant in ipairs(instance:GetDescendants()) do
                local keyText = tostring(descendant.Name or ""):lower()
                if descendant:IsA("StringValue") and (keyText:find("mutation", 1, true) or keyText:find("variant", 1, true)) then
                    addMutation(descendant.Value)
                elseif descendant:IsA("BoolValue") and descendant.Value == true then
                    addMutation(descendant.Name)
                end
            end
        end

        return ordered
    end

    local function selectedMutationMatch(entry)
        if not Config.Hatch.KeepMutatedPets then
            return nil
        end

        local mutations = readEntryMutationNames(entry)
        for _, mutationName in ipairs(mutations) do
            if Config.Hatch.KeepMutations[mutationName] then
                return mutationName
            end
        end

        return nil
    end

    local function getPetBaseWeight(entry)
        for _, instance in ipairs(entry and entry.Instances or {}) do
            local value = readNumericField(instance, {
                "BaseWeight",
                "BaseKG",
                "BaseMass",
                "Weight",
                "KG",
                "Mass",
            }, {
                "Max",
                "Target",
                "Goal",
                "Boost",
            })

            if value then
                return value
            end
        end

        return getPetKg(entry)
    end

    local function autoKeepReason(entry)
        local mutationName = selectedMutationMatch(entry)
        if mutationName then
            return "mutation " .. mutationName
        end

        if Config.Hatch.KeepByMinWeight then
            local weight = getPetBaseWeight(entry)
            local target = tonumber(Config.Hatch.KeepMinWeight) or 3
            if weight and weight >= target then
                return ("weight %.2fkg >= %.2fkg"):format(weight, target)
            end
        end

        return nil
    end

    local function predictEggPetName(eggObject)
        if Runtime.EggPredictionCache[eggObject] then
            return Runtime.EggPredictionCache[eggObject]
        end

        local predicted = getMetadataTextField(eggObject, {
            "PetName",
            "PetType",
            "HatchedPet",
            "HatchPet",
            "PredictedPet",
            "ResultPet",
            "RewardPet",
            "NextPet",
            "Type",
        })

        if predicted and not isLikelyEggName(predicted) then
            Runtime.EggPredictionCache[eggObject] = predicted
            return predicted
        end

        local searchText = getAttributeText(eggObject):gsub("[^%w]", "")
        local bestName

        local function scanOptionList(options)
            for _, petName in ipairs(options or {}) do
                local normalized = tostring(petName or ""):lower():gsub("[^%w]", "")
                if normalized ~= ""
                    and not isLikelyEggName(petName)
                    and searchText:find(normalized, 1, true)
                then
                    if not bestName or #petName > #bestName then
                        bestName = petName
                    end
                end
            end
        end

        scanOptionList(OPTIONS.Pets)
        for _, petOptions in pairs(OPTIONS.EggPetsByEgg or {}) do
            scanOptionList(petOptions)
        end

        if bestName then
            Runtime.EggPredictionCache[eggObject] = bestName
            return bestName
        end

        local remote = findGameEventRemote("PetEggService")
        if remote and remote:IsA("RemoteFunction") then
            for _, action in ipairs({"GetPet", "GetHatchPet", "GetEggPet", "GetPetInEgg", "GetReward"}) do
                local ok, result = callGameEvent("PetEggService", action, eggObject)
                if ok and result ~= nil then
                    local resultText = tostring(result)
                    if type(result) == "table" then
                        local parts = {}
                        local function collect(value, depth)
                            if depth > 4 then
                                return
                            end
                            if type(value) == "table" then
                                for key, child in pairs(value) do
                                    parts[#parts + 1] = tostring(key)
                                    collect(child, depth + 1)
                                end
                            else
                                parts[#parts + 1] = tostring(value)
                            end
                        end
                        collect(result, 0)
                        resultText = table.concat(parts, " ")
                    end

                    local resultName = findPetBaseNameInText(resultText) or petBaseNameForCache(resultText)
                    if resultName then
                        Runtime.EggPredictionCache[eggObject] = resultName
                        return resultName
                    end
                end
            end
        end

        return "Unknown pet"
    end

    local function isEggReadyToHatch(eggObject)
        local ready = readBooleanField(eggObject, {
            "Ready",
            "CanHatch",
            "HatchReady",
            "IsReady",
        })
        if ready ~= nil then
            return ready
        end

        local remaining = readNumericField(eggObject, {
            "TimeLeft",
            "Remaining",
            "HatchTime",
            "ReadyTime",
            "Cooldown",
        })
        if remaining ~= nil then
            return remaining <= 0
        end

        return false
    end

    local function getEggRemainingSeconds(eggObject)
        local remaining = readNumericField(eggObject, {
            "TimeLeft",
            "Remaining",
            "RemainingTime",
            "HatchTimeLeft",
            "HatchRemaining",
            "Cooldown",
        })

        if remaining ~= nil then
            return math.max(0, remaining)
        end

        local readyAt = readNumericField(eggObject, {
            "ReadyAt",
            "HatchAt",
            "HatchReadyAt",
            "EndTime",
            "FinishTime",
        })

        if readyAt then
            local now = os.time()
            if readyAt > now then
                return readyAt - now
            end
            return 0
        end

        return nil
    end

    local function formatDuration(seconds)
        seconds = math.max(0, math.floor(tonumber(seconds) or 0))
        local minutes = math.floor(seconds / 60)
        local secs = seconds % 60

        if minutes >= 60 then
            local hours = math.floor(minutes / 60)
            minutes = minutes % 60
            return ("%dh %02dm"):format(hours, minutes)
        end

        return ("%dm %02ds"):format(minutes, secs)
    end

    Actions.IsEggReadyToHatch = isEggReadyToHatch

    local function getEggAdornee(eggObject)
        if eggObject:IsA("BasePart") then
            return eggObject
        end
        return eggObject:FindFirstChildWhichIsA("BasePart", true)
    end

    local function updateEggEsp()
        for object, billboard in pairs(Runtime.EggEspBillboards) do
            if not object.Parent or not Config.Hatch.EggEsp then
                billboard:Destroy()
                Runtime.EggEspBillboards[object] = nil
            end
        end

        if not Config.Hatch.EggEsp then
            return
        end

        local eggObjects = collectPhysicalEggObjects()
        if #eggObjects == 0 then
            return
        end

        for _, object in ipairs(eggObjects) do
                local ready = isEggReadyToHatch(object)
                local billboard = Runtime.EggEspBillboards[object]
                local adornee = getEggAdornee(object)
                if adornee and not billboard then
                    billboard = Instance.new("BillboardGui")
                    billboard.Name = "GAGPetEggESP"
                    billboard.AlwaysOnTop = true
                    billboard.Size = UDim2.fromOffset(190, 64)
                    billboard.StudsOffset = Vector3.new(0, 4, 0)
                    billboard.Adornee = adornee
                    billboard.Parent = screenGui

                    local label = Instance.new("TextLabel")
                    label.Name = "Label"
                    label.BackgroundColor3 = Theme.Background
                    label.BackgroundTransparency = 0.15
                    label.BorderSizePixel = 0
                    label.Size = UDim2.fromScale(1, 1)
                    label.Font = Enum.Font.GothamBold
                    label.TextColor3 = Theme.Text
                    label.TextSize = 12
                    label.TextWrapped = true
                    label.Parent = billboard
                    makeCorner(label, 6)
                    makeStroke(label, Theme.Accent, 1)

                    Runtime.EggEspBillboards[object] = billboard
                end

                if billboard then
                    local remaining = getEggRemainingSeconds(object)
                    billboard.Enabled = true
                    local label = billboard:FindFirstChild("Label")
                    if label then
                        local timeText = ready and "Ready" or (remaining and ("Hatches in " .. formatDuration(remaining)) or "Timer unknown")
                        label.Text = ("%s\n%s\n%s"):format(getPhysicalEggName(object), predictEggPetName(object), timeText)
                        label.TextColor3 = ready and Theme.Text or Theme.Muted
                    end
                end
        end
    end

    function Actions.RefreshEggEsp(silent)
        updateEggEsp()
        if not silent then
            log("Pet egg ESP refreshed.")
        end
    end

    local function selectedEggPriorityList()
        local priority = {}

        for _, eggName in ipairs(Config.Hatch.EggPriority or {}) do
            if hasOption(OPTIONS.Eggs, eggName) and not hasOption(priority, eggName) then
                priority[#priority + 1] = eggName
            end
        end

        for _, eggName in ipairs(Config.Hatch.SelectedEggs.__order or {}) do
            if Config.Hatch.SelectedEggs[eggName] and not hasOption(priority, eggName) then
                priority[#priority + 1] = eggName
            end
        end

        return priority
    end

    local function cyclePetTeam(selected, runtimeIndexKey, maxCount, label)
        local equippedCount = 0
        local entries = selectedPetEntries(selected)
        if #entries == 0 then
            return 0
        end

        local startIndex = tonumber(Runtime[runtimeIndexKey]) or 1
        for offset = 0, #entries - 1 do
            if equippedCount >= maxCount then
                break
            end

            local index = ((startIndex + offset - 1) % #entries) + 1
            local entry = entries[index]
            Runtime[runtimeIndexKey] = (index % #entries) + 1

            if equipPetEntry(entry, equippedCount + 1) then
                equippedCount = equippedCount + 1
            end
        end

        if equippedCount > 0 then
            log(("%s equipped %d pet(s)."):format(label, equippedCount))
        end

        return equippedCount
    end

    local function sellPetEntry(entry)
        local uuid = firstUuid(entry)
        local tool = firstToolInstance(entry)
        local instance = firstInstance(entry)
        local payload = tool or instance
        if not uuid and not payload then
            return false
        end

        cachePetEntryName(entry)
        return tryFireGameEventAny("SellPet", {
            {payload, true},
            {payload, Config.Hatch.AutoSellWithSeal},
            {payload},
            {uuid},
            {uuid, Config.Hatch.AutoSellWithSeal},
            {"Sell", uuid},
            {"SellPet", uuid},
        })
    end

    local function sellUnkeptPets(eggName, petEntries, newlyHatchedOnly)
        if not Config.Hatch.AutoSellPets then
            return 0
        end

        if Config.Hatch.OnlySellNewlyHatched and not newlyHatchedOnly then
            log("Sell skipped: Only Sell Newly Hatched is enabled.")
            return 0
        end

        if Config.Hatch.AutoSellWithSeal then
            cyclePetTeam(Config.Hatch.SealPets, "SealIndex", MAX_PETS_EQUIPPED, "Seal team")
            task.wait(0.25)
        end

        local keepRule = Config.Hatch.SellRulesByEgg[eggName] or {}
        local soldCount = 0
        for _, entry in ipairs(petEntries or {}) do
            local reason = autoKeepReason(entry)
            if reason then
                log(("Kept hatch pet by auto rule: %s (%s)"):format(tostring(entry.Name), reason))
            elseif not keepRule[entry.Name] then
                if not Config.Hatch.DontSellFavorited or not readBooleanField(firstInstance(entry), {"Favorite", "Favorited", "IsFavorite", "Locked"}) then
                    if sellPetEntry(entry) then
                        soldCount = soldCount + 1
                        log("Sold non-keep hatch pet: " .. tostring(entry.Name))
                    end
                else
                    log("Kept favorited hatch pet: " .. tostring(entry.Name))
                end
            else
                log("Kept hatch pet by egg rule: " .. tostring(entry.Name))
            end
        end

        return soldCount
    end

    local function addBuffLine(lines, seen, sourceName, key, value)
        local text = tostring(key or "")
        local lower = text:lower()
        if not hasAnyKeyword(lower, BUFF_KEYWORDS) then
            return
        end

        local line = ("%s | %s = %s"):format(tostring(sourceName), text, tostring(value))
        if not seen[line] then
            seen[line] = true
            lines[#lines + 1] = line
        end
    end

    local function readBuffPercent(entry, includeKeywords, fallbackPercent)
        local best

        local function parsePercent(value)
            if type(value) == "number" then
                return value
            end

            if type(value) == "string" then
                return tonumber(value:match("(%d+%.?%d*)%s*%%?"))
            end

            return nil
        end

        local function matches(name)
            local normalized = tostring(name or ""):lower():gsub("[^%w]", "")
            if normalized == "" then
                return false
            end

            local matchedSpecific = false
            for _, keyword in ipairs(includeKeywords or {}) do
                local wanted = tostring(keyword or ""):lower():gsub("[^%w]", "")
                if wanted ~= "" and normalized:find(wanted, 1, true) then
                    matchedSpecific = true
                    break
                end
            end

            return matchedSpecific
                and (
                    normalized:find("chance", 1, true)
                    or normalized:find("percent", 1, true)
                    or normalized:find("boost", 1, true)
                    or normalized:find("refund", 1, true)
                    or normalized:find("eggback", 1, true)
                    or normalized:find("size", 1, true)
                )
        end

        local function record(name, value)
            local numeric = parsePercent(value)
            if not numeric or not matches(name) then
                return
            end

            if numeric <= 1 then
                numeric = numeric * 100
            end

            if not best or numeric > best then
                best = numeric
            end
        end

        for _, instance in ipairs(entry and entry.Instances or {}) do
            local ok, attributes = pcall(function()
                return instance:GetAttributes()
            end)
            if ok and type(attributes) == "table" then
                for key, value in pairs(attributes) do
                    record(key, value)
                end
            end

            for _, descendant in ipairs(instance:GetDescendants()) do
                if descendant:IsA("NumberValue") or descendant:IsA("IntValue") or descendant:IsA("StringValue") then
                    record(descendant.Name, descendant.Value)
                end
            end
        end

        return best or fallbackPercent
    end

    local function collectPetBuffLines(entry)
        local lines = {}
        local seen = {}

        for _, instance in ipairs(entry and entry.Instances or {}) do
            local ok, attributes = pcall(function()
                return instance:GetAttributes()
            end)
            if ok and type(attributes) == "table" then
                for key, value in pairs(attributes) do
                    addBuffLine(lines, seen, entry.Name, key, value)
                end
            end

            for _, descendant in ipairs(instance:GetDescendants()) do
                if descendant:IsA("StringValue") or descendant:IsA("NumberValue") or descendant:IsA("IntValue") or descendant:IsA("BoolValue") then
                    addBuffLine(lines, seen, entry.Name, descendant.Name, descendant.Value)
                end
            end
        end

        local lowerName = tostring(entry and entry.Name or ""):lower()
        for _, instance in ipairs(entry and entry.Instances or {}) do
            lowerName = lowerName .. " " .. getAttributeText(instance)
        end
        local function addEstimate(label, value)
            if value and value > 0 then
                if value <= 1 then
                    value = value * 100
                end
                local line = ("%s | calculated %s = %.1f%%"):format(tostring(entry.Name), label, value)
                if not seen[line] then
                    seen[line] = true
                    lines[#lines + 1] = line
                end
            end
        end

        if lowerName:find("seal", 1, true) then
            addEstimate("sell egg refund chance", readBuffPercent(entry, {"seal", "sell", "refund", "eggback"}, nil))
        elseif lowerName:find("koi", 1, true) then
            addEstimate("hatch egg refund chance", readBuffPercent(entry, {"koi", "hatch", "refund", "eggback"}, nil))
        elseif lowerName:find("bronto", 1, true) or lowerName:find("brontosaurus", 1, true) then
            addEstimate("hatch size boost", readBuffPercent(entry, {"bronto", "hatch", "size", "boost"}, 30))
        end

        return lines
    end

    local function buffKindForEntry(entry)
        local lowerName = tostring(entry and entry.Name or ""):lower()
        for _, instance in ipairs(entry and entry.Instances or {}) do
            lowerName = lowerName .. " " .. getAttributeText(instance)
        end

        if lowerName:find("seal", 1, true) then
            return "Seal"
        end
        if lowerName:find("koi", 1, true) then
            return "Koi"
        end
        if lowerName:find("bronto", 1, true) or lowerName:find("brontosaurus", 1, true) then
            return "Bronto"
        end

        return nil
    end

    local function activePlacedPetEntries()
        local entries = {}
        local seen = {}
        local petsPhysical = Workspace:FindFirstChild("PetsPhysical")
        local petMover = petsPhysical and petsPhysical:FindFirstChild("PetMover")
        if not petMover then
            return entries
        end

        for _, petModel in ipairs(petMover:GetChildren()) do
            local uuid = getInstanceUuid(petModel)
            if uuid and isLocalPlacedPet(petModel, uuid) then
                local key = uuidCacheKey(uuid)
                if not seen[key] then
                    seen[key] = true
                    entries[#entries + 1] = {
                        Name = getPhysicalPetDisplayName(petModel, uuid),
                        Instances = {petModel},
                        UUIDs = {uuid},
                    }
                end
            end
        end

        return entries
    end

    local function applyBuffTotals(entry, totals)
        local kind = buffKindForEntry(entry)
        if kind == "Seal" then
            local value = readBuffPercent(entry, {"sell", "refund", "eggback", "chance", "percent"}, nil)
            if value then
                totals.SellRefund = totals.SellRefund + value
                return true
            end
        elseif kind == "Koi" then
            local value = readBuffPercent(entry, {"hatch", "refund", "eggback", "chance", "percent"}, nil)
            if value then
                totals.HatchRefund = totals.HatchRefund + value
                return true
            end
        elseif kind == "Bronto" then
            local value = readBuffPercent(entry, {"hatch", "size", "boost", "percent"}, 30)
            if value then
                totals.SizeBoost = totals.SizeBoost + value
                return true
            end
        end

        return false
    end

    local function currentPlacedEggCount()
        return #collectPhysicalEggObjects()
    end

    local function selectedEggToolInstances(priority)
        local tools = {}
        local seen = {}

        for _, eggName in ipairs(priority or {}) do
            local entry = Inventory.EggsByName[eggName]
            for _, instance in ipairs(entry and entry.Instances or {}) do
                if instance and instance:IsA("Tool") and not seen[instance] then
                    seen[instance] = true
                    tools[#tools + 1] = {
                        Name = eggName,
                        Tool = instance,
                    }
                end
            end
        end

        return tools
    end

    local function placeEquippedEggAt(eggName, cframe, previousCount)
        local position = cframe.Position
        local remote = getGameEventRemote("PetEggService")
        if not remote or not remote:IsA("RemoteEvent") then
            return false
        end

        remote:FireServer("CreateEgg", position)
        task.wait(0.12)
        if currentPlacedEggCount() > previousCount then
            return true
        end

        remote:FireServer("PlaceEgg", position)
        task.wait(0.12)
        return currentPlacedEggCount() > previousCount
    end

    function Actions.PlaceSelectedEggsOnce()
        local priority = selectedEggPriorityList()
        if #priority == 0 then
            log("Egg placement skipped: no eggs selected.")
            return 0
        end

        scanInventory()

        local maxEggs = clampNumber(math.floor(tonumber(Config.Hatch.MaxEggsPlaced) or MAX_EGGS_PLACED), 1, 100)
        local alreadyPlaced = currentPlacedEggCount()
        local remainingSlots = math.max(0, maxEggs - alreadyPlaced)
        if remainingSlots <= 0 then
            log(("Egg placement skipped: local farm already has %d/%d egg(s)."):format(alreadyPlaced, maxEggs))
            return 0
        end

        if not getEggPlantLocation() then
            log("Egg placement skipped: local farm Plant_Locations was not found.")
            return 0
        end

        local eggTools = selectedEggToolInstances(priority)
        if #eggTools == 0 then
            log("Egg placement skipped: no selected egg tools found. Equip/buy eggs into your backpack first.")
            return 0
        end

        local placedCount = 0
        for _, egg in ipairs(eggTools) do
            if placedCount >= remainingSlots then
                break
            end

            if egg.Tool and egg.Tool.Parent and equipToolInstance(egg.Tool) then
                task.wait(0.08)
                local cframe = getEggPlacementCFrame(alreadyPlaced + placedCount + 1)
                if placeEquippedEggAt(egg.Name, cframe, alreadyPlaced + placedCount) then
                    placedCount = placedCount + 1
                    task.wait(0.08)
                end
            end
        end

        if placedCount == 0 then
            log("Egg placement skipped: selected egg tools were found, but PetEggService did not place them.")
        else
            log(("Placed %d egg(s) on local farm (%d/%d max) using %s placement."):format(
                placedCount,
                alreadyPlaced + placedCount,
                maxEggs,
                tostring(Config.Hatch.EggPlacementMode)
            ))
        end

        return placedCount
    end

    function Actions.RunHatchTeamsOnce()
        local reductionCount = cyclePetTeam(Config.Hatch.EggReductionPets, "EggReductionIndex", MAX_PETS_EQUIPPED, "Egg reduction team")
        local remainingSlots = math.max(0, MAX_PETS_EQUIPPED - reductionCount)
        local supportCount = 0

        if remainingSlots > 0 then
            supportCount = cyclePetTeam(Config.Hatch.HatchSupportPets, "HatchSupportIndex", remainingSlots, "Hatch support team")
        end

        if reductionCount == 0 and supportCount == 0 then
            log("Hatch teams skipped: no reduction/refund/size pets selected.")
        end

        return reductionCount + supportCount
    end

    function Actions.LogSelectedHatchBuffs()
        local lines = {}
        local totals = {
            SellRefund = 0,
            HatchRefund = 0,
            SizeBoost = 0,
        }
        local seenEntries = {}

        local function addEntry(entry, source)
            if not entry then
                return
            end

            local key = entryUuidKey(entry) or tostring(entry)
            if seenEntries[key] then
                return
            end
            seenEntries[key] = true

            for _, line in ipairs(collectPetBuffLines(entry)) do
                lines[#lines + 1] = source .. " | " .. line
            end

            if applyBuffTotals(entry, totals) then
                lines[#lines + 1] = ("%s | active buff source = %s"):format(source, tostring(entry.Name))
            end
        end

        for _, entry in ipairs(activePlacedPetEntries()) do
            addEntry(entry, "Equipped")
        end

        for _, selected in ipairs({
            Config.Hatch.EggReductionPets,
            Config.Hatch.HatchSupportPets,
            Config.Hatch.SealPets,
        }) do
            for _, entry in ipairs(selectedPetEntries(selected)) do
                addEntry(entry, "Selected")
            end
        end

        if totals.SellRefund > 0 then
            lines[#lines + 1] = ("Active total | sell egg refund chance = %.1f%%"):format(totals.SellRefund)
        end
        if totals.HatchRefund > 0 then
            lines[#lines + 1] = ("Active total | hatch egg refund chance = %.1f%%"):format(totals.HatchRefund)
        end
        if totals.SizeBoost > 0 then
            lines[#lines + 1] = ("Active total | hatch size boost = %.1f%%"):format(totals.SizeBoost)
        end

        local summary = ("Active buffs: Sell refund %.1f%% | Hatch refund %.1f%% | Size boost %.1f%%"):format(
            totals.SellRefund,
            totals.HatchRefund,
            totals.SizeBoost
        )
        if UIRefresh.ActiveBuffSummary then
            UIRefresh.ActiveBuffSummary.Text = summary
        end

        if #lines == 0 then
            log("No active or selected hatch buff stats detected.")
            return 0
        end

        log(summary)
        for _, line in ipairs(lines) do
            log("Detected pet buff: " .. line)
        end

        return #lines
    end

    function Actions.SellUnkeptHatchedPets(eggName, petEntries)
        return sellUnkeptPets(eggName, petEntries, true)
    end
end

installHatchActions()

function Actions.AutoHatch(enabled)
    log("Auto Hatch " .. (enabled and "enabled" or "disabled"))
end

function Actions.HatchOnce()
    local eggObject = findHatchableEggObject()
    if not eggObject then
        log("Auto Hatch skipped: no physical egg found in Farm > Objects_Physical.")
        return false
    end

    if Actions.IsEggReadyToHatch and not Actions.IsEggReadyToHatch(eggObject) then
        log("Auto Hatch skipped: selected egg is not ready yet.")
        return false
    end

    local eggName = getPhysicalEggName(eggObject)
    local previousPetUuidKeys = captureInventoryPetUuidKeys()
    Actions.RunHatchTeamsOnce()
    task.wait(0.2)
    fireGameEvent("PetEggService", "HatchPet", eggObject)
    log("HatchPet fired for " .. tostring(eggObject.Name))

    task.delay(2.5, function()
        if not screenGui.Parent then
            return
        end

        scanInventory()
        local newPetEntries = findNewPetEntries(previousPetUuidKeys)
        for _, petEntry in ipairs(newPetEntries) do
            log(("Hatched %s from %s."):format(tostring(petEntry.Name), tostring(eggName)))
            sendHatchWebhook(eggName, petEntry)
        end
        Actions.SellUnkeptHatchedPets(eggName, newPetEntries)
    end)

    return true
end

function Actions.AutoMutation(enabled)
    log("Auto Mutation " .. (enabled and "enabled" or "disabled"))
end

function isMutationSelected(name)
    return Config.Mutation.SelectedMutations[name] == true
end

function hasSelectedPetGivenMutation()
    for mutationName in pairs(PET_GIVEN_MUTATIONS) do
        if isMutationSelected(mutationName) then
            return true
        end
    end

    return false
end

function Actions.SubmitMutationPetOnce()
    local entry = nextSelectedPetEntry(Config.Mutation.PetsToUse, "MutationIndex")

    if not entry then
        log("Mutation skipped: no selected pet found.")
        return false
    end

    cachePetEntryName(entry)
    local uuid = firstUuid(entry)
    local petTool = firstToolInstance(entry)
    if not petTool and uuid then
        fireGameEvent("PetsService", "UnequipPet", uuid)
        task.wait(0.4)
        scanInventory()
        local latestEntry = findPetEntryByUuidKey(uuidCacheKey(uuid)) or entry
        petTool = firstToolInstance(latestEntry)
        entry = latestEntry
    end

    if not petTool then
        log("Mutation skipped: selected pet is not available as a held Backpack tool: " .. tostring(entry.Name))
        return false
    end

    equipToolInstance(petTool)
    task.wait(0.15)
    fireGameEvent("PetMutationMachine", "SubmitHeldPet")
    log("Submitted mutation pet: " .. tostring(entry.Name))
    return true
end

function Actions.LevelMutationPetsOnce()
    local targetLevel = clampNumber(math.floor(tonumber(Config.Main.LevelTarget) or 100), 1, 100)
    local firedCount = 0

    for _, entry in ipairs(selectedPetEntries(Config.Mutation.PetsToUse)) do
        local uuid = firstUuid(entry)
        local level = getPetLevel(entry)

        if uuid and (not level or level < targetLevel) then
            cachePetEntryName(entry)
            local fired = tryFireGameEvent("PetBoostService", "Level", uuid)
                or tryFireGameEvent("PetBoostService", "XP", uuid)
                or tryFireGameEvent("ActivePetService", "Feed", uuid)

            if fired then
                firedCount = firedCount + 1
            end
        end
    end

    if firedCount > 0 then
        log(("Mutation level team fired for %d pet(s)."):format(firedCount))
    end

    return firedCount
end

function Actions.RunMutationCooldownTeamOnce()
    local entry = nextSelectedPetEntry(Config.Mutation.MutationCooldownPets, "MutationCooldownIndex")
    if not entry then
        log("Mutation cooldown skipped: no cooldown team pets selected in Config.")
        return false
    end

    local uuid = firstUuid(entry)
    if not uuid then
        log("Mutation cooldown skipped: selected pet has no UUID.")
        return false
    end

    cachePetEntryName(entry)
    if not waitForPetAbilityFinished(uuid, firstInstance(entry)) then
        log("Mutation cooldown skipped: ability-finished check timed out for " .. tostring(entry.Name))
        return false
    end

    fireGameEvent("PetsService", "UnequipPet", uuid)
    task.wait(tonumber(Config.Main.PickUpDelay) or 0.6)
    fireGameEvent("PetsService", "EquipPet", uuid, getPlacementCFrame())
    log("Mutation cooldown team cycled: " .. tostring(entry.Name))
    return true
end

function Actions.RunPetGivenMutationOnce()
    local entry = nextSelectedPetEntry(Config.Mutation.PetMutationGivers, "PetMutationGiverIndex")
    if not entry then
        log("Pet mutation skipped: no giver pets selected in Config.")
        return false
    end

    local uuid = firstUuid(entry)
    if not uuid then
        log("Pet mutation skipped: selected giver has no UUID.")
        return false
    end

    cachePetEntryName(entry)
    if not waitForPetAbilityFinished(uuid, firstInstance(entry)) then
        log("Pet mutation skipped: ability-finished check timed out for " .. tostring(entry.Name))
        return false
    end

    fireGameEvent("PetsService", "UnequipPet", uuid)
    task.wait(tonumber(Config.Main.PickUpDelay) or 0.6)
    fireGameEvent("PetsService", "EquipPet", uuid, getPlacementCFrame())
    log("Pet mutation giver cycled: " .. tostring(entry.Name))
    return true
end

function Actions.AutoMutationOnce()
    local ranAny = false

    if isMutationSelected("Mutation Machine") then
        Actions.LevelMutationPetsOnce()
        ranAny = Actions.SubmitMutationPetOnce() or ranAny
        ranAny = Actions.RunMutationCooldownTeamOnce() or ranAny
    end

    if hasSelectedPetGivenMutation() then
        ranAny = Actions.RunPetGivenMutationOnce() or ranAny
    end

    if not ranAny then
        log("Auto Mutation skipped: select Mutation Machine or Venom/Nightmare/Enchanted in Config.")
    end

    return ranAny
end

function Actions.PickAndPlace(enabled)
    log("Pick & Place " .. (enabled and "enabled" or "disabled") .. " | selected pets")
end

function Actions.PickAndPlaceOnce()
    local entry = nextSelectedPetEntry(Config.Main.PickAndPlacePets, "PickAndPlaceIndex")
    if not entry then
        log("Pick & Place skipped: no selected pet found.")
        return false
    end

    cachePetEntryName(entry)
    local uuid = firstUuid(entry)
    if not uuid then
        log("Pick & Place skipped: selected pet has no UUID.")
        return false
    end

    selectedTableRememberUuid(Config.Main.PickAndPlacePets, uuid)
    local petTool = firstInstance(entry)
    if not waitForPetAbilityFinished(uuid, petTool) then
        log("Pick & Place skipped: ability-finished check timed out for " .. tostring(entry.Name))
        return false
    end

    unequipPetEntry(entry)
    task.wait(tonumber(Config.Main.PickUpDelay) or 0.6)
    selectedTableRememberUuid(Config.Main.PickAndPlacePets, uuid)
    equipPetEntry(entry, Runtime.PickAndPlaceIndex)
    task.wait(tonumber(Config.Main.EquipDelay) or 0)
    queueInventoryRefresh("pick and place cycled")
    log("Pick & Place cycled pet: " .. tostring(entry.Name))
    return true
end

local function removeTexturesFromInstance(instance)
    if Runtime.TextureBackups[instance] then
        return
    end

    if instance:IsA("Decal") or instance:IsA("Texture") then
        Runtime.TextureBackups[instance] = {
            Type = "Texture",
            Transparency = instance.Transparency,
        }
        instance.Transparency = 1
    elseif instance:IsA("BasePart") then
        Runtime.TextureBackups[instance] = {
            Type = "Part",
            Material = instance.Material,
            Reflectance = instance.Reflectance,
        }
        instance.Material = Enum.Material.SmoothPlastic
        instance.Reflectance = 0
    elseif instance:IsA("Terrain") then
        local ok, decoration = pcall(function()
            return instance.Decoration
        end)
        if ok then
            Runtime.TextureBackups[instance] = {
                Type = "Terrain",
                Decoration = decoration,
            }
            pcall(function()
                instance.Decoration = false
            end)
        end
    end
end

local function restoreRemovedTextures()
    for instance, backup in pairs(Runtime.TextureBackups) do
        if instance and instance.Parent then
            pcall(function()
                if backup.Type == "Texture" then
                    instance.Transparency = backup.Transparency
                elseif backup.Type == "Part" then
                    instance.Material = backup.Material
                    instance.Reflectance = backup.Reflectance
                elseif backup.Type == "Terrain" then
                    instance.Decoration = backup.Decoration
                end
            end)
        end
    end
    Runtime.TextureBackups = {}
end

function Actions.SetTexturesRemoved(enabled)
    for _, connection in ipairs(Runtime.TextureConnections) do
        connection:Disconnect()
    end
    Runtime.TextureConnections = {}

    if not enabled then
        restoreRemovedTextures()
        return
    end

    for _, instance in ipairs(Workspace:GetDescendants()) do
        pcall(removeTexturesFromInstance, instance)
    end

    Runtime.TextureConnections[#Runtime.TextureConnections + 1] = Workspace.DescendantAdded:Connect(function(instance)
        if Config.Misc.RemoveTextures then
            task.defer(function()
                pcall(removeTexturesFromInstance, instance)
            end)
        end
    end)
end

function Actions.MiscToggle(name, enabled)
    log(name .. " " .. (enabled and "enabled" or "disabled"))

    if name == "Anti Lag" then
        fireGameEvent("SettingsService", "SetSetting", "PerformanceMode", enabled)
    elseif name == "Remove Textures" then
        Actions.SetTexturesRemoved(enabled)
    elseif name == "Auto Un/Favorite" and enabled then
        Actions.FavoriteSelectedPetsOnce()
    elseif name == "Auto Pick Up Fruit" then
        Runtime.FruitCollectLastEmptyLog = 0
    elseif name == "Auto Sell Fruit" and enabled then
        Actions.SellSelectedFruitOnce()
    elseif name == "Auto Buy" and enabled then
        Actions.AutoBuySelectedShopsOnce()
    elseif name == "Auto Place Seeds" and enabled then
        Actions.PlaceSelectedSeedsOnce()
    elseif name == "Auto Rebirth" and enabled then
        Actions.RebirthOnce()
    end
end

