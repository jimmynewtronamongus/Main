local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
end

local function stroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or Theme.Stroke
    s.Thickness = thickness or 1
    s.Parent = parent
end

local function pad(parent, all)
    local p = Instance.new("UIPadding")
    p.PaddingTop = UDim.new(0, all)
    p.PaddingBottom = UDim.new(0, all)
    p.PaddingLeft = UDim.new(0, all)
    p.PaddingRight = UDim.new(0, all)
    p.Parent = parent
end

local function log(message)
    local line = os.date("%H:%M:%S") .. " | " .. tostring(message)
    State.Logs[#State.Logs + 1] = line
    if #State.Logs > 140 then
        table.remove(State.Logs, 1)
    end
    if logLabel then
        logLabel.Text = table.concat(State.Logs, "\n")
        task.defer(function()
            if logLabel and logLabel.Parent then
                local height = math.max(380, logLabel.TextBounds.Y + 24)
                logLabel.Size = UDim2.new(1, -18, 0, height)
                logLabel.Parent.CanvasSize = UDim2.fromOffset(0, height + 24)
            end
        end)
    end
end

local function setStatus(text)
    if statusLabel then
        statusLabel.Text = text
    end
end

local function gameEvents()
    return ReplicatedStorage:FindFirstChild("GameEvents")
end

local function remoteByPath(path)
    local node = gameEvents()
    for _, name in ipairs(path or {}) do
        node = node and node:FindFirstChild(name)
    end
    return node
end

local function remote(name)
    local path = Remotes[name]
    if not path then
        return nil
    end

    local found = remoteByPath(path)
    if found then
        return found
    end

    local root = gameEvents()
    local fallback = path[#path]
    if root and fallback then
        for _, descendant in ipairs(root:GetDescendants()) do
            if descendant.Name == fallback
                and (descendant:IsA("RemoteEvent") or descendant:IsA("RemoteFunction") or descendant:IsA("UnreliableRemoteEvent"))
            then
                return descendant
            end
        end
    end
    return nil
end

local function callRemote(name, ...)
    local r = remote(name)
    if not r then
        return false, nil
    end
    if r:IsA("RemoteFunction") then
        local ok, result = pcall(function(...)
            return r:InvokeServer(...)
        end, ...)
        return ok, result
    end
    if r:IsA("RemoteEvent") or r:IsA("UnreliableRemoteEvent") then
        r:FireServer(...)
        return true, nil
    end
    return false, nil
end

local function callVariants(name, variants, delaySeconds)
    local count = 0
    for _, args in ipairs(variants or {{}}) do
        local ok = callRemote(name, unpackArgs(args))
        if ok then
            count += 1
            if delaySeconds and delaySeconds > 0 then
                task.wait(delaySeconds)
            end
        end
    end
    return count
end

local function buyVariants(remoteName, itemName, index)
    local variants = {}
    if itemName and itemName ~= "" then
        variants[#variants + 1] = {itemName}
        variants[#variants + 1] = {itemName, 1}
        variants[#variants + 1] = {itemName, true}
        variants[#variants + 1] = {"Buy", itemName}
        variants[#variants + 1] = {"Purchase", itemName}
    end
    if index then
        variants[#variants + 1] = {index}
        variants[#variants + 1] = {index, 1}
        if itemName then
            variants[#variants + 1] = {index, itemName}
            variants[#variants + 1] = {itemName, index}
        end
    end
    if #variants == 0 then
        variants[1] = {}
    end
    return callVariants(remoteName, variants, 0.02)
end

local function textOf(instance)
    local pieces = {instance.Name}
    local ok, attrs = pcall(function()
        return instance:GetAttributes()
    end)
    if ok then
        for key, value in pairs(attrs) do
            pieces[#pieces + 1] = tostring(key)
            pieces[#pieces + 1] = tostring(value)
        end
    end
    for _, child in ipairs(instance:GetChildren()) do
        if child:IsA("StringValue") or child:IsA("NumberValue") or child:IsA("BoolValue") then
            pieces[#pieces + 1] = child.Name
            pieces[#pieces + 1] = tostring(child.Value)
        end
    end
    return table.concat(pieces, " "):lower()
end

local function firstUuid(instance)
    local names = {"UUID", "Uuid", "PetUUID", "PetUuid", "ItemUUID", "ItemUuid", "EggUUID", "EggUuid"}
    for _, name in ipairs(names) do
        local ok, value = pcall(function()
            return instance:GetAttribute(name)
        end)
        if ok and value then
            return tostring(value)
        end
        local child = instance:FindFirstChild(name)
        if child and child:IsA("ValueBase") then
            return tostring(child.Value)
        end
    end
    return nil
end

local function addEntry(bucket, displayName, instance)
    displayName = tostring(displayName or instance.Name)
    local entry = {
        Name = displayName,
        Instance = instance,
        Uuid = firstUuid(instance),
    }
    bucket[#bucket + 1] = entry
    return entry
end

local function sortOptions(list)
    table.sort(list, function(a, b)
        return tostring(a) < tostring(b)
    end)
end

local function refreshInventory()
    for key in pairs(Inventory) do
        Inventory[key] = {}
    end
    for key in pairs(Options) do
        if key ~= "Shops" then
            Options[key] = {}
        end
    end

    local seen = {}
    local roots = {backpack, character}
    for _, root in ipairs(roots) do
        if root then
            for _, item in ipairs(root:GetChildren()) do
                if item:IsA("Tool") or item:IsA("Model") then
                    local lower = textOf(item)
                    local bucket
                    if lower:find("seed pack", 1, true) or lower:find("pack", 1, true) then
                        bucket = "SeedPacks"
                    elseif lower:find("egg", 1, true) then
                        bucket = "Eggs"
                    elseif lower:find("seed", 1, true) then
                        bucket = "Seeds"
                    elseif lower:find("fruit", 1, true) or lower:find("kg", 1, true) then
                        bucket = "Fruits"
                    elseif lower:find("pet", 1, true) or firstUuid(item) then
                        bucket = "Pets"
                    end
                    if bucket then
                        addEntry(Inventory[bucket], item.Name, item)
                        if not seen[bucket .. item.Name] then
                            seen[bucket .. item.Name] = true
                            Options[bucket][#Options[bucket] + 1] = item.Name
                        end
                    end
                end
            end
        end
    end

    local petsPhysical = Workspace:FindFirstChild("PetsPhysical")
    local petMover = petsPhysical and petsPhysical:FindFirstChild("PetMover")
    if petMover then
        for _, pet in ipairs(petMover:GetChildren()) do
            addEntry(Inventory.Pets, pet.Name, pet)
            if not seen["Pets" .. pet.Name] then
                seen["Pets" .. pet.Name] = true
                Options.Pets[#Options.Pets + 1] = pet.Name
            end
        end
    end

    for _, fallback in ipairs(DefaultEggs) do
        if not seen["Eggs" .. fallback] then
            Options.Eggs[#Options.Eggs + 1] = fallback
        end
    end
    for _, fallback in ipairs(DefaultSeeds) do
        if not seen["Seeds" .. fallback] then
            Options.Seeds[#Options.Seeds + 1] = fallback
        end
    end
    for _, fallback in ipairs(DefaultSeedPacks) do
        if not seen["SeedPacks" .. fallback] then
            Options.SeedPacks[#Options.SeedPacks + 1] = fallback
        end
    end

    for key, list in pairs(Options) do
        if type(list) == "table" and key ~= "Shops" then
            sortOptions(list)
        end
    end

    for _, refresh in pairs(refreshers) do
        refresh()
    end

    if summaryLabel then
        summaryLabel.Text = ("Eggs %d | Seeds %d | Pets %d | Fruits %d | Packs %d"):format(
            #Inventory.Eggs, #Inventory.Seeds, #Inventory.Pets, #Inventory.Fruits, #Inventory.SeedPacks
        )
    end

    log("Inventory refreshed.")
end

local function equip(instance)
    if not instance then
        return false
    end
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if humanoid and instance:IsA("Tool") then
        pcall(function()
            humanoid:EquipTool(instance)
        end)
        return true
    end
    if instance.Parent == backpack then
        instance.Parent = character
        return true
    end
    return false
end

local function selectedEntries(bucket, selected)
    local out = {}
    local empty = #(selectedNames(selected)) == 0
    for _, entry in ipairs(Inventory[bucket] or {}) do
        if empty or hasSelection(selected, entry.Name) then
            out[#out + 1] = entry
        end
    end
    return out
end

local function farmOwnerText(farm)
    local data = farm and farm:FindFirstChild("Important")
    data = data and data:FindFirstChild("Data")
    local owner = data and data:FindFirstChild("Owner")
    if owner and owner:IsA("ValueBase") and owner.Value ~= nil then
        return tostring(owner.Value)
    end

    for _, key in ipairs({"Owner", "OwnerName", "PlayerName", "UserId", "OwnerId"}) do
        local ok, value = pcall(function()
            return farm:GetAttribute(key)
        end)
        if ok and value ~= nil then
            return tostring(value)
        end
    end
    return nil
end

local function isOwnFarm(farm)
    local owner = farmOwnerText(farm)
    if not owner or owner == "" then
        return false
    end
    return owner == player.Name
        or owner == player.DisplayName
        or owner == tostring(player.UserId)
end

local function findOwnFarm()
    local roots = {
        Workspace:FindFirstChild("Farm"),
        Workspace:FindFirstChild("Farms"),
        Workspace:FindFirstChild("Plots"),
        Workspace:FindFirstChild("PlayerFarms"),
    }

    for _, root in ipairs(roots) do
        if root then
            if isOwnFarm(root) then
                return root
            end
            for _, child in ipairs(root:GetChildren()) do
                if isOwnFarm(child) then
                    return child
                end
                local nested = child:FindFirstChild("Farm")
                if nested and isOwnFarm(nested) then
                    return nested
                end
            end
        end
    end

    for _, descendant in ipairs(Workspace:GetDescendants()) do
        if descendant.Name == "Important" and descendant.Parent and isOwnFarm(descendant.Parent) then
            return descendant.Parent
        end
    end
    return nil
end

local function ownFarmImportant()
    local farm = findOwnFarm()
    return farm and farm:FindFirstChild("Important")
end

local function eggPlacementArea()
    local important = ownFarmImportant()
    local locations = important and important:FindFirstChild("Plant_Locations")
    if locations then
        for _, descendant in ipairs(locations:GetDescendants()) do
            if descendant.Name == "Can_Plant" and descendant:IsA("BasePart") then
                return descendant
            end
        end
    end
    return nil
end

local function placementCFrame(index)
    local area = eggPlacementArea()
    if area then
        local columns = 4
        local spacing = 4
        local col = (index - 1) % columns
        local rowIndex = math.floor((index - 1) / columns)
        local width = math.max(0, area.Size.X - 6)
        local depth = math.max(0, area.Size.Z - 6)
        local x = math.clamp((col - (columns - 1) / 2) * spacing, -width / 2, width / 2)
        local z = math.clamp((rowIndex - 1) * spacing, -depth / 2, depth / 2)
        return area.CFrame * CFrame.new(x, 0.5, z)
    end

    return nil
end

local Actions = {}

function Actions.AutoBuyOnce()
    local fired = 0
    local shops = selectedNames(Config.Shops.SelectedShops)
    if #shops == 0 then
        shops = Options.Shops
    end
    local eggs = selectedNames(Config.Hatch.SelectedEggs)
    if #eggs == 0 then
        eggs = DefaultEggs
    end

    for _, shop in ipairs(shops) do
        if shop == "Seed Shop" then
            for index, name in ipairs(DefaultSeeds) do
                fired += buyVariants("BuySeedStock", name, index)
                fired += buyVariants("BuyDailySeedShopStock", name, index)
            end
        elseif shop == "Gear Shop" then
            for index, name in ipairs(DefaultGear) do
                fired += buyVariants("BuyGearStock", name, index)
            end
        elseif shop == "Egg Shop" then
            for index, name in ipairs(eggs) do
                fired += buyVariants("BuyPetEgg", name, index)
            end
        elseif shop == "Cosmetic Shop" then
            fired += buyVariants("BuyCosmeticItem")
            fired += buyVariants("BuyCosmeticCrate")
            fired += buyVariants("BuyCosmeticShopFence")
        elseif shop == "Event Merchant" then
            for index, name in ipairs(DefaultEventItems) do
                fired += buyVariants("BuyEventShopStock", name, index)
            end
            local ok = callRemote("BuyEventShopRestock")
            if ok then fired += 1 end
        elseif shop == "Traveling Merchant" then
            for index, name in ipairs(DefaultEventItems) do
                fired += buyVariants("BuyTravelingMerchantShopStock", name, index)
            end
        elseif shop == "Garden Coin Shop" then
            for index, name in ipairs(DefaultEventItems) do
                fired += buyVariants("BuyGardenCoinShopStock", name, index)
            end
        elseif shop == "Night Event Shop" then
            for index, name in ipairs(DefaultEventItems) do
                fired += buyVariants("BuyNightEventShopStock", name, index)
            end
        elseif shop == "Easter Shop" then
            for index, name in ipairs(DefaultEventItems) do
                fired += buyVariants("BuyEasterStock", name, index)
            end
        end
    end
    log(("Auto Buy sent %d request(s)."):format(fired))
end

function Actions.ClaimRewardsOnce()
    local fired = 0
    local claims = {
        {"AchievementClaim", 12}, {"DailyQuestClaim", 12}, {"QuestClaim", 12},
        {"SeasonPassClaimReward", 20}, {"SeasonPassClaimQuest", 12},
        {"SeasonPassClaimInfinite", 4}, {"InfinitePackClaim", 8},
        {"InfinitePackEventClaim", 8}, {"ClaimChipmunkRewards", 12},
        {"ClaimLeafBlower", 4}, {"ClaimDinoQuest", 12},
        {"ConfirmItemInstanceClaim", 8}, {"WateringCanClaim", 4},
    }
    for _, item in ipairs(claims) do
        local variants = {{}}
        for index = 1, item[2] do
            variants[#variants + 1] = {index}
            variants[#variants + 1] = {tostring(index)}
        end
        fired += callVariants(item[1], variants, 0.03)
    end
    fired += buyVariants("GardenGameSpin")
    fired += buyVariants("SpinnerGame")
    log(("Claim sweep sent %d request(s)."):format(fired))
end

function Actions.OpenSeedPacksOnce()
    local fired = 0
    local entries = selectedEntries("SeedPacks", Config.Rewards.SelectedPacks)
    for _, entry in ipairs(entries) do
        equip(entry.Instance)
        task.wait(0.03)
        local variants = {{}, {entry.Name}}
        if entry.Uuid then
            variants[#variants + 1] = {entry.Uuid}
            variants[#variants + 1] = {entry.Name, entry.Uuid}
        end
        variants[#variants + 1] = {entry.Instance}
        fired += callVariants("SeedPackOpen", variants, 0.03)
    end
    if fired == 0 then
        for index, name in ipairs(DefaultSeedPacks) do
            fired += buyVariants("SeedPackOpen", name, index)
        end
    end
    log(("Seed pack opener sent %d request(s)."):format(fired))
end

local function normalizedEggText(value)
    return tostring(value or "")
        :lower()
        :gsub("%b[]", " ")
        :gsub("%b()", " ")
        :gsub("[_%-]+", " ")
        :gsub("%s+", " ")
        :gsub("^%s+", "")
        :gsub("%s+$", "")
end

local function eggDisplayName(egg)
    for _, key in ipairs({"EggName", "PetEggName", "EggType", "Type", "DisplayName", "ItemName"}) do
        local ok, value = pcall(function()
            return egg:GetAttribute(key)
        end)
        if ok and value and tostring(value) ~= "" then
            return tostring(value)
        end
        local child = egg:FindFirstChild(key)
        if child and child:IsA("ValueBase") and child.Value and tostring(child.Value) ~= "" then
            return tostring(child.Value)
        end
    end
    return egg.Name
end

local function eggMatchesSelection(egg, selected)
    local names = selectedNames(selected)
    if #names == 0 then
        return true
    end

    local haystack = normalizedEggText(egg.Name .. " " .. eggDisplayName(egg) .. " " .. textOf(egg))
    for _, selectedName in ipairs(names) do
        local needle = normalizedEggText(selectedName)
        if needle ~= "" and haystack:find(needle, 1, true) then
            return true
        end
    end
    return false
end

local function eggReady(egg)
    local lower = textOf(egg)
    if lower:find("can hatch", 1, true)
        or lower:find("canhatch true", 1, true)
        or lower:find("hatchready true", 1, true)
        or lower:find("ready true", 1, true)
        or lower:find("ready!", 1, true)
    then
        return true
    end

    for _, key in ipairs({"Ready", "CanHatch", "HatchReady", "IsReady"}) do
        local ok, value = pcall(function()
            return egg:GetAttribute(key)
        end)
        if ok and value == true then
            return true
        end
        local child = egg:FindFirstChild(key)
        if child and child:IsA("BoolValue") and child.Value == true then
            return true
        end
    end

    local now = os.time()
    for _, key in ipairs({"HatchAt", "ReadyAt", "HatchReadyAt", "FinishTime", "EndTime"}) do
        local ok, value = pcall(function()
            return egg:GetAttribute(key)
        end)
        if ok and tonumber(value) and tonumber(value) <= now then
            return true
        end
        local child = egg:FindFirstChild(key)
        if child and child:IsA("ValueBase") and tonumber(child.Value) and tonumber(child.Value) <= now then
            return true
        end
    end

    for _, key in ipairs({"TimeLeft", "TimeRemaining", "ReadyTime", "HatchTime", "HatchTimeLeft", "HatchTimeRemaining", "Remaining", "Cooldown"}) do
        local ok, value = pcall(function()
            return egg:GetAttribute(key)
        end)
        if ok and tonumber(value) and tonumber(value) <= 0 then
            return true
        end
        local child = egg:FindFirstChild(key)
        if child and child:IsA("ValueBase") and tonumber(child.Value) and tonumber(child.Value) <= 0 then
            return true
        end
    end

    return false
end

local function eggWorldPosition(egg)
    if egg:IsA("BasePart") then
        return egg.Position
    end
    if egg:IsA("Model") then
        local ok, cf = pcall(function()
            return egg:GetPivot()
        end)
        if ok then
            return cf.Position
        end
        local part = egg.PrimaryPart or egg:FindFirstChildWhichIsA("BasePart", true)
        return part and part.Position
    end
    local part = egg:FindFirstChildWhichIsA("BasePart", true)
    return part and part.Position
end

local function eggRoots()
    local roots = {}
    local important = ownFarmImportant()
    local physical = important and important:FindFirstChild("Objects_Physical")
    if physical then
        roots[#roots + 1] = physical
    elseif important then
        roots[#roots + 1] = important
    end
    if #roots == 0 then
        local farm = findOwnFarm()
        if farm then
            roots[1] = farm
        end
    end
    return roots
end

local function findReadyEggs()
    local selected = Config.Hatch.SelectedEggs
    local found = {}
    local seen = {}
    local root = character and character:FindFirstChild("HumanoidRootPart")
    local rootPos = root and root.Position

    for _, searchRoot in ipairs(eggRoots()) do
        for _, descendant in ipairs(searchRoot:GetDescendants()) do
            if not seen[descendant]
                and (descendant:IsA("Model") or descendant:IsA("BasePart") or descendant:IsA("Folder"))
            then
                seen[descendant] = true
                local lower = normalizedEggText(descendant.Name .. " " .. textOf(descendant))
                if lower:find("egg", 1, true)
                    and eggMatchesSelection(descendant, selected)
                    and eggReady(descendant)
                then
                    local pos = eggWorldPosition(descendant)
                    local distance = (rootPos and pos) and (pos - rootPos).Magnitude or 0
                    found[#found + 1] = {
                        Egg = descendant,
                        Distance = distance,
                    }
                end
            end
        end
    end

    table.sort(found, function(a, b)
        return a.Distance < b.Distance
    end)
    return found
end

local function countPhysicalEggs()
    local count = 0
    local seen = {}
    for _, searchRoot in ipairs(eggRoots()) do
        for _, descendant in ipairs(searchRoot:GetDescendants()) do
            if not seen[descendant]
                and (descendant:IsA("Model") or descendant:IsA("Folder"))
            then
                seen[descendant] = true
                local lower = normalizedEggText(descendant.Name .. " " .. textOf(descendant))
                if lower:find("egg", 1, true) then
                    count += 1
                end
            end
        end
    end
    return count
end

local function hatchEgg(egg)
    local ok = callRemote("PetEggService", "HatchPet", egg)
    return ok and 1 or 0
end

function Actions.HatchOnce()
    local eggs = findReadyEggs()
    if #eggs == 0 then
        log("Hatch skipped: no ready selected egg found.")
        return false
    end

    local fired = hatchEgg(eggs[1].Egg)
    local name = eggDisplayName(eggs[1].Egg)
    log(fired > 0 and ("Hatch sent " .. fired .. " request(s) for " .. name .. ".") or "Hatch skipped: PetEggService missing.")
    task.delay(1, refreshInventory)
    return fired > 0
end

function Actions.PlaceEggsOnce()
    local count = 0
    local maxEggs = math.max(1, tonumber(Config.Hatch.MaxEggsPlaced) or MAX_EGGS_PLACED)
    local alreadyPlaced = countPhysicalEggs()
    local remainingSlots = math.max(0, maxEggs - alreadyPlaced)
    if remainingSlots <= 0 then
        log(("Place eggs skipped: already at %d/%d physical egg(s)."):format(alreadyPlaced, maxEggs))
        return 0
    end

    for _, entry in ipairs(selectedEntries("Eggs", Config.Hatch.SelectedEggs)) do
        if count >= remainingSlots then
            break
        end

        equip(entry.Instance)
        task.wait(0.08)
        local cf = placementCFrame(alreadyPlaced + count + 1)
        if not cf then
            log("Place eggs skipped: could not find your own garden Plant_Locations.")
            return count
        end
        local pos = cf.Position

        local before = countPhysicalEggs()
        local placed = callRemote("PetEggService", "CreateEgg", pos)
        task.wait(0.12)
        if countPhysicalEggs() <= before then
            placed = callRemote("PetEggService", "PlaceEgg", pos)
            task.wait(0.12)
        end

        if placed and countPhysicalEggs() > before then
            count += 1
        elseif entry.Instance and entry.Instance:IsA("Tool") then
            local activated = pcall(function()
                entry.Instance:Activate()
            end)
            if activated then
                count += 1
            end
        end
    end
    log(("Placed %d egg(s), now at about %d/%d."):format(count, alreadyPlaced + count, maxEggs))
    task.delay(1, refreshInventory)
    return count
end

function Actions.FeedPetsOnce()
