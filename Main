local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
end

local function stroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or Theme.Stroke
    s.Thickness = thickness or 1
    s.Parent = parent
end

local function pad(parent, all)
    local p = Instance.new("UIPadding")
    p.PaddingTop = UDim.new(0, all)
    p.PaddingBottom = UDim.new(0, all)
    p.PaddingLeft = UDim.new(0, all)
    p.PaddingRight = UDim.new(0, all)
    p.Parent = parent
end

local function log(message)
    local line = os.date("%H:%M:%S") .. " | " .. tostring(message)
    State.Logs[#State.Logs + 1] = line
    if #State.Logs > 140 then
        table.remove(State.Logs, 1)
    end
    if logLabel then
        logLabel.Text = table.concat(State.Logs, "\n")
        task.defer(function()
            if logLabel and logLabel.Parent then
                local height = math.max(380, logLabel.TextBounds.Y + 24)
                logLabel.Size = UDim2.new(1, -18, 0, height)
                logLabel.Parent.CanvasSize = UDim2.fromOffset(0, height + 24)
            end
        end)
    end
end

local function setStatus(text)
    if statusLabel then
        statusLabel.Text = text
    end
end

local function gameEvents()
    return ReplicatedStorage:FindFirstChild("GameEvents")
end

local function remoteByPath(path)
    local node = gameEvents()
    for _, name in ipairs(path or {}) do
        node = node and node:FindFirstChild(name)
    end
    return node
end

local function remote(name)
    local path = Remotes[name]
    if not path then
        return nil
    end

    local found = remoteByPath(path)
    if found then
        return found
    end

    local root = gameEvents()
    local fallback = path[#path]
    if root and fallback then
        for _, descendant in ipairs(root:GetDescendants()) do
            if descendant.Name == fallback
                and (descendant:IsA("RemoteEvent") or descendant:IsA("RemoteFunction") or descendant:IsA("UnreliableRemoteEvent"))
            then
                return descendant
            end
        end
    end
    return nil
end

local function callRemote(name, ...)
    local r = remote(name)
    if not r then
        return false, nil
    end
    if r:IsA("RemoteFunction") then
        local ok, result = pcall(function(...)
            return r:InvokeServer(...)
        end, ...)
        return ok, result
    end
    if r:IsA("RemoteEvent") or r:IsA("UnreliableRemoteEvent") then
        r:FireServer(...)
        return true, nil
    end
    return false, nil
end

local function callVariants(name, variants, delaySeconds)
    local count = 0
    for _, args in ipairs(variants or {{}}) do
        local ok = callRemote(name, unpackArgs(args))
        if ok then
            count += 1
            if delaySeconds and delaySeconds > 0 then
                task.wait(delaySeconds)
            end
        end
    end
    return count
end

local function buyVariants(remoteName, itemName, index)
    local variants = {}
    if itemName and itemName ~= "" then
        variants[#variants + 1] = {itemName}
        variants[#variants + 1] = {itemName, 1}
        variants[#variants + 1] = {itemName, true}
        variants[#variants + 1] = {"Buy", itemName}
        variants[#variants + 1] = {"Purchase", itemName}
    end
    if index then
        variants[#variants + 1] = {index}
        variants[#variants + 1] = {index, 1}
        if itemName then
            variants[#variants + 1] = {index, itemName}
            variants[#variants + 1] = {itemName, index}
        end
    end
    if #variants == 0 then
        variants[1] = {}
    end
    return callVariants(remoteName, variants, 0.02)
end

local function textOf(instance)
    local pieces = {instance.Name}
    local ok, attrs = pcall(function()
        return instance:GetAttributes()
    end)
    if ok then
        for key, value in pairs(attrs) do
            pieces[#pieces + 1] = tostring(key)
            pieces[#pieces + 1] = tostring(value)
        end
    end
    for _, child in ipairs(instance:GetChildren()) do
        if child:IsA("StringValue") or child:IsA("NumberValue") or child:IsA("BoolValue") then
            pieces[#pieces + 1] = child.Name
            pieces[#pieces + 1] = tostring(child.Value)
        end
    end
    return table.concat(pieces, " "):lower()
end

local function firstUuid(instance)
    local names = {"UUID", "Uuid", "PetUUID", "PetUuid", "ItemUUID", "ItemUuid", "EggUUID", "EggUuid"}
    for _, name in ipairs(names) do
        local ok, value = pcall(function()
            return instance:GetAttribute(name)
        end)
        if ok and value then
            return tostring(value)
        end
        local child = instance:FindFirstChild(name)
        if child and child:IsA("ValueBase") then
            return tostring(child.Value)
        end
    end
    return nil
end

local function normalizedName(value)
    return tostring(value or "")
        :lower()
        :gsub("[^%w]+", "")
end

local function trim(value)
    return tostring(value or ""):gsub("^%s+", ""):gsub("%s+$", "")
end

local function csvList(text)
    local out = {}
    local seen = {}
    for value in tostring(text or ""):gmatch("[^,]+") do
        value = trim(value)
        local key = normalizedName(value)
        if key ~= "" and not seen[key] then
            seen[key] = true
            out[#out + 1] = value
        end
    end
    return out
end

local function addUnique(list, seen, value)
    value = tostring(value or "")
    if value == "" then
        return
    end
    local key = normalizedName(value)
    if key ~= "" and not seen[key] then
        seen[key] = true
        list[#list + 1] = value
    end
end

local function petMutationNames(instance)
    local names = {}
    local seen = {}
    if not instance then
        return names
    end

    local ok, attrs = pcall(function()
        return instance:GetAttributes()
    end)
    if ok then
        for key, value in pairs(attrs) do
            local keyText = tostring(key)
            local valueText = tostring(value)
            local lowerKey = keyText:lower()
            if lowerKey:find("mutation", 1, true) or lowerKey:find("variant", 1, true) or lowerKey:find("trait", 1, true) then
                if type(value) == "boolean" then
                    if value then addUnique(names, seen, keyText) end
                else
                    addUnique(names, seen, valueText)
                end
            end
        end
    end

    for _, descendant in ipairs(instance:GetDescendants()) do
        if descendant:IsA("StringValue") or descendant:IsA("NumberValue") or descendant:IsA("BoolValue") then
            local lowerName = descendant.Name:lower()
            if lowerName:find("mutation", 1, true) or lowerName:find("variant", 1, true) or lowerName:find("trait", 1, true) then
                if descendant:IsA("BoolValue") then
                    if descendant.Value then addUnique(names, seen, descendant.Name) end
                else
                    addUnique(names, seen, descendant.Value)
                end
            end
        end
    end

    local text = normalizedName(textOf(instance))
    for _, mutation in ipairs(DefaultMutations) do
        if text:find(normalizedName(mutation), 1, true) then
            addUnique(names, seen, mutation)
        end
    end
    for mutation in pairs((Config and Config.Hatch and Config.Hatch.KeepMutations) or {}) do
        if mutation ~= "__order" and text:find(normalizedName(mutation), 1, true) then
            addUnique(names, seen, mutation)
        end
    end
    return names
end

local function addEntry(bucket, displayName, instance)
    displayName = tostring(displayName or instance.Name)
    local entry = {
        Name = displayName,
        Instance = instance,
        Uuid = firstUuid(instance),
    }
    bucket[#bucket + 1] = entry
    return entry
end

local function sortOptions(list)
    table.sort(list, function(a, b)
        return tostring(a) < tostring(b)
    end)
end

local function isPetItem(instance)
    local lowerName = tostring(instance and instance.Name or ""):lower()
    if lowerName:find("egg", 1, true)
        or lowerName:find("seed", 1, true)
        or lowerName:find("pack", 1, true)
        or lowerName:find("sprinkler", 1, true)
        or lowerName:find("trowel", 1, true)
        or lowerName:find("wrench", 1, true)
        or lowerName:find("tool", 1, true)
        or lowerName:find("fruit", 1, true)
    then
        return false
    end

    local lower = textOf(instance)
    if lower:find("pettool", 1, true)
        or lower:find("petuuid", 1, true)
        or lower:find("age ", 1, true)
        or lower:find("[age", 1, true)
        or lower:find(" kg", 1, true)
    then
        return true
    end

    for _, child in ipairs(instance:GetChildren()) do
        local childName = child.Name:lower()
        if childName:find("pet", 1, true) and (child:IsA("LocalScript") or child:IsA("Script") or child:IsA("ModuleScript")) then
            return true
        end
    end
    return false
end

local function petKgFromName(name)
    local text = tostring(name or "")
    local value = text:match("([%d%.]+)%s*[Kk][Gg]")
    return tonumber(value)
end

local function petBaseName(name)
    return tostring(name or "")
        :gsub("%s*%[[^%]]+%]", "")
        :gsub("%s+", " ")
        :gsub("^%s+", "")
        :gsub("%s+$", "")
end

local function petKg(entry)
    return petKgFromName(entry and entry.Name) or petKgFromName(entry and entry.Instance and textOf(entry.Instance)) or 0
end

local function petNameMatches(entry, target)
    local name = normalizedName(entry and entry.Name)
    local instanceName = normalizedName(entry and entry.Instance and entry.Instance.Name)
    local needle = normalizedName(target)
    return name:find(needle, 1, true) ~= nil or instanceName:find(needle, 1, true) ~= nil
end

local function highestPetByName(target)
    local best
    local bestKg = -1
    for _, entry in ipairs(Inventory.Pets or {}) do
        if petNameMatches(entry, target) then
            local kg = petKg(entry)
            if kg > bestKg then
                best = entry
                bestKg = kg
            end
        end
    end
    return best
end

local function setSinglePetSelection(selection, entry)
    if entry then
        setSelectionFromList(selection, {entry.Name})
    else
        setSelectionFromList(selection, {})
    end
end

local function autoSelectSpecificPetTeams()
    setSinglePetSelection(Config.Hatch.SealTeam, highestPetByName("Seal"))
    setSinglePetSelection(Config.Hatch.KoiTeam, highestPetByName("Koi"))
    setSinglePetSelection(Config.Hatch.BrontoTeam, highestPetByName("Bronto"))
    setSinglePetSelection(Config.Pets.KgBoostTeam, highestPetByName("Elephant"))
end

local function refreshInventory()
    for key in pairs(Inventory) do
        Inventory[key] = {}
    end
    for key in pairs(Options) do
        if key ~= "Shops" then
            Options[key] = {}
        end
    end

    local seen = {}
    local roots = {backpack, character}
    for _, root in ipairs(roots) do
        if root then
            for _, item in ipairs(root:GetChildren()) do
                if item:IsA("Tool") or item:IsA("Model") then
                    local lower = textOf(item)
                    local bucket
                    if lower:find("seed pack", 1, true) or lower:find("pack", 1, true) then
                        bucket = "SeedPacks"
                    elseif lower:find("egg", 1, true) then
                        bucket = "Eggs"
                    elseif lower:find("seed", 1, true) then
                        bucket = "Seeds"
                    elseif isPetItem(item) then
                        bucket = "Pets"
                    elseif lower:find("fruit", 1, true) or lower:find("kg", 1, true) then
                        bucket = "Fruits"
                    end
                    if bucket then
                        local displayName = bucket == "Eggs" and canonicalEggName(item.Name) or (bucket == "Pets" and petBaseName(item.Name) or item.Name)
                        addEntry(Inventory[bucket], displayName, item)
                        if not seen[bucket .. displayName] then
                            seen[bucket .. displayName] = true
                            Options[bucket][#Options[bucket] + 1] = displayName
                        end
                        if bucket == "Pets" then
                            for _, mutation in ipairs(petMutationNames(item)) do
                                if not seen["Mutations" .. mutation] then
                                    seen["Mutations" .. mutation] = true
                                    Options.Mutations[#Options.Mutations + 1] = mutation
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    local petsPhysical = Workspace:FindFirstChild("PetsPhysical")
    local petMover = petsPhysical and petsPhysical:FindFirstChild("PetMover")
    if petMover then
        for _, pet in ipairs(petMover:GetChildren()) do
            local displayName = petBaseName(pet.Name)
            addEntry(Inventory.Pets, displayName, pet)
            if not seen["Pets" .. displayName] then
                seen["Pets" .. displayName] = true
                Options.Pets[#Options.Pets + 1] = displayName
            end
            for _, mutation in ipairs(petMutationNames(pet)) do
                if not seen["Mutations" .. mutation] then
                    seen["Mutations" .. mutation] = true
                    Options.Mutations[#Options.Mutations + 1] = mutation
                end
            end
        end
    end

    for _, fallback in ipairs(DefaultEggs) do
        if not seen["Eggs" .. fallback] then
            Options.Eggs[#Options.Eggs + 1] = fallback
        end
    end
    normalizeEggSelection()
    for _, fallback in ipairs(DefaultSeeds) do
        if not seen["Seeds" .. fallback] then
            Options.Seeds[#Options.Seeds + 1] = fallback
        end
    end
    for _, fallback in ipairs(DefaultSeedPacks) do
        if not seen["SeedPacks" .. fallback] then
            Options.SeedPacks[#Options.SeedPacks + 1] = fallback
        end
    end
    for _, fallback in ipairs(DefaultMutations) do
        if not seen["Mutations" .. fallback] then
            seen["Mutations" .. fallback] = true
            Options.Mutations[#Options.Mutations + 1] = fallback
        end
    end
    for mutation in pairs(Config.Hatch.KeepMutations or {}) do
        if mutation ~= "__order" and not seen["Mutations" .. mutation] then
            seen["Mutations" .. mutation] = true
            Options.Mutations[#Options.Mutations + 1] = mutation
        end
    end
    autoSelectSpecificPetTeams()

    for key, list in pairs(Options) do
        if type(list) == "table" and key ~= "Shops" then
            sortOptions(list)
        end
    end

    for _, refresh in pairs(refreshers) do
        refresh()
    end

    if summaryLabel then
        summaryLabel.Text = ("Eggs %d | Seeds %d | Pets %d | Fruits %d | Packs %d"):format(
            #Inventory.Eggs, #Inventory.Seeds, #Inventory.Pets, #Inventory.Fruits, #Inventory.SeedPacks
        )
    end

    log("Inventory refreshed.")
end

local function equip(instance)
    if not instance then
        return false
    end
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if humanoid and instance:IsA("Tool") then
        pcall(function()
            humanoid:EquipTool(instance)
        end)
        return true
    end
    if instance.Parent == backpack then
        instance.Parent = character
        return true
    end
    return false
end

local function selectedEntries(bucket, selected)
    local out = {}
    local empty = #(selectedNames(selected)) == 0
    for _, entry in ipairs(Inventory[bucket] or {}) do
        local selectedMatch = bucket == "Eggs" and hasEggSelection(selected, entry.Name) or hasSelection(selected, entry.Name)
        if empty or selectedMatch then
            out[#out + 1] = entry
        end
    end
    return out
end

local function mutationMatchesKeep(mutations)
    local selected = Config.Hatch.KeepMutations or {}
    for _, mutation in ipairs(mutations or {}) do
        local mutationKey = normalizedName(mutation)
        for selectedName, enabled in pairs(selected) do
            if selectedName ~= "__order" and enabled and mutationKey == normalizedName(selectedName) then
                return mutation
            end
        end
    end
    return nil
end

local function petEntryKey(entry)
    if entry.Uuid then
        return "uuid:" .. entry.Uuid
    end
    if entry.Instance then
        local ok, debugId = pcall(function()
            return entry.Instance:GetDebugId()
        end)
        if ok and debugId then
            return "instance:" .. debugId
        end
        return "instance:" .. entry.Instance:GetFullName()
    end
    return "name:" .. tostring(entry.Name)
end

local function capturePetKeys()
    local keys = {}
    refreshInventory()
    for _, entry in ipairs(Inventory.Pets or {}) do
        keys[petEntryKey(entry)] = true
    end
    return keys
end

local function favoritePetEntry(entry)
    local variants = {}
    if entry.Uuid then
        variants[#variants + 1] = {entry.Uuid, true}
        variants[#variants + 1] = {entry.Uuid}
    end
    if entry.Instance then
        variants[#variants + 1] = {entry.Instance, true}
        variants[#variants + 1] = {entry.Instance}
    end
    return callVariants("FavoriteItem", variants, 0.02)
end

local function petAge(entry)
    local text = tostring(entry and entry.Name or "") .. " " .. tostring(entry and entry.Instance and textOf(entry.Instance) or "")
    return tonumber(text:match("[Aa]ge%s*(%d+)")) or tonumber(text:match("%[Age%s*(%d+)%]")) or 1
end

local function petLevel(entry)
    local instance = entry and entry.Instance
    if instance then
        for _, key in ipairs({"Level", "Lvl", "PetLevel"}) do
            local ok, value = pcall(function()
                return instance:GetAttribute(key)
            end)
            if ok and tonumber(value) then
                return tonumber(value)
            end
            local child = instance:FindFirstChild(key)
            if child and child:IsA("ValueBase") and tonumber(child.Value) then
                return tonumber(child.Value)
            end
        end
    end
    local text = tostring(entry and entry.Name or "") .. " " .. tostring(instance and textOf(instance) or "")
    return tonumber(text:match("[Ll]evel%s*(%d+)")) or tonumber(text:match("[Ll]vl%s*(%d+)")) or petAge(entry)
end

local function petBaseKg(entry)
    local instance = entry and entry.Instance
    if instance then
        for _, key in ipairs({"BaseWeight", "BaseKG", "BaseKg", "BaseMass", "Weight", "KG", "Kg"}) do
            local ok, value = pcall(function()
                return instance:GetAttribute(key)
            end)
            if ok and tonumber(value) then
                return tonumber(value)
            end
            local child = instance:FindFirstChild(key)
            if child and child:IsA("ValueBase") and tonumber(child.Value) then
                return tonumber(child.Value)
            end
        end
    end
    return petKg(entry)
end

local function petNameMatchesList(entry, names)
    if not names or #names == 0 then
        return false
    end
    local haystack = normalizedName(petBaseName(entry and entry.Name))
    if haystack == "" then
        haystack = normalizedName(entry and entry.Name)
    end
    for _, name in ipairs(names) do
        local needle = normalizedName(name)
        if needle ~= "" and (haystack == needle or haystack:find(needle, 1, true)) then
            return name
        end
    end
    return false
end

local function petNameSelectedForKeep(entry)
    return petNameMatchesList(entry, selectedNames(Config.Hatch.KeepPetNames))
end

local function ensureEggPetRules()
    if type(Config.Hatch.PetRulesByEgg) ~= "table" then
        Config.Hatch.PetRulesByEgg = {}
    end
    return Config.Hatch.PetRulesByEgg
end

local function setEggPetRule()
    local eggName = canonicalEggName(Config.Hatch.RuleEggName)
    if eggName == "" then
        return
    end
    local keepPets = csvList(Config.Hatch.RuleKeepPets)
    local sellPets = csvList(Config.Hatch.RuleSellPets)
    ensureEggPetRules()[eggName] = {
        Keep = keepPets,
        Sell = sellPets,
    }
end

local function eggPetRule(eggName)
    local rules = ensureEggPetRules()
    local canonical = canonicalEggName(eggName)
    return rules[canonical] or rules[tostring(eggName or "")]
end

local function sellPetEntry(entry)
    local variants = {}
    if entry.Uuid then
        variants[#variants + 1] = {entry.Uuid}
        variants[#variants + 1] = {entry.Uuid, true}
    end
    if entry.Instance then
        variants[#variants + 1] = {entry.Instance}
        variants[#variants + 1] = {entry.Instance, true}
    end
    local fired = callVariants("SellPet", variants, 0.03)
    if fired == 0 then
        fired = callVariants("RemoveItem", variants, 0.03)
    end
    return fired
end

local function processNewlyHatchedPets(previousKeys, eggName)
    refreshInventory()
    local kept = 0
    local sold = 0
    local rule = eggPetRule(eggName) or {}
    local keepNames = rule.Keep or rule.keep or {}
    local sellNames = rule.Sell or rule.sell or {}
    local hasSellRules = type(sellNames) == "table" and #sellNames > 0
    for _, entry in ipairs(Inventory.Pets or {}) do
        if not previousKeys[petEntryKey(entry)] then
            local mutations = petMutationNames(entry.Instance)
            local match = mutationMatchesKeep(mutations)
            local baseKg = petBaseKg(entry)
            local age = petAge(entry)
            local level = petLevel(entry)
            local ruleKeepName = petNameMatchesList(entry, keepNames)
            local ruleSellName = petNameMatchesList(entry, sellNames)
            local globalKeepName = petNameSelectedForKeep(entry)
            local keepReason
            if ruleKeepName then
                keepReason = "egg rule " .. tostring(ruleKeepName)
            elseif globalKeepName then
                keepReason = "selected pet " .. tostring(globalKeepName)
            elseif baseKg >= (tonumber(Config.Hatch.AlwaysKeepBaseKg) or 3) then
                keepReason = ("base %.2fkg"):format(baseKg)
            elseif age <= 1 and baseKg >= (tonumber(Config.Hatch.KeepMinBaseKg) or 3) then
                keepReason = ("age 1 base %.2fkg"):format(baseKg)
            elseif Config.Hatch.KeepMutatedPets and match then
                keepReason = "mutation " .. match
            end

            if keepReason then
                favoritePetEntry(entry)
                kept += 1
                log(("Kept hatched pet %s from %s (%s)."):format(entry.Name, tostring(eggName or "egg"), keepReason))
            elseif Config.Hatch.SellUnkeptHatchedPets and ((not hasSellRules) or ruleSellName) then
                if (not Config.Hatch.SellOnlyLevelOne) or level <= 1 then
                    local fired = sellPetEntry(entry)
                    if fired > 0 then
                        sold += 1
                        local reason = ruleSellName and ("sell rule " .. tostring(ruleSellName)) or "unkept hatch"
                        log(("Sold newly hatched pet %s from %s (%s)."):format(entry.Name, tostring(eggName or "egg"), reason))
                    end
                else
                    log(("Skipped selling %s because it is level %d."):format(entry.Name, level))
                end
            end
        end
    end
    if kept == 0 and sold == 0 then
        log("Hatch results: no new pet matched keep/sell rules.")
    end
end

local function farmOwnerText(farm)
    local data = farm and farm:FindFirstChild("Important")
    data = data and data:FindFirstChild("Data")
    local owner = data and data:FindFirstChild("Owner")
    if owner and owner:IsA("ValueBase") and owner.Value ~= nil then
        return tostring(owner.Value)
    end

    for _, key in ipairs({"Owner", "OwnerName", "PlayerName", "UserId", "OwnerId"}) do
        local ok, value = pcall(function()
            return farm:GetAttribute(key)
        end)
        if ok and value ~= nil then
            return tostring(value)
        end
    end
    return nil
end

local function isOwnFarm(farm)
    local owner = farmOwnerText(farm)
    if not owner or owner == "" then
        return false
    end
    return owner == player.Name
        or owner == player.DisplayName
        or owner == tostring(player.UserId)
end

local function findOwnFarm()
    local roots = {
        Workspace:FindFirstChild("Farm"),
        Workspace:FindFirstChild("Farms"),
        Workspace:FindFirstChild("Plots"),
        Workspace:FindFirstChild("PlayerFarms"),
    }

    for _, root in ipairs(roots) do
        if root then
            if isOwnFarm(root) then
                return root
            end
            for _, child in ipairs(root:GetChildren()) do
                if isOwnFarm(child) then
                    return child
                end
                local nested = child:FindFirstChild("Farm")
                if nested and isOwnFarm(nested) then
                    return nested
                end
            end
        end
    end

    for _, descendant in ipairs(Workspace:GetDescendants()) do
        if descendant.Name == "Important" and descendant.Parent and isOwnFarm(descendant.Parent) then
            return descendant.Parent
        end
    end
    return nil
end

local function ownFarmImportant()
    local farm = findOwnFarm()
    return farm and farm:FindFirstChild("Important")
end

local function eggPlacementArea()
    local important = ownFarmImportant()
    local locations = important and important:FindFirstChild("Plant_Locations")
    if locations then
        for _, descendant in ipairs(locations:GetDescendants()) do
            if descendant.Name == "Can_Plant" and descendant:IsA("BasePart") then
                return descendant
            end
        end
    end
    return nil
end

local function placementCFrame(index)
    local area = eggPlacementArea()
    if area then
        local columns = 4
        local spacing = 4
        local col = (index - 1) % columns
        local rowIndex = math.floor((index - 1) / columns)
        local width = math.max(0, area.Size.X - 6)
        local depth = math.max(0, area.Size.Z - 6)
        local x = math.clamp((col - (columns - 1) / 2) * spacing, -width / 2, width / 2)
        local z = math.clamp((rowIndex - 1) * spacing, -depth / 2, depth / 2)
        return area.CFrame * CFrame.new(x, 0.5, z)
    end

    return nil
end

local Actions = {}

function Actions.AutoBuyOnce()
    local fired = 0
    local shops = selectedNames(Config.Shops.SelectedShops)
    if #shops == 0 then
        shops = Options.Shops
    end
    local eggs = selectedNames(Config.Hatch.SelectedEggs)
    if #eggs == 0 then
        eggs = DefaultEggs
    else
        for index, name in ipairs(eggs) do
            eggs[index] = canonicalEggName(name)
        end
    end

    for _, shop in ipairs(shops) do
        if shop == "Seed Shop" then
            for index, name in ipairs(DefaultSeeds) do
                fired += buyVariants("BuySeedStock", name, index)
                fired += buyVariants("BuyDailySeedShopStock", name, index)
            end
        elseif shop == "Gear Shop" then
            for index, name in ipairs(DefaultGear) do
                fired += buyVariants("BuyGearStock", name, index)
            end
        elseif shop == "Egg Shop" then
            for index, name in ipairs(eggs) do
                fired += buyVariants("BuyPetEgg", name, index)
            end
        elseif shop == "Cosmetic Shop" then
            fired += buyVariants("BuyCosmeticItem")
            fired += buyVariants("BuyCosmeticCrate")
            fired += buyVariants("BuyCosmeticShopFence")
        elseif shop == "Event Merchant" then
            for index, name in ipairs(DefaultEventItems) do
                fired += buyVariants("BuyEventShopStock", name, index)
            end
            local ok = callRemote("BuyEventShopRestock")
            if ok then fired += 1 end
        elseif shop == "Traveling Merchant" then
            for index, name in ipairs(DefaultEventItems) do
                fired += buyVariants("BuyTravelingMerchantShopStock", name, index)
            end
        elseif shop == "Garden Coin Shop" then
            for index, name in ipairs(DefaultEventItems) do
                fired += buyVariants("BuyGardenCoinShopStock", name, index)
            end
        elseif shop == "Night Event Shop" then
            for index, name in ipairs(DefaultEventItems) do
                fired += buyVariants("BuyNightEventShopStock", name, index)
            end
        elseif shop == "Easter Shop" then
            for index, name in ipairs(DefaultEventItems) do
                fired += buyVariants("BuyEasterStock", name, index)
            end
        end
    end
    log(("Auto Buy sent %d request(s)."):format(fired))
end

function Actions.ClaimRewardsOnce()
    local fired = 0
    local claims = {
        {"AchievementClaim", 12}, {"DailyQuestClaim", 12}, {"QuestClaim", 12},
        {"SeasonPassClaimReward", 20}, {"SeasonPassClaimQuest", 12},
        {"SeasonPassClaimInfinite", 4}, {"InfinitePackClaim", 8},
        {"InfinitePackEventClaim", 8}, {"ClaimChipmunkRewards", 12},
        {"ClaimLeafBlower", 4}, {"ClaimDinoQuest", 12},
        {"ConfirmItemInstanceClaim", 8}, {"WateringCanClaim", 4},
    }
    for _, item in ipairs(claims) do
        local variants = {{}}
        for index = 1, item[2] do
            variants[#variants + 1] = {index}
            variants[#variants + 1] = {tostring(index)}
        end
        fired += callVariants(item[1], variants, 0.03)
    end
    fired += buyVariants("GardenGameSpin")
    fired += buyVariants("SpinnerGame")
    log(("Claim sweep sent %d request(s)."):format(fired))
end

function Actions.OpenSeedPacksOnce()
    local fired = 0
    local entries = selectedEntries("SeedPacks", Config.Rewards.SelectedPacks)
    for _, entry in ipairs(entries) do
        equip(entry.Instance)
        task.wait(0.03)
        local variants = {{}, {entry.Name}}
        if entry.Uuid then
            variants[#variants + 1] = {entry.Uuid}
            variants[#variants + 1] = {entry.Name, entry.Uuid}
        end
        variants[#variants + 1] = {entry.Instance}
        fired += callVariants("SeedPackOpen", variants, 0.03)
    end
    if fired == 0 then
        for index, name in ipairs(DefaultSeedPacks) do
            fired += buyVariants("SeedPackOpen", name, index)
        end
    end
    log(("Seed pack opener sent %d request(s)."):format(fired))
end

local function normalizedEggText(value)
    return tostring(value or "")
        :lower()
        :gsub("%b[]", " ")
        :gsub("%b()", " ")
        :gsub("[_%-]+", " ")
        :gsub("%s+", " ")
        :gsub("^%s+", "")
        :gsub("%s+$", "")
end

local function eggDisplayName(egg)
    for _, key in ipairs({"EggName", "PetEggName", "EggType", "Type", "DisplayName", "ItemName"}) do
        local ok, value = pcall(function()
            return egg:GetAttribute(key)
        end)
        if ok and value and tostring(value) ~= "" then
            return tostring(value)
        end
        local child = egg:FindFirstChild(key)
        if child and child:IsA("ValueBase") and child.Value and tostring(child.Value) ~= "" then
            return tostring(child.Value)
        end
        local deepChild = egg:FindFirstChild(key, true)
        if deepChild and deepChild:IsA("ValueBase") and deepChild.Value and tostring(deepChild.Value) ~= "" then
            return tostring(deepChild.Value)
        end
    end
    return egg.Name
end

local function isLikelyEggName(value)
    return normalizedEggText(value):find("egg", 1, true) ~= nil
end

local function eggPredictedPetName(egg)
    local keys = {
        "PetName", "PetType", "HatchedPet", "HatchPet", "PredictedPet",
        "ResultPet", "RewardPet", "NextPet", "CurrentPet", "Pet",
    }

    for _, key in ipairs(keys) do
        local ok, value = pcall(function()
            return egg:GetAttribute(key)
        end)
        if ok and value and tostring(value) ~= "" and not isLikelyEggName(value) then
            return tostring(value)
        end
        local child = egg:FindFirstChild(key)
        if child and child:IsA("ValueBase")
            and child.Value
            and tostring(child.Value) ~= ""
            and not isLikelyEggName(child.Value)
        then
            return tostring(child.Value)
        end
    end

    local haystack = normalizedEggText(textOf(egg))
    for _, petName in ipairs(Options.Pets or {}) do
        local needle = normalizedEggText(petName)
        if needle ~= "" and not isLikelyEggName(petName) and haystack:find(needle, 1, true) then
            return petName
        end
    end
    return nil
end

local function eggMatchesSelection(egg, selected)
    return hasEggSelection(selected, egg.Name)
        or hasEggSelection(selected, eggDisplayName(egg))
        or hasEggSelection(selected, textOf(egg))
end

local function readEggField(egg, key)
    local ok, value = pcall(function()
        return egg:GetAttribute(key)
    end)
    if ok and value ~= nil then
        return value
    end
    local child = egg:FindFirstChild(key)
    if child and child:IsA("ValueBase") then
        return child.Value
    end
    local deepChild = egg:FindFirstChild(key, true)
    if deepChild and deepChild:IsA("ValueBase") then
        return deepChild.Value
    end
    return nil
end

local function eggWorldPosition(egg)
    if egg:IsA("BasePart") then
        return egg.Position
    end
    if egg:IsA("Model") then
        local ok, cf = pcall(function()
            return egg:GetPivot()
        end)
        if ok then
            return cf.Position
        end
        local part = egg.PrimaryPart or egg:FindFirstChildWhichIsA("BasePart", true)
        return part and part.Position
    end
    local part = egg:FindFirstChildWhichIsA("BasePart", true)
    return part and part.Position
end

local function eggSignalKey(egg)
    local pos = eggWorldPosition(egg)
    local name = canonicalEggName(eggDisplayName(egg))
    if pos then
        return ("%s@%d,%d,%d"):format(name, math.floor(pos.X + 0.5), math.floor(pos.Y + 0.5), math.floor(pos.Z + 0.5))
    end
    return name .. "@" .. egg:GetFullName()
end

local function durationTextSeconds(text)
    local lower = tostring(text or ""):lower()
    local colonTimer = lower:match("(%d+%s*:%s*%d+%s*:%s*%d+)") or lower:match("(%d+%s*:%s*%d+)")
    if colonTimer then
        local parts = {}
        for part in colonTimer:gmatch("%d+") do
            parts[#parts + 1] = tonumber(part) or 0
        end
        if #parts == 3 then
            return parts[1] * 3600 + parts[2] * 60 + parts[3]
        end
        if #parts == 2 then
            return parts[1] * 60 + parts[2]
        end
    end

    local total
    for amount, unit in lower:gmatch("(%d+)%s*([dhms])") do
        total = total or 0
        amount = tonumber(amount) or 0
        if unit == "d" then
            total += amount * 86400
        elseif unit == "h" then
            total += amount * 3600
        elseif unit == "m" then
            total += amount * 60
        elseif unit == "s" then
            total += amount
        end
    end
    return total
end

local function eggTimerTextInfo(egg)
    for _, descendant in ipairs(egg:GetDescendants()) do
        if descendant:IsA("TextLabel") or descendant:IsA("TextButton") then
            local name = descendant.Name:lower()
            if name:find("time", 1, true)
                or name:find("hatch", 1, true)
                or name:find("ready", 1, true)
                or name:find("status", 1, true)
            then
                local text = tostring(descendant.Text or "")
                local lower = text:lower()
                local seconds = durationTextSeconds(text)
                if seconds then
                    if seconds <= 0 then
                        return true, "timer done"
                    end
                    return false, text, seconds
                end
                if lower:find("ready", 1, true)
                    and not lower:find("not ready", 1, true)
                    and not lower:find("ready in", 1, true)
                then
                    return true, text
                end
            end
        end
    end
    return nil, nil
end

local function formatDuration(seconds)
    seconds = math.max(0, math.floor(tonumber(seconds) or 0))
    local hours = math.floor(seconds / 3600)
    local minutes = math.floor((seconds % 3600) / 60)
    local secs = seconds % 60
    if hours > 0 then
        return ("%dh %02dm"):format(hours, minutes)
    end
    if minutes > 0 then
        return ("%dm %02ds"):format(minutes, secs)
    end
    return tostring(secs) .. "s"
end

local function progressEta(signal)
    if not signal or not signal.Progress or signal.Progress >= 0.999 then
        return nil
    end

    local previousProgress = signal.LastProgress
    local previousAt = signal.LastProgressAt
    if (not previousProgress or not previousAt)
        and signal.FirstProgress
        and signal.FirstProgressAt
        and signal.FirstProgress < signal.Progress
    then
        previousProgress = signal.FirstProgress
        previousAt = signal.FirstProgressAt
    end

    if not previousProgress or not previousAt then
        return nil
    end

    local progressDelta = signal.Progress - previousProgress
    local timeDelta = (signal.ProgressAt or os.clock()) - previousAt
    if progressDelta <= 0 or timeDelta <= 0 then
        return nil
    end

    return math.max(0, (1 - signal.Progress) / (progressDelta / timeDelta))
end

local function eggReadyInfo(egg)
    local signal = State.EggSignals[egg] or State.EggSignalKeys[eggSignalKey(egg)]
    local falseReadyReason

    for _, key in ipairs({"Ready", "CanHatch", "HatchReady", "IsReady"}) do
        local value = readEggField(egg, key)
        if value == true then
            return true, key
        elseif value == false then
            falseReadyReason = falseReadyReason or (key .. "=false")
        end
    end

    local now = os.time()
    for _, key in ipairs({"HatchAt", "ReadyAt", "HatchReadyAt", "FinishTime", "EndTime"}) do
        local value = tonumber(readEggField(egg, key))
        if value then
            if value > 100000000000 then
                value = value / 1000
            end
            if value <= now then
                return true, key
            end
            return false, formatDuration(value - now), value - now
        end
    end

    for _, key in ipairs({"TimeLeft", "TimeRemaining", "HatchTimeLeft", "HatchTimeRemaining", "Remaining", "Cooldown"}) do
        local raw = readEggField(egg, key)
        local value = tonumber(raw) or durationTextSeconds(raw)
        if value then
            if value <= 0 then
                return true, key
            end
            return false, formatDuration(value), value
        end
    end

    local textReady, textReason, textSeconds = eggTimerTextInfo(egg)
    if textReady ~= nil then
        return textReady, textReason, textSeconds
    end

    local readyTime = tonumber(readEggField(egg, "ReadyTime"))
    if readyTime then
        if readyTime > 100000 then
            if readyTime > 100000000000 then
                readyTime = readyTime / 1000
            end
            if readyTime <= now then
                return true, "ReadyTime"
            end
            return false, formatDuration(readyTime - now), readyTime - now
        end
        if readyTime <= 0 then
            return true, "ReadyTime"
        end
        return false, formatDuration(readyTime), readyTime
    end

    if signal and signal.Ready == true then
        return true, signal.Reason or "ready remote"
    end

    if falseReadyReason then
        return false, falseReadyReason
    end

    if signal and signal.Progress then
        if signal.Progress >= 0.999 then
            return true, "PetEggService progress"
        end
        local eta = progressEta(signal)
        if eta then
            return false, formatDuration(eta), eta
        end
        return false, ("estimating time (%d%%)"):format(math.floor(signal.Progress * 100))
    end

    return false, "no ready signal"
end

local function eggReady(egg)
    local ready = eggReadyInfo(egg)
    return ready == true
end

local function eggRoots()
    local roots = {}
    local important = ownFarmImportant()
    local physical = important and important:FindFirstChild("Objects_Physical")
    if physical then
        roots[#roots + 1] = physical
    elseif important then
        roots[#roots + 1] = important
    end
    if #roots == 0 then
        local farm = findOwnFarm()
        if farm then
            roots[1] = farm
        end
    end
    return roots
end

local function hasEggAncestor(instance, root)
    local parent = instance.Parent
    while parent and parent ~= root do
        if normalizedEggText(parent.Name):find("egg", 1, true) then
            return true
        end
        parent = parent.Parent
    end
    return false
end

local function physicalObjectRoot(instance, searchRoot)
    local current = instance
    local parent = current and current.Parent
    while parent and parent ~= searchRoot do
        current = parent
        parent = current.Parent
    end
    return current
end

local function isEggTargetCandidate(instance)
    if not instance or not instance.Parent then
        return false
    end
    if readEggField(instance, "EggName")
        or readEggField(instance, "PetEggName")
        or readEggField(instance, "HatchAt")
        or readEggField(instance, "ReadyAt")
        or readEggField(instance, "ReadyTime")
        or readEggField(instance, "TimeLeft")
        or readEggField(instance, "HatchTimeLeft")
    then
        return true
    end
    if instance:FindFirstChild("PetEgg", true) then
        return true
    end
    local lower = normalizedEggText(instance.Name .. " " .. eggDisplayName(instance) .. " " .. textOf(instance))
    return lower:find("egg", 1, true) ~= nil
end

local function eggTargetCandidates(selected)
    local targets = {}
    local seen = {}
    local checked = {}
    for _, searchRoot in ipairs(eggRoots()) do
        for _, child in ipairs(searchRoot:GetChildren()) do
            checked[child] = isEggTargetCandidate(child)
            if not seen[child] and checked[child] and eggMatchesSelection(child, selected) then
                seen[child] = true
                targets[#targets + 1] = child
            end
        end
        for _, descendant in ipairs(searchRoot:GetDescendants()) do
            if descendant:IsA("Model") or descendant:IsA("BasePart") or descendant:IsA("Folder") then
                local root = physicalObjectRoot(descendant, searchRoot)
                if root and not seen[root] then
                    if checked[root] == nil then
                        checked[root] = isEggTargetCandidate(root)
                    end
                    if checked[root] and eggMatchesSelection(root, selected) then
                        seen[root] = true
                        targets[#targets + 1] = root
                    end
                end
            end
        end
    end
    return targets
end

local function canonicalEggInstance(instance)
    if typeof(instance) ~= "Instance" then
        return instance
    end
    for _, searchRoot in ipairs(eggRoots()) do
        if instance == searchRoot then
            return instance
        end
        if instance:IsDescendantOf(searchRoot) then
            return physicalObjectRoot(instance, searchRoot)
        end
    end
    return instance
end

local function findReadyEggs()
    local selected = Config.Hatch.SelectedEggs
    local found = {}
    local root = character and character:FindFirstChild("HumanoidRootPart")
    local rootPos = root and root.Position

    for _, egg in ipairs(eggTargetCandidates(selected)) do
        if eggReady(egg) then
            local pos = eggWorldPosition(egg)
            local distance = (rootPos and pos) and (pos - rootPos).Magnitude or 0
            found[#found + 1] = {
                Egg = egg,
                Distance = distance,
            }
        end
    end

    table.sort(found, function(a, b)
        return a.Distance < b.Distance
    end)
    return found
end

local function countPhysicalEggs()
    return #eggTargetCandidates(nil)
end

local function hatchEgg(egg)
    local ok = callRemote("PetEggService", "HatchPet", egg)
    return ok and 1 or 0
end

local updateEggEsp

local function noteEggSignal(egg, ready, reason, progress)
    if typeof(egg) ~= "Instance" then
        return
    end
    egg = canonicalEggInstance(egg)
    local signal = State.EggSignals[egg] or {}
    local now = os.clock()
    if ready ~= nil then
        signal.Ready = ready
    end
    if reason then
        signal.Reason = reason
    end
    progress = tonumber(progress)
    if progress then
        if not signal.FirstProgress or progress < signal.FirstProgress then
            signal.FirstProgress = progress
            signal.FirstProgressAt = now
        end
        signal.LastProgress = signal.Progress
        signal.LastProgressAt = signal.ProgressAt
        signal.Progress = progress
        signal.ProgressAt = now
    end
    signal.UpdatedAt = now
    State.EggSignals[egg] = signal
    State.EggSignalKeys[eggSignalKey(egg)] = signal
end

local function installEggRemoteListeners()
    if State.EggRemoteListenersInstalled then
        return
    end
    State.EggRemoteListenersInstalled = true

    local petEggRemote = remote("PetEggService")
    if petEggRemote and petEggRemote:IsA("RemoteEvent") then
        petEggRemote.OnClientEvent:Connect(function(egg, progress)
            if typeof(egg) == "Instance" then
                local numericProgress = tonumber(progress)
                noteEggSignal(egg, numericProgress and numericProgress >= 0.999 or nil, "PetEggService", numericProgress)
                task.defer(updateEggEsp)
            end
        end)
    end

    local readyRemote = remote("EggReadyToHatch")
    if readyRemote and readyRemote:IsA("RemoteEvent") then
        readyRemote.OnClientEvent:Connect(function(egg, ready)
            if typeof(egg) == "Instance" then
                local readyState = nil
                if ready == true then
                    readyState = true
                elseif ready == false then
                    readyState = false
                end
                noteEggSignal(egg, readyState, "EggReadyToHatch_RE")
                task.defer(updateEggEsp)
            end
        end)
    end
end

local function remoteStatus(name)
    local r = remote(name)
    if not r then
        return name .. ": missing"
    end
    return ("%s: %s at %s"):format(name, r.ClassName, r:GetFullName())
end

function Actions.LogEggRemoteStatus()
    installEggRemoteListeners()
    log(remoteStatus("PetEggService"))
    log(remoteStatus("EggReadyToHatch"))
    log(("Own farm egg roots: %d"):format(#eggRoots()))
end

local function eggAdornee(egg)
    if egg:IsA("BasePart") then
        return egg
    end
    if egg:IsA("Model") then
        return egg.PrimaryPart or egg:FindFirstChildWhichIsA("BasePart", true)
    end
    return egg:FindFirstChildWhichIsA("BasePart", true)
end

local function clearEggEsp()
    for egg, adornments in pairs(State.EggEsp) do
        if adornments.Billboard then
            adornments.Billboard:Destroy()
        end
        if adornments.Highlight then
            adornments.Highlight:Destroy()
        end
        State.EggEsp[egg] = nil
    end
end

local function eggEspTargets()
    return eggTargetCandidates(Config.Hatch.SelectedEggs)
end

function updateEggEsp()
    if not Config.Hatch.EggEsp then
        clearEggEsp()
        return
    end

    local alive = {}
    for _, egg in ipairs(eggEspTargets()) do
        local adornee = eggAdornee(egg)
        if adornee then
            alive[egg] = true
            local adornments = State.EggEsp[egg]
            if not adornments then
                adornments = {}

                local billboard = Instance.new("BillboardGui")
                billboard.Name = "GAGEggESP"
                billboard.AlwaysOnTop = true
                billboard.LightInfluence = 0
                billboard.MaxDistance = 450
                billboard.Size = UDim2.fromOffset(148, 38)
                billboard.StudsOffset = Vector3.new(0, 2.35, 0)
                billboard.Adornee = adornee
                billboard.Parent = screenGui

                local label = Instance.new("TextLabel")
                label.Name = "Label"
                label.BackgroundColor3 = Color3.fromRGB(8, 12, 14)
                label.BackgroundTransparency = 0.42
                label.BorderSizePixel = 0
                label.Size = UDim2.fromScale(1, 1)
                label.Font = Enum.Font.GothamBold
                label.TextColor3 = Theme.Text
                label.TextSize = 10
                label.TextWrapped = true
                label.Parent = billboard
                corner(label, 5)
                local outline = Instance.new("UIStroke")
                outline.Color = Theme.StrokeSoft
                outline.Thickness = 1
                outline.Transparency = 0.55
                outline.Parent = label

                local highlight = Instance.new("Highlight")
                highlight.Name = "GAGEggESPHighlight"
                highlight.Adornee = egg
                highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                highlight.FillTransparency = 0.92
                highlight.OutlineTransparency = 0.72
                highlight.Parent = screenGui

                adornments.Billboard = billboard
                adornments.Highlight = highlight
                adornments.Label = label
                State.EggEsp[egg] = adornments
            end

            if adornments.Billboard then
                adornments.Billboard.Adornee = adornee
            end
            if adornments.Highlight then
                adornments.Highlight.Adornee = egg
            end

            local ready, readyReason = eggReadyInfo(egg)
            local color = ready and Theme.Accent or Theme.Accent2
            if adornments.Highlight then
                adornments.Highlight.FillColor = color
                adornments.Highlight.OutlineColor = color
            end
            if adornments.Label then
                adornments.Label.TextColor3 = color
                local petName = ready and eggPredictedPetName(egg)
                local stateText = ready and "READY" or "Growing"
                if petName then
                    stateText = stateText .. " | " .. petName
                elseif ready then
                    stateText = stateText .. " | Pet unknown"
                else
                    stateText = stateText .. " | " .. tostring(readyReason or "time unknown")
                end
                adornments.Label.Text = ("%s\n%s"):format(eggDisplayName(egg), stateText)
            end
        end
    end

    for egg, adornments in pairs(State.EggEsp) do
        if not alive[egg] or not egg.Parent then
            if adornments.Billboard then
                adornments.Billboard:Destroy()
            end
            if adornments.Highlight then
                adornments.Highlight:Destroy()
            end
            State.EggEsp[egg] = nil
        end
    end
end

local function runPetTeam(selected, label)
    local fired = 0
    for _, entry in ipairs(selectedEntries("Pets", selected)) do
        if entry.Uuid then
            local ok = callRemote("ActivePetService", "Feed", entry.Uuid)
                or callRemote("PetBoostService", "Level", entry.Uuid)
                or callRemote("PetBoostService", "Feed", entry.Uuid)
            if ok then fired += 1 end
        end
    end
    if fired > 0 then
        log(("%s sent %d pet request(s)."):format(label, fired))
    end
    return fired
end

function Actions.HatchOnce()
    local eggs = findReadyEggs()
    if #eggs == 0 then
        local targets = eggEspTargets()
        if #targets > 0 then
            local _, reason = eggReadyInfo(targets[1])
            log("Hatch skipped: selected egg is not ready (" .. tostring(reason) .. ").")
        else
            log("Hatch skipped: no selected physical egg found in your own garden.")
        end
        return false
    end

    local previousPetKeys = capturePetKeys()
    runPetTeam(Config.Hatch.HatchReductionTeam, "Egg hatch reduction team")
    runPetTeam(Config.Hatch.SealTeam, "Seal hatch team")
    runPetTeam(Config.Hatch.KoiTeam, "Koi hatch team")
    runPetTeam(Config.Hatch.BrontoTeam, "Bronto hatch team")
    task.wait(0.15)
    local fired = hatchEgg(eggs[1].Egg)
    local name = eggDisplayName(eggs[1].Egg)
    log(fired > 0 and ("Hatch sent " .. fired .. " request(s) for " .. name .. ".") or "Hatch skipped: PetEggService missing.")
    if fired > 0 then
        task.delay(1.5, function()
            processNewlyHatchedPets(previousPetKeys, name)
        end)
    end
    return fired > 0
end

function Actions.PlaceEggsOnce()
    local count = 0
    local maxEggs = math.max(1, tonumber(Config.Hatch.MaxEggsPlaced) or MAX_EGGS_PLACED)
    local alreadyPlaced = countPhysicalEggs()
    local remainingSlots = math.max(0, maxEggs - alreadyPlaced)
    if remainingSlots <= 0 then
        log(("Place eggs skipped: already at %d/%d physical egg(s)."):format(alreadyPlaced, maxEggs))
        return 0
    end

    for _, entry in ipairs(selectedEntries("Eggs", Config.Hatch.SelectedEggs)) do
        if count >= remainingSlots then
            break
        end

        equip(entry.Instance)
        task.wait(0.08)
        local cf = placementCFrame(alreadyPlaced + count + 1)
        if not cf then
            log("Place eggs skipped: could not find your own garden Plant_Locations.")
            return count
        end
        local pos = cf.Position

        local before = countPhysicalEggs()
        local placed = callRemote("PetEggService", "CreateEgg", pos)
        task.wait(0.12)
        if countPhysicalEggs() <= before then
            placed = callRemote("PetEggService", "PlaceEgg", pos)
            task.wait(0.12)
        end

        if placed and countPhysicalEggs() > before then
            count += 1
        elseif entry.Instance and entry.Instance:IsA("Tool") then
            local activated = pcall(function()
                entry.Instance:Activate()
            end)
            if activated then
                count += 1
            end
        end
    end
    log(("Placed %d egg(s), now at about %d/%d."):format(count, alreadyPlaced + count, maxEggs))
    task.delay(1, refreshInventory)
    return count
end

