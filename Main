function buildHatchPage()
    local hatchSection = createSection(hatchPage, "Quick Hatch")
    local sellRuleSummary
    local sellPetsRefresh

    local function updateSelectedEggDependentControls()
        local eggOptions = normalizeEggPriorityToSelected()

        if Runtime.SelectedSellRuleEgg == "" or not hasOption(eggOptions, Runtime.SelectedSellRuleEgg) then
            Runtime.SelectedSellRuleEgg = eggOptions[1] or ""
        end

        for _, eggName in ipairs(eggOptions) do
            local petOptions = eggPetOptions(eggName)
            Config.Hatch.SellRulesByEgg[eggName] = Config.Hatch.SellRulesByEgg[eggName] or copyArrayToSelected(petOptions)
            syncSelectedOptions(Config.Hatch.SellRulesByEgg[eggName], petOptions)
        end

        for eggName in pairs(Config.Hatch.SellRulesByEgg) do
            if not hasOption(eggOptions, eggName) then
                Config.Hatch.SellRulesByEgg[eggName] = nil
            end
        end

        if UIRefresh.EggPriority then
            UIRefresh.EggPriority(Config.Hatch.EggPriority[1], eggOptions, false)
        end

        if UIRefresh.EggRule then
            UIRefresh.EggRule(Runtime.SelectedSellRuleEgg, eggOptions, false)
        end

        if sellRuleSummary then
            sellRuleSummary.Text = "Keep rule: " .. (Runtime.SelectedSellRuleEgg ~= "" and Runtime.SelectedSellRuleEgg or "No selected eggs")
        end

        if sellPetsRefresh then
            local sellPetOptions = eggPetOptions(Runtime.SelectedSellRuleEgg)
            local currentSellRule = Runtime.SelectedSellRuleEgg ~= ""
                and (Config.Hatch.SellRulesByEgg[Runtime.SelectedSellRuleEgg] or copyArrayToSelected(sellPetOptions))
                or copyArrayToSelected({})
            sellPetsRefresh(currentSellRule, sellPetOptions)
        end
    end

    createToggle(hatchSection, "Auto Hatch Ready Eggs", Config.Hatch.AutoHatch, function(enabled)
        Config.Hatch.AutoHatch = enabled
        Actions.AutoHatch(enabled)
    end)

    UIRefresh.EggsToHatch = createMultiSelect(hatchSection, "Eggs To Hatch", OPTIONS.Eggs, Config.Hatch.SelectedEggs, function()
        log("Egg selection updated: " .. selectedListToText(Config.Hatch.SelectedEggs))
        updateSelectedEggDependentControls()
    end)

    UIRefresh.EggPriority = createDropdown(hatchSection, "Priority Egg", selectedEggRuleOptions(), Config.Hatch.EggPriority[1], function(value)
        if not value or value == "" then
            Config.Hatch.EggPriority = {}
            log("Egg priority cleared.")
            return
        end

        Config.Hatch.EggPriority = {value}
        log("Egg priority set to " .. value)
    end)

    createButton(hatchSection, "Use Queue As Rotation", function()
        Config.Hatch.EggPriority = selectedToPriority(Config.Hatch.SelectedEggs)
        normalizeEggPriorityToSelected()
        if UIRefresh.EggPriority then
            UIRefresh.EggPriority(Config.Hatch.EggPriority[1], selectedEggRuleOptions(), false)
        end
        log("Egg priority rotation: " .. table.concat(Config.Hatch.EggPriority, ", "))
        scheduleSaveConfig()
    end)

    createToggle(hatchSection, "Auto Place Eggs", Config.Hatch.AutoPlaceEggs, function(enabled)
        Config.Hatch.AutoPlaceEggs = enabled
        log("Auto Place Eggs " .. (enabled and "enabled" or "disabled"))
    end)

    createTextInput(hatchSection, "Garden Egg Limit", tostring(MAX_EGGS_PLACED), Config.Hatch.MaxEggsPlaced, function(text)
        local value = tonumber(text)
        if value then
            Config.Hatch.MaxEggsPlaced = clampNumber(math.floor(value), 1, 100)
            log("Max eggs placed set to " .. tostring(Config.Hatch.MaxEggsPlaced))
        end
    end)

    createDropdown(hatchSection, "Egg Placement", {"Middle", "Random", "Near Player"}, Config.Hatch.EggPlacementMode, function(value)
        Config.Hatch.EggPlacementMode = value or "Middle"
        log("Egg placement mode set to " .. tostring(Config.Hatch.EggPlacementMode))
    end)

    createTextInput(hatchSection, "Place Egg Interval", "8", Config.Hatch.PlaceEggInterval, function(text)
        local value = tonumber(text)
        if value then
            Config.Hatch.PlaceEggInterval = math.max(2, value)
            log("Place egg interval set to " .. tostring(Config.Hatch.PlaceEggInterval) .. "s")
        end
    end)

    local espSection = createSection(hatchPage, "Egg ESP")

    createToggle(espSection, "Show Ready Egg Pet", Config.Hatch.EggEsp, function(enabled)
        Config.Hatch.EggEsp = enabled
        if Actions.RefreshEggEsp then
            Actions.RefreshEggEsp()
        end
        log("Pet egg ESP " .. (enabled and "enabled" or "disabled"))
    end)

    createButton(espSection, "Refresh Egg ESP", function()
        if Actions.RefreshEggEsp then
            Actions.RefreshEggEsp()
        end
    end)

    local hatchTeamsSection = createCollapsibleSection(hatchPage, "Buff Teams", false)

    UIRefresh.EggReductionPets = createMultiSelect(hatchTeamsSection, "Egg Cooldown Team", OPTIONS.Pets, Config.Hatch.EggReductionPets, function()
        log("Egg reduction team updated: " .. selectedListToText(Config.Hatch.EggReductionPets))
    end)

    UIRefresh.HatchSupportPets = createMultiSelect(hatchTeamsSection, "Koi / Bronto Team", OPTIONS.Pets, Config.Hatch.HatchSupportPets, function()
        log("Refund / size team updated: " .. selectedListToText(Config.Hatch.HatchSupportPets))
    end)

    UIRefresh.SealPets = createMultiSelect(hatchTeamsSection, "Seal Team", OPTIONS.Pets, Config.Hatch.SealPets, function()
        log("Seal team updated: " .. selectedListToText(Config.Hatch.SealPets))
    end)

    local buffSummary = Instance.new("TextLabel")
    buffSummary.Name = "ActiveBuffSummary"
    buffSummary.BackgroundTransparency = 1
    buffSummary.Size = UDim2.new(1, 0, 0, 36)
    buffSummary.Font = Enum.Font.GothamMedium
    buffSummary.Text = "Active buffs: press calculate"
    buffSummary.TextColor3 = Theme.Muted
    buffSummary.TextSize = 12
    buffSummary.TextWrapped = true
    buffSummary.TextXAlignment = Enum.TextXAlignment.Left
    buffSummary.Parent = hatchTeamsSection
    UIRefresh.ActiveBuffSummary = buffSummary

    createButton(hatchTeamsSection, "Run Hatch Teams Once", function()
        Actions.RunHatchTeamsOnce()
    end)

    createButton(hatchTeamsSection, "Calculate Active Buffs", function()
        Actions.LogSelectedHatchBuffs()
    end)

    local sellSection = createCollapsibleSection(hatchPage, "Sell Protection", false)

    createToggle(sellSection, "Sell Pets Not Kept", Config.Hatch.AutoSellPets, function(enabled)
        Config.Hatch.AutoSellPets = enabled
        log("Sell Non-Keep Pets " .. (enabled and "enabled" or "disabled"))
    end)

    createToggle(sellSection, "Use Seal Team Before Selling", Config.Hatch.AutoSellWithSeal, function(enabled)
        Config.Hatch.AutoSellWithSeal = enabled
        log("Use Seal Team Before Selling " .. (enabled and "enabled" or "disabled"))
    end)

    createToggle(sellSection, "Only Sell Newly Hatched", Config.Hatch.OnlySellNewlyHatched, function(enabled)
        Config.Hatch.OnlySellNewlyHatched = enabled
        log("Only Sell Newly Hatched " .. (enabled and "enabled" or "disabled"))
    end)

    createToggle(sellSection, "Do Not Sell Favorited Pets", Config.Hatch.DontSellFavorited, function(enabled)
        Config.Hatch.DontSellFavorited = enabled
        log("Do Not Sell Favorited Pets " .. (enabled and "enabled" or "disabled"))
    end)

    createToggle(sellSection, "Keep Selected Mutations", Config.Hatch.KeepMutatedPets, function(enabled)
        Config.Hatch.KeepMutatedPets = enabled
        log("Keep Selected Mutations " .. (enabled and "enabled" or "disabled"))
    end)

    UIRefresh.HatchKeepMutations = createMultiSelect(sellSection, "Mutations To Keep", OPTIONS.Mutations, Config.Hatch.KeepMutations, function()
        log("Hatch keep mutations updated: " .. selectedListToText(Config.Hatch.KeepMutations))
    end)

    createToggle(sellSection, "Keep By Base Weight", Config.Hatch.KeepByMinWeight, function(enabled)
        Config.Hatch.KeepByMinWeight = enabled
        log("Keep By Base Weight " .. (enabled and "enabled" or "disabled"))
    end)

    createTextInput(sellSection, "Min Base Weight KG", "3.0", Config.Hatch.KeepMinWeight, function(text)
        local value = tonumber(text)
        if value then
            Config.Hatch.KeepMinWeight = math.max(0, value)
            log("Minimum hatch keep weight set to " .. tostring(Config.Hatch.KeepMinWeight) .. " KG")
        end
    end)

    sellRuleSummary = Instance.new("TextLabel")
    sellRuleSummary.BackgroundTransparency = 1
    sellRuleSummary.Size = UDim2.new(1, 0, 0, 22)
    sellRuleSummary.Font = Enum.Font.Gotham
    sellRuleSummary.Text = "Keep rule: " .. Runtime.SelectedSellRuleEgg
    sellRuleSummary.TextColor3 = Theme.Muted
    sellRuleSummary.TextSize = 12
    sellRuleSummary.TextXAlignment = Enum.TextXAlignment.Left
    sellRuleSummary.Parent = sellSection
    UIRefresh.SellRuleSummary = sellRuleSummary

    UIRefresh.EggRule = createDropdown(sellSection, "Egg Rule", selectedEggRuleOptions(), Runtime.SelectedSellRuleEgg, function(value)
        if not value or value == "" then
            return
        end

        Runtime.SelectedSellRuleEgg = value
        local petOptions = eggPetOptions(value)
        Config.Hatch.SellRulesByEgg[value] = Config.Hatch.SellRulesByEgg[value] or copyArrayToSelected(petOptions)
        syncSelectedOptions(Config.Hatch.SellRulesByEgg[value], petOptions)
        sellRuleSummary.Text = "Keep rule: " .. value
        if sellPetsRefresh then
            sellPetsRefresh(Config.Hatch.SellRulesByEgg[value], petOptions)
        end
        log("Editing keep rule for " .. value)
    end)

    local initialSellPetOptions = eggPetOptions(Runtime.SelectedSellRuleEgg)
    local initialSellRule = Runtime.SelectedSellRuleEgg ~= ""
        and (Config.Hatch.SellRulesByEgg[Runtime.SelectedSellRuleEgg] or copyArrayToSelected(initialSellPetOptions))
        or copyArrayToSelected({})
    sellPetsRefresh = createMultiSelect(sellSection, "Pets To Keep", initialSellPetOptions, initialSellRule, function(currentSelected)
        if Runtime.SelectedSellRuleEgg ~= "" then
            Config.Hatch.SellRulesByEgg[Runtime.SelectedSellRuleEgg] = currentSelected
            log("Keep pets updated for " .. Runtime.SelectedSellRuleEgg .. ": " .. selectedListToText(currentSelected))
        end
    end)
    UIRefresh.SellPets = sellPetsRefresh

    createButton(sellSection, "Save Current Keep Rule", function()
        local currentSelected = Config.Hatch.SellRulesByEgg[Runtime.SelectedSellRuleEgg]
        log("Saved keep rule for " .. Runtime.SelectedSellRuleEgg .. ": " .. selectedListToText(currentSelected))
    end)
end
buildHatchPage()

function buildMutationPage()
    local mutationSection = createSection(mutationPage, "Auto Mutation")

    createToggle(mutationSection, "Auto Mutation", Config.Mutation.AutoMutation, function(enabled)
        Config.Mutation.AutoMutation = enabled
        Actions.AutoMutation(enabled)
    end)

    createButton(mutationSection, "Refresh Mutation Names", function()
        if refreshMutationOptionsFromRemote() then
            syncSelectedOptions(Config.Mutation.SelectedMutations, OPTIONS.Mutations)
            if UIRefresh.Mutations then
                UIRefresh.Mutations(Config.Mutation.SelectedMutations, OPTIONS.Mutations)
            end
            if UIRefresh.HatchKeepMutations then
                UIRefresh.HatchKeepMutations(Config.Hatch.KeepMutations, OPTIONS.Mutations)
            end
            log("Mutation names refreshed from GetPetMutationNames.")
        else
            log("Mutation names refresh skipped: GetPetMutationNames returned no names.")
        end
    end)

    createButton(mutationSection, "Run Selected Mutation Once", function()
        log("Manual mutation requested: " .. selectedListToText(Config.Mutation.SelectedMutations))
        Actions.AutoMutationOnce()
    end)
end
buildMutationPage()

