local function copyList(list)
    local out = {}
    for _, value in ipairs(list or {}) do
        out[#out + 1] = value
    end
    return out
end

local function selectedFrom(list)
    local selected = {__order = {}}
    for _, value in ipairs(list or {}) do
        selected[value] = true
        selected.__order[#selected.__order + 1] = value
    end
    return selected
end

local function selectedNames(selected)
    local names = {}
    for _, name in ipairs((selected and selected.__order) or {}) do
        if selected[name] then
            names[#names + 1] = name
        end
    end
    return names
end

local function setSelectionFromList(selected, list)
    selected = selected or {}
    for key in pairs(selected) do
        selected[key] = nil
    end
    selected.__order = {}
    for _, value in ipairs(list or {}) do
        value = tostring(value or ""):gsub("^%s+", ""):gsub("%s+$", "")
        if value ~= "" and not selected[value] then
            selected[value] = true
            selected.__order[#selected.__order + 1] = value
        end
    end
    return selected
end

local function selectionKey(value)
    return tostring(value or ""):lower():gsub("[^%w]+", "")
end

local function hasSelection(selected, name)
    local order = selected and selected.__order
    if not order or #order == 0 then
        return true
    end
    if selected[name] == true then
        return true
    end
    local haystack = selectionKey(name)
    for _, selectedName in ipairs(order) do
        if selected[selectedName] and haystack == selectionKey(selectedName) then
            return true
        end
    end
    return false
end

local function cleanItemName(name)
    return tostring(name or "")
        :gsub("%s+x%d+$", "")
        :gsub("%s+X%d+$", "")
        :gsub("%s+%[X%d+%]", "")
        :gsub("%s+%[x%d+%]", "")
        :gsub("%s+%(%d+%)$", "")
        :gsub("%s+", " ")
        :gsub("^%s+", "")
        :gsub("%s+$", "")
end

local function canonicalEggName(name)
    local cleaned = cleanItemName(name)
    local lower = cleaned:lower()
    for _, eggName in ipairs(DefaultEggs) do
        if lower:find(eggName:lower(), 1, true) then
            return eggName
        end
    end
    return cleaned
end

local function hasEggSelection(selected, name)
    local order = selected and selected.__order
    if not order or #order == 0 then
        return true
    end
    local haystack = canonicalEggName(name):lower()
    for _, selectedName in ipairs(order) do
        if selected[selectedName] then
            local needle = canonicalEggName(selectedName):lower()
            if haystack == needle
                or haystack:find(needle, 1, true)
                or needle:find(haystack, 1, true)
            then
                return true
            end
        end
    end
    return false
end

local function normalizeEggSelection()
    local names = selectedNames(Config.Hatch.SelectedEggs)
    if #names == 0 then
        return
    end
    local cleaned = {}
    for _, name in ipairs(names) do
        cleaned[#cleaned + 1] = canonicalEggName(name)
    end
    Config.Hatch.SelectedEggs = setSelectionFromList(Config.Hatch.SelectedEggs, cleaned)
end

local function mergeConfig(target, source, allowUnknown)
    if type(target) ~= "table" or type(source) ~= "table" then
        return
    end
    for key, value in pairs(source) do
        if type(target[key]) == "table" and type(value) == "table" then
            mergeConfig(target[key], value, true)
        elseif target[key] ~= nil or allowUnknown then
            target[key] = value
        end
    end
end

local function loadConfig()
    if type(readfile) ~= "function" or type(isfile) ~= "function" or not isfile(CONFIG_FILE) then
        return
    end
    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_FILE))
    end)
    if ok and type(decoded) == "table" then
        mergeConfig(Config, decoded, false)
    end
end

local saveQueued = false
local function saveConfigSoon()
    if saveQueued then
        return
    end
    saveQueued = true
    task.delay(0.5, function()
        saveQueued = false
        if type(writefile) ~= "function" then
            return
        end
        pcall(function()
            writefile(CONFIG_FILE, HttpService:JSONEncode(Config))
        end)
    end)
end

loadConfig()
normalizeEggSelection()

