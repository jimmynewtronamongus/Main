end

function Actions.KgBoostPetsOnce()
    local fired = 0
    local elephant = highestPetByName("Elephant")
    if not elephant then
        log("KG boost skipped: no Elephant pet found.")
        return 0
    end

    setSinglePetSelection(Config.Pets.KgBoostTeam, elephant)
    local currentKg = petKg(elephant)
    local stopAt = tonumber(Config.Pets.KgBoostStopAt) or 5.4
    if currentKg >= stopAt then
        log(("KG boost stopped: Elephant is %.2fkg / %.2fkg."):format(currentKg, stopAt))
        return 0
    end

    for _, entry in ipairs(selectedEntries("Pets", Config.Pets.KgBoostTeam)) do
        local uuid = entry.Uuid
        if uuid then
            local ok = callRemote("PetBoostService", "Weight", uuid)
                or callRemote("PetBoostService", "KG", uuid)
                or callRemote("PetBoostService", "Size", uuid)
                or callRemote("PetBoostService", "Boost", uuid)
            if ok then fired += 1 end
        end
    end
    log(("KG boost pets sent %d request(s)."):format(fired))
end

function Actions.FavoritePetsOnce()
    local desired = Config.Pets.FavoriteMode ~= "Unfavorite"
    local fired = 0
    for _, entry in ipairs(selectedEntries("Pets", Config.Pets.SelectedPets)) do
        local uuid = entry.Uuid
        local variants = {}
        if uuid then
            variants[#variants + 1] = {uuid}
            variants[#variants + 1] = {uuid, desired}
        end
        variants[#variants + 1] = {entry.Instance}
        variants[#variants + 1] = {entry.Instance, desired}
        fired += callVariants("FavoriteItem", variants, 0.02)
    end
    log(("Favorite pets sent %d request(s)."):format(fired))
end

