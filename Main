local dragging = false
local dragStart
local startPos
topbar.InputBegan:Connect(function(inputObject)
    if inputObject.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = inputObject.Position
        startPos = window.Position
    end
end)
topbar.InputEnded:Connect(function(inputObject)
    if inputObject.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)
UserInputService.InputChanged:Connect(function(inputObject)
    if dragging and inputObject.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = inputObject.Position - dragStart
        window.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputBegan:Connect(function(inputObject, processed)
    if not processed and inputObject.KeyCode == Enum.KeyCode.RightShift then
        window.Visible = not window.Visible
    end
end)
close.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

player.CharacterAdded:Connect(function(newCharacter)
    character = newCharacter
    task.delay(1, refreshInventory)
end)
if backpack then
    backpack.ChildAdded:Connect(function() task.delay(0.2, refreshInventory) end)
    backpack.ChildRemoved:Connect(function() task.delay(0.2, refreshInventory) end)
end

local function tickAction(key, interval, busyKey, callback)
    local now = os.clock()
    State.Last[key] = State.Last[key] or 0
    if State.Busy[busyKey] or now - State.Last[key] < interval then
        return
    end
    State.Last[key] = now
    State.Busy[busyKey] = true
    task.spawn(function()
        pcall(callback)
        State.Busy[busyKey] = false
    end)
end

task.spawn(function()
    while screenGui.Parent do
        if Config.Hatch.AutoHatch then
            tickAction("Hatch", tonumber(Config.Hatch.HatchInterval) or 1.5, "Hatch", Actions.HatchOnce)
        end
        if Config.Hatch.AutoPlaceEggs then
            tickAction("PlaceEggs", tonumber(Config.Hatch.PlaceInterval) or 8, "PlaceEggs", Actions.PlaceEggsOnce)
        end
        if Config.Pets.AutoFeed then
            tickAction("Feed", tonumber(Config.Pets.FeedInterval) or 2, "Feed", Actions.FeedPetsOnce)
        end
        if Config.Pets.AutoLevel then
            tickAction("Level", tonumber(Config.Pets.LevelInterval) or 5, "Level", Actions.LevelPetsOnce)
        end
        if Config.Pets.AutoKgBoost then
            tickAction("KgBoost", tonumber(Config.Pets.KgBoostInterval) or 5, "KgBoost", Actions.KgBoostPetsOnce)
        end
        if Config.Pets.AutoFavorite then
            tickAction("Favorite", 6, "Favorite", Actions.FavoritePetsOnce)
        end
        if Config.Shops.AutoBuy then
            tickAction("Buy", tonumber(Config.Shops.BuyInterval) or 3, "Buy", Actions.AutoBuyOnce)
        end
        if Config.Rewards.AutoOpenPacks then
            tickAction("Packs", tonumber(Config.Rewards.PackInterval) or 12, "Packs", Actions.OpenSeedPacksOnce)
        end
        if Config.Utility.AutoCollectFruit then
            tickAction("Fruit", tonumber(Config.Utility.FruitInterval) or 2, "Fruit", Actions.CollectFruitOnce)
        end
        if Config.Utility.AutoSellFruit then
            tickAction("SellFruit", 10, "SellFruit", Actions.SellFruitOnce)
        end
        if Config.Utility.AutoPlantSeeds then
            tickAction("Plant", tonumber(Config.Utility.PlantInterval) or 0.6, "Plant", Actions.PlantSeedsOnce)
        end
        if Config.Utility.AutoRebirth then
            tickAction("Rebirth", tonumber(Config.Utility.RebirthInterval) or 10, "Rebirth", Actions.RebirthOnce)
        end
        if Config.Hatch.EggEsp then
            tickAction("EggEsp", 0.35, "EggEsp", updateEggEsp)
        else
            clearEggEsp()
        end

        local active = 0
        if Config.Hatch.AutoHatch then active += 1 end
        if Config.Hatch.AutoPlaceEggs then active += 1 end
        if Config.Pets.AutoFeed then active += 1 end
        if Config.Pets.AutoLevel then active += 1 end
        if Config.Pets.AutoKgBoost then active += 1 end
        if Config.Pets.AutoFavorite then active += 1 end
        if Config.Shops.AutoBuy then active += 1 end
        if Config.Rewards.AutoOpenPacks then active += 1 end
        if Config.Utility.AutoCollectFruit then active += 1 end
        if Config.Utility.AutoSellFruit then active += 1 end
        if Config.Utility.AutoPlantSeeds then active += 1 end
        if Config.Utility.AutoRebirth then active += 1 end
        setStatus(active > 0 and (tostring(active) .. " active") or "Idle")

        task.wait(0.2)
    end
end)

installEggRemoteListeners()
refreshInventory()
switch("Dashboard")
if Config.Utility.AntiLag then
    Actions.SetAntiLag(true)
end
if Config.Utility.RemoveTextures then
    Actions.SetTexturesRemoved(true)
end
log("GAG Main rewrite loaded.")
