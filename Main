local url = "https://raw.githubusercontent.com/jimmynewtronamongus/Main/refs/heads/codex-initial-link/MainSource?cb=bootstrap-1"
local ok, source = pcall(function()
    return game:HttpGet(url)
end)

if not ok or type(source) ~= "string" or source == "" then
    warn("[GAG Main] Failed to fetch MainSource: " .. tostring(source))
    return
end

local chunk, err = loadstring(source)
if not chunk then
    warn("[GAG Main] MainSource compile failed: " .. tostring(err))
    return
end

return chunk()
