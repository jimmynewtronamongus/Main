local Actions = {}
local UIRefresh = {}
local inventorySummaryLabel
local queueInventoryRefresh

function selectedListToText(selected, emptyText)
    selected = selected or {__order = {}}

    local names = {}
    for _, name in ipairs(selected.__order or {}) do
        if selected[name] then
            names[#names + 1] = name
        end
    end

    if #names == 0 then
        for name, enabled in pairs(selected) do
            if type(name) ~= "string" or name:sub(1, 2) ~= "__" then
                if enabled then
                    names[#names + 1] = name
                end
            end
        end
        table.sort(names)
    end

    if #names == 0 then
        return emptyText or "None"
    end

    return table.concat(names, ", ")
end

function isSelectionMetadataKey(key)
    return type(key) == "string" and key:sub(1, 2) == "__"
end

function selectedTableEnsureUuidKeys(selected)
    selected.__uuidKeys = selected.__uuidKeys or {}
    return selected.__uuidKeys
end

function selectedTableRememberUuid(selected, uuid)
    local key = uuid and uuidCacheKey(uuid) or nil
    if key and key ~= "" then
        selectedTableEnsureUuidKeys(selected)[key] = true
    end
end

function copyArrayToSelected(options)
    local selected = {__order = {}, __uuidKeys = {}}
    for _, option in ipairs(options) do
        selected.__order[#selected.__order + 1] = option
    end
    return selected
end

function syncSelectedOptions(selected, options)
    selected.__order = {}

    local available = {}
    for _, option in ipairs(options) do
        selected.__order[#selected.__order + 1] = option
        available[option] = true
        if selected[option] == nil then
            selected[option] = false
        end
    end

    for key in pairs(selected) do
        if not isSelectionMetadataKey(key) and not available[key] then
            selected[key] = nil
        end
    end
end

function hasOption(options, value)
    for _, option in ipairs(options) do
        if option == value then
            return true
        end
    end
    return false
end

function isSelectedName(selected, name)
    if not selected or not name then
        return false
    end

    return selected[name] == true
end

function selectedPetEntries(selected)
    local entries = {}
    local seen = {}
    for _, name in ipairs(selected and selected.__order or {}) do
        if isSelectedName(selected, name) then
            local entry = Inventory.PetsByName[name]
            if entry and not seen[entry] then
                seen[entry] = true
                entries[#entries + 1] = entry
            end
        end
    end

    for key in pairs((type(selected) == "table" and selected.__uuidKeys) or {}) do
        local entry = findPetEntryByUuidKey(key)
        if entry and not seen[entry] then
            seen[entry] = true
            entries[#entries + 1] = entry
        end
    end

    return entries
end

function entryHasUuidKey(entry, wantedKey)
    if not entry or not wantedKey then
        return false
    end

    for _, uuid in ipairs(entry.UUIDs or {}) do
        if uuidCacheKey(uuid) == wantedKey then
            return true
        end
    end

    return false
end

function captureSelectedPetUuidKeys(selected)
    local keys = {}

    for name, enabled in pairs(selected or {}) do
        if not isSelectionMetadataKey(name) and enabled then
            local entry = Inventory.PetsByName[name]
            if entry then
                for _, uuid in ipairs(entry.UUIDs or {}) do
                    local key = uuidCacheKey(uuid)
                    keys[key] = true
                    selectedTableRememberUuid(selected, uuid)

                    rememberPetName(uuid, name)
                end
            else
                local uuid = canonicalizeUuid(name)
                if uuid then
                    local key = uuidCacheKey(uuid)
                    keys[key] = true
                    selectedTableRememberUuid(selected, uuid)
                end
            end
        end
    end

    for key in pairs((type(selected) == "table" and selected.__uuidKeys) or {}) do
        keys[key] = true
    end

    return keys
end

function syncSelectedPetOptions(selected, options, selectedUuidKeys)
    syncSelectedOptions(selected, options)

    if not selectedUuidKeys then
        return
    end

    selected.__uuidKeys = selectedUuidKeys
    for _, option in ipairs(options) do
        local entry = Inventory.PetsByName[option]
        for key in pairs(selectedUuidKeys) do
            if entryHasUuidKey(entry, key) then
                selected[option] = true
                break
            end
        end
    end

    for key in pairs(selectedUuidKeys) do
        local rememberedName = PetDisplayNamesByUuid[key]
        local entry = findPetEntryByUuidKey(key)
        local displayName = entry and entry.Name or rememberedName
        if displayName and displayName ~= "" and not selected[displayName] then
            selected[displayName] = true
            local exists = false
            for _, option in ipairs(selected.__order or {}) do
                if option == displayName then
                    exists = true
                    break
                end
            end
            if not exists then
                selected.__order[#selected.__order + 1] = displayName
            end
        end
    end
end

function isTrackedPetUuid(uuid)
    local key = uuid and uuidCacheKey(uuid) or nil
    if not key or key == "" then
        return false
    end

    for _, selected in ipairs({
        Config.Main.LevelPets,
        Config.Main.FeedPets,
        Config.Main.KgBoosterPets,
        Config.Main.KgTargetPets,
        Config.Main.PickAndPlacePets,
        Config.Mutation.PetsToUse,
        Config.Mutation.MutationCooldownPets,
        Config.Mutation.PetMutationGivers,
        Config.Misc.FavoritePets,
        Config.Hatch.EggReductionPets,
        Config.Hatch.HatchSupportPets,
        Config.Hatch.SealPets,
    }) do
        if type(selected) == "table" and selected.__uuidKeys and selected.__uuidKeys[key] then
            return true
        end
    end

    return false
end

function nextSelectedPetEntry(selected, runtimeIndexKey, skipEntry)
    local entries = selectedPetEntries(selected)
    if #entries == 0 then
        return nil
    end

    local startIndex = tonumber(Runtime[runtimeIndexKey]) or 1
    for offset = 0, #entries - 1 do
        local index = ((startIndex + offset - 1) % #entries) + 1
        local entry = entries[index]
        Runtime[runtimeIndexKey] = (index % #entries) + 1

        if not skipEntry or not skipEntry(entry) then
            return entry
        end
    end

    return nil
end

function selectedFruitEntries(selected)
    local entries = {}
    for _, name in ipairs(selected and selected.__order or {}) do
        if isSelectedName(selected, name) then
            local entry = Inventory.FruitsByName[name]
            if entry then
                entries[#entries + 1] = entry
            end
        end
    end
    return entries
end

function selectedFruitCollectEntries(selected)
    local entries = {}
    for _, name in ipairs(selected and selected.__order or {}) do
        if isSelectedName(selected, name) then
            local entry = Inventory.FarmFruitsByName[name] or Inventory.FruitsByName[name]
            if entry then
                entries[#entries + 1] = entry
            end
        end
    end
    return entries
end

function selectedSeedEntries(selected)
    local entries = {}
    for _, name in ipairs(selected and selected.__order or {}) do
        if isSelectedName(selected, name) then
            local entry = Inventory.SeedsByName[name]
            if entry then
                entries[#entries + 1] = entry
            end
        end
    end
    return entries
end

function addUniqueInstance(list, seen, instance)
    if instance and instance.Parent and not seen[instance] then
        seen[instance] = true
        list[#list + 1] = instance
    end
end

function getFruitCollectTargets(entry)
    local targets = {}
    local seen = {}

    for _, instance in ipairs(entry and entry.Instances or {}) do
        if instance and instance:IsDescendantOf(Workspace) then
            addUniqueInstance(targets, seen, instance)

            for _, child in ipairs(instance:GetChildren()) do
                local text = getAttributeText(child)
                if stripStackData(child.Name) == entry.Name or hasAnyKeyword(text, {"fruit", "harvest", "crop"}) then
                    addUniqueInstance(targets, seen, child)
                end
            end

            for _, descendant in ipairs(instance:GetDescendants()) do
                local text = getAttributeText(descendant)
                if stripStackData(descendant.Name) == entry.Name or hasAnyKeyword(text, {"fruit", "harvest", "crop"}) then
                    addUniqueInstance(targets, seen, descendant)
                end
            end
        end
    end

    return targets
end

function firstInstance(entry)
    if entry and entry.Instances then
        return entry.Instances[1]
    end
    return nil
end

function firstToolInstance(entry)
    for _, instance in ipairs(entry and entry.Instances or {}) do
        if instance and instance:IsA("Tool") then
            return instance
        end
    end
    return nil
end

function firstUuid(entry)
    if entry and entry.UUIDs then
        return entry.UUIDs[1]
    end

    local instance = firstInstance(entry)
    return instance and getInstanceUuid(instance) or nil
end

function cachePetEntryName(entry)
    local uuid = firstUuid(entry)
    rememberPetName(uuid, entry and entry.Name)
end

function getPlacementCFrame(slotIndex)
    local activeCharacter = localPlayer.Character
    local root = activeCharacter and activeCharacter:FindFirstChild("HumanoidRootPart")

    if root then
        local index = math.max(1, tonumber(slotIndex) or 1)
        local xOffset = (((index - 1) % 4) - 1.5) * 4
        local zOffset = -6 - (math.floor((index - 1) / 4) * 4)
        return root.CFrame * CFrame.new(xOffset, 0, zOffset)
    end

    return CFrame.new(0, 0, 0)
end

function readInstanceValue(instance)
    if not instance then
        return nil
    end

    if instance:IsA("ObjectValue") then
        return instance.Value
    end

    if instance:IsA("StringValue") or instance:IsA("IntValue") or instance:IsA("NumberValue") then
        return instance.Value
    end

    local ok, value = pcall(function()
        return instance.Value
    end)

    if ok then
        return value
    end

    return nil
end

function ownerMatchesLocalPlayer(ownerValue)
    if ownerValue == localPlayer then
        return true
    end

    if type(typeof) == "function" and typeof(ownerValue) == "Instance" then
        if ownerValue == localPlayer then
            return true
        end

        return ownerValue.Name == localPlayer.Name
    end

    local text = tostring(ownerValue or "")
    return text == localPlayer.Name or tonumber(text) == localPlayer.UserId
end

function isLocalFarm(farm)
    local important = farm and farm:FindFirstChild("Important")
    local data = important and important:FindFirstChild("Data")
    local owner = data and data:FindFirstChild("Owner")

    if owner and ownerMatchesLocalPlayer(readInstanceValue(owner)) then
        return true
    end

    local ok, ownerAttribute = pcall(function()
        return data and data:GetAttribute("Owner")
    end)

    return ok and ownerMatchesLocalPlayer(ownerAttribute)
end

function getLocalFarm()
    local farmRoot = Workspace:FindFirstChild("Farm")
    if not farmRoot then
        return nil
    end

    for _, farm in ipairs(farmRoot:GetChildren()) do
        if isLocalFarm(farm) then
            return farm
        end
    end

    return nil
end

function firstBasePart(instance)
    if not instance then
        return nil
    end

    if instance:IsA("BasePart") then
        return instance
    end

    if instance:IsA("Model") then
        return instance.PrimaryPart or instance:FindFirstChildWhichIsA("BasePart", true)
    end

    return instance:FindFirstChildWhichIsA("BasePart", true)
end

function getEggPlantLocation()
    local farm = getLocalFarm()
    local important = farm and farm:FindFirstChild("Important")
    local plantLocations = important and important:FindFirstChild("Plant_Locations")
    if not plantLocations then
        return nil
    end

    local children = plantLocations:GetChildren()
    return children[2] or children[1]
end

function pointInPart(part, mode, slotIndex)
    if not part then
        return nil
    end

    local function clampAxis(value, halfSize)
        local limit = math.max(0, halfSize - 1)
        return clampNumber(value, -limit, limit)
    end

    local normalizedMode = tostring(mode or "Middle"):lower()
    local index = math.max(1, tonumber(slotIndex) or 1)
    local halfSize = part.Size * 0.5
    local localX = 0
    local localZ = 0

    if normalizedMode == "random" then
        localX = (math.random() - 0.5) * math.max(0, part.Size.X - 2)
        localZ = (math.random() - 0.5) * math.max(0, part.Size.Z - 2)
    elseif normalizedMode == "near player" then
        local activeCharacter = localPlayer.Character
        local root = activeCharacter and activeCharacter:FindFirstChild("HumanoidRootPart")
        if root then
            local localPosition = part.CFrame:PointToObjectSpace(root.Position)
            localX = localPosition.X
            localZ = localPosition.Z
        end
    end

    if normalizedMode ~= "random" then
        local columns = math.max(1, math.floor(math.max(4, part.Size.X - 2) / 3))
        local row = math.floor((index - 1) / columns)
        local column = (index - 1) % columns
        localX = localX + (column - ((columns - 1) / 2)) * 3
        localZ = localZ + row * 3
    else
        localX = localX + (((index - 1) % 3) - 1) * 0.75
        localZ = localZ + ((math.floor((index - 1) / 3) % 3) - 1) * 0.75
    end

    return (part.CFrame * CFrame.new(
        clampAxis(localX, halfSize.X),
        0,
        clampAxis(localZ, halfSize.Z)
    )).Position
end

function getEggPlacementCFrame(slotIndex)
    local location = getEggPlantLocation()
    local part = firstBasePart(location)
    local position = pointInPart(part, Config.Hatch.EggPlacementMode, slotIndex)

    if position then
        return CFrame.new(position)
    end

    return getPlacementCFrame(slotIndex)
end

function getFarmPhysicalContainer(name)
    local farmRoot = Workspace:FindFirstChild("Farm")
    if not farmRoot then
        return nil
    end

    local localFarm = getLocalFarm()
    local localImportant = localFarm and localFarm:FindFirstChild("Important")
    local localContainer = localImportant and localImportant:FindFirstChild(name)
    if localContainer then
        return localContainer
    end

    for _, farm in ipairs(farmRoot:GetChildren()) do
        local important = farm:FindFirstChild("Important")
        local container = important and important:FindFirstChild(name)

        if container then
            return container
        end
    end

    return nil
end

function getFarmPhysicalContainers(name)
    local containers = {}
    local seen = {}
    local function add(container)
        if container and not seen[container] then
            seen[container] = true
            containers[#containers + 1] = container
        end
    end

    add(getFarmPhysicalContainer(name))

    local farmRoot = Workspace:FindFirstChild("Farm")
    if farmRoot then
        local directFarm = farmRoot:FindFirstChild("Farm")
        local directImportant = directFarm and directFarm:FindFirstChild("Important")
        add(directImportant and directImportant:FindFirstChild(name))

        for _, farm in ipairs(farmRoot:GetChildren()) do
            local important = farm:FindFirstChild("Important")
            add(important and important:FindFirstChild(name))
        end
    end

    return containers
end

function collectPhysicalEggObjects()
    local eggs = {}
    local seen = {}
    local function eggRootFor(object, objectsContainer)
        local current = object
        while current and current.Parent and current.Parent ~= objectsContainer do
            if current.Parent.Name == "PetEgg" or isLikelyEggName(current.Parent.Name) then
                current = current.Parent
            else
                break
            end
        end
        return current
    end

    local function add(object)
        if object and not seen[object] and isLikelyEggName(getPhysicalEggName(object)) then
            seen[object] = true
            eggs[#eggs + 1] = object
        end
    end

    for _, objects in ipairs(getFarmPhysicalContainers("Objects_Physical")) do
        for _, child in ipairs(objects:GetChildren()) do
            add(child)
        end
        for _, descendant in ipairs(objects:GetDescendants()) do
            if descendant.Name == "PetEgg" or isLikelyEggName(descendant.Name) then
                add(eggRootFor(descendant, objects))
            end
        end
    end

    return eggs
end

function getPhysicalEggName(instance)
    local name = stripStackData(instance and instance.Name or "")
    local ok, attributes = pcall(function()
        return instance:GetAttributes()
    end)

    if ok and type(attributes) == "table" then
        for _, key in ipairs({"EggName", "EggType", "Name", "Type"}) do
            local value = attributes[key]
            if type(value) == "string" and value ~= "" then
                return normalizeEggDisplayName(value)
            end
        end
    end

    return normalizeEggDisplayName(name)
end

function findHatchableEggObject()
    local objects = getFarmPhysicalContainer("Objects_Physical")
    if not objects then
        return nil
    end

    local priority = {}
    for _, eggName in ipairs(Config.Hatch.EggPriority) do
        priority[#priority + 1] = eggName
    end
    for _, eggName in ipairs(Config.Hatch.SelectedEggs.__order or {}) do
        if Config.Hatch.SelectedEggs[eggName] and not hasOption(priority, eggName) then
            priority[#priority + 1] = eggName
        end
    end

    local eggObjects = collectPhysicalEggObjects()
    for _, wantedEgg in ipairs(priority) do
        for _, object in ipairs(eggObjects) do
            local objectName = getPhysicalEggName(object)
            if objectName == wantedEgg or tostring(object.Name):find(wantedEgg, 1, true) then
                return object
            end
        end
    end

    return eggObjects[1]
end

function equipToolInstance(instance)
    if not instance or not instance:IsA("Tool") then
        return false
    end

    local activeCharacter = localPlayer.Character
    local humanoid = activeCharacter and activeCharacter:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid:EquipTool(instance)
        return true
    end

    return false
end

function isCooldownKey(key)
    local normalized = tostring(key or ""):lower():gsub("[^%w]", "")
    return normalized:find("cooldown", 1, true)
        or normalized:find("remaining", 1, true)
        or normalized:find("timeleft", 1, true)
        or normalized:find("duration", 1, true)
end

function parseCooldownValue(value)
    if type(value) == "number" then
        return value
    end

    if type(value) == "string" then
        return tonumber(value)
    end

    if type(value) ~= "table" then
        return nil
    end

    local firstNumber
    for key, childValue in pairs(value) do
        local parsed = parseCooldownValue(childValue)
        if parsed ~= nil then
            if isCooldownKey(key) then
                return parsed
            end

            firstNumber = firstNumber or parsed
        end
    end

    return firstNumber
end

function getPetCooldownSeconds(uuid)
    if not uuid then
        return nil
    end

    local ok, result = callGameEvent("GetPetCooldown", uuid)
    if not ok then
        return nil
    end

    local cooldown = parseCooldownValue(result)
    if cooldown == nil then
        return nil
    end

    return math.max(0, cooldown)
end

function waitForPetAbilityFinished(uuid, petInstance)
    local env = (type(getgenv) == "function" and getgenv()) or _G
    local checker = type(env) == "table" and env.GAG_IsPetAbilityFinished or nil
    local hasChecker = type(checker) == "function"
    local hasCooldownRemote = findGameEventRemote("GetPetCooldown") ~= nil

    if not hasChecker and not hasCooldownRemote then
        return true
    end

    local started = os.clock()
    while true do
        if hasChecker then
            local ok, finished = pcall(checker, uuid, petInstance)
            if ok and finished then
                return true
            end
        else
            local cooldown = getPetCooldownSeconds(uuid)
            if cooldown == nil or cooldown <= 0 then
                return true
            end
        end

        if os.clock() - started > 30 then
            return false
        end

        task.wait(0.1)
    end

    return false
end

function normalizeLookupKey(value)
    return tostring(value or ""):lower():gsub("[^%w]", "")
end

function keyMatchesAny(key, names)
    local normalized = normalizeLookupKey(key)
    for _, name in ipairs(names) do
        local wanted = normalizeLookupKey(name)
        if normalized == wanted or normalized:find(wanted, 1, true) then
            return true
        end
    end
    return false
end

function keyHasAny(key, names)
    local normalized = normalizeLookupKey(key)
    for _, name in ipairs(names) do
        if normalized:find(normalizeLookupKey(name), 1, true) then
            return true
        end
    end
    return false
end

function readNumericField(root, names, excludedNames)
    if not root then
        return nil
    end

    excludedNames = excludedNames or {}

    local okAttributes, attributes = pcall(function()
        return root:GetAttributes()
    end)

    if okAttributes and type(attributes) == "table" then
        for key, value in pairs(attributes) do
            if type(value) == "number" and keyMatchesAny(key, names) and not keyHasAny(key, excludedNames) then
                return value
            end
        end
    end

    local function readInstanceValue(instance)
        if not instance then
            return nil
        end

        if (instance:IsA("NumberValue") or instance:IsA("IntValue"))
            and keyMatchesAny(instance.Name, names)
            and not keyHasAny(instance.Name, excludedNames)
        then
            return instance.Value
        end

        return nil
    end

    local directValue = readInstanceValue(root)
    if directValue ~= nil then
        return directValue
    end

    for _, child in ipairs(root:GetChildren()) do
        local value = readInstanceValue(child)
        if value ~= nil then
            return value
        end
    end

    for _, descendant in ipairs(root:GetDescendants()) do
        local value = readInstanceValue(descendant)
        if value ~= nil then
            return value
        end
    end

    return nil
end

function readBooleanField(root, names)
    if not root then
        return nil
    end

    local okAttributes, attributes = pcall(function()
        return root:GetAttributes()
    end)

    if okAttributes and type(attributes) == "table" then
        for key, value in pairs(attributes) do
            if type(value) == "boolean" and keyMatchesAny(key, names) then
                return value
            end
        end
    end

    local function readInstanceValue(instance)
        if instance and instance:IsA("BoolValue") and keyMatchesAny(instance.Name, names) then
            return instance.Value
        end
        return nil
    end

    local directValue = readInstanceValue(root)
    if directValue ~= nil then
        return directValue
    end

    for _, child in ipairs(root:GetChildren()) do
        local value = readInstanceValue(child)
        if value ~= nil then
            return value
        end
    end

    for _, descendant in ipairs(root:GetDescendants()) do
        local value = readInstanceValue(descendant)
        if value ~= nil then
            return value
        end
    end

    return nil
end

function findPhysicalPetByUuid(uuid)
    if not uuid then
        return nil
    end

    local petsPhysical = Workspace:FindFirstChild("PetsPhysical")
    local petMover = petsPhysical and petsPhysical:FindFirstChild("PetMover")
    if not petMover then
        return nil
    end

    local compactUuid = tostring(uuid):gsub("[{}]", "")
    return petMover:FindFirstChild(tostring(uuid))
        or petMover:FindFirstChild("{" .. compactUuid .. "}")
        or petMover:FindFirstChild(compactUuid)
end

function getPetHungerPercent(entry)
    local uuid = firstUuid(entry)
    local roots = {
        firstInstance(entry),
        findPhysicalPetByUuid(uuid),
    }

    for _, root in ipairs(roots) do
        local current = readNumericField(root, {"Hunger", "CurrentHunger", "Food", "Satiety"}, {"Max", "Capacity"})
        if current ~= nil then
            local maxValue = readNumericField(root, {"MaxHunger", "HungerMax", "MaxFood", "FoodCapacity"})

            if maxValue and maxValue > 0 then
                return clampNumber((current / maxValue) * 100, 0, 100)
            end

            if current <= 1 then
                return clampNumber(current * 100, 0, 100)
            end

            return clampNumber(current, 0, 100)
        end
    end

    return nil
end

