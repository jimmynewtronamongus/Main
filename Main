    button.TextSize = 12
    button.Parent = parent

    makeCorner(button, 7)
    makeStroke(button, Color3.fromRGB(255, 214, 132), 1)

    button.MouseButton1Click:Connect(function()
        if callback then
            callback()
        end
    end)

    return button
end

function createTextInput(parent, labelText, placeholder, default, callback)
    local row = createRow(parent, 44)

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Position = UDim2.fromOffset(12, 0)
    label.Size = UDim2.new(0.38, -14, 1, 0)
    label.Font = Enum.Font.GothamMedium
    label.Text = labelText
    label.TextColor3 = Theme.Text
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextTruncate = Enum.TextTruncate.AtEnd
    label.Parent = row

    local box = Instance.new("TextBox")
    box.AnchorPoint = Vector2.new(1, 0.5)
    box.Position = UDim2.new(1, -10, 0.5, 0)
    box.Size = UDim2.new(0.62, -8, 0, 30)
    box.BackgroundColor3 = Theme.Input
    box.BorderSizePixel = 0
    box.ClearTextOnFocus = false
    box.Font = Enum.Font.Gotham
    box.PlaceholderText = placeholder or ""
    box.PlaceholderColor3 = Theme.Muted
    box.Text = tostring(default or "")
    box.TextColor3 = Theme.Text
    box.TextSize = 12
    box.TextXAlignment = Enum.TextXAlignment.Left
    box.Parent = row

    makeCorner(box, 6)
    makeStroke(box, Theme.StrokeSoft, 1)
    makePadding(box, 8)

    box.FocusLost:Connect(function()
        if callback then
            callback(box.Text)
            scheduleSaveConfig()
        end
    end)

    return box
end

function optionListHeight(optionCount)
    return math.min(math.max(optionCount or 1, 1) * 32 + 10, 230)
end

function createDropdown(parent, labelText, options, default, callback)
    local currentOptions = options or {}
    local currentValue = default or currentOptions[1]

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 44)
    container.AutomaticSize = Enum.AutomaticSize.Y
    container.Parent = parent

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 6)
    layout.Parent = container

    local row = createRow(container, 44)
    row.LayoutOrder = 1

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Position = UDim2.fromOffset(12, 0)
    label.Size = UDim2.new(0.38, -14, 1, 0)
    label.Font = Enum.Font.GothamMedium
    label.Text = labelText
    label.TextColor3 = Theme.Text
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextTruncate = Enum.TextTruncate.AtEnd
    label.Parent = row

    local button = Instance.new("TextButton")
    button.AnchorPoint = Vector2.new(1, 0.5)
    button.Position = UDim2.new(1, -10, 0.5, 0)
    button.Size = UDim2.new(0.62, -8, 0, 30)
    button.BackgroundColor3 = Theme.Input
    button.BorderSizePixel = 0
    button.Font = Enum.Font.Gotham
    button.Text = tostring(currentValue or "No items found")
    button.TextColor3 = Theme.Text
    button.TextSize = 12
    button.TextXAlignment = Enum.TextXAlignment.Left
    button.TextTruncate = Enum.TextTruncate.AtEnd
    button.Parent = row
    makeCorner(button, 6)
    makeStroke(button, Theme.StrokeSoft, 1)
    makePadding(button, 8)

    local list = Instance.new("ScrollingFrame")
    list.BackgroundColor3 = Theme.Input
    list.BorderSizePixel = 0
    list.Size = UDim2.new(1, 0, 0, optionListHeight(#currentOptions))
    list.ClipsDescendants = true
    list.Visible = false
    list.LayoutOrder = 2
    list.ScrollBarThickness = 4
    list.ScrollBarImageColor3 = Theme.Accent
    list.CanvasSize = UDim2.fromOffset(0, 0)
    list.Parent = container
    makeCorner(list, 7)
    makeStroke(list, Theme.StrokeSoft, 1)
    makePadding(list, 4)

    local listLayout = Instance.new("UIListLayout")
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Padding = UDim.new(0, 4)
    listLayout.Parent = list

    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        list.CanvasSize = UDim2.fromOffset(0, listLayout.AbsoluteContentSize.Y + 8)
    end)

    local function clearDropdownItems()
        for _, child in ipairs(list:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
    end

    local function rebuildDropdown()
        clearDropdownItems()
        list.Size = UDim2.new(1, 0, 0, optionListHeight(#currentOptions))

        if #currentOptions == 0 then
            local empty = Instance.new("TextButton")
            empty.LayoutOrder = 1
            empty.BackgroundColor3 = Theme.PanelAlt
            empty.BorderSizePixel = 0
            empty.Size = UDim2.new(1, 0, 0, 28)
            empty.AutoButtonColor = false
            empty.Font = Enum.Font.Gotham
            empty.Text = "No items found"
            empty.TextColor3 = Theme.Muted
            empty.TextSize = 12
            empty.TextXAlignment = Enum.TextXAlignment.Left
            empty.Parent = list
            makeCorner(empty, 4)
            makePadding(empty, 8)
            return
        end

        for index, option in ipairs(currentOptions) do
            local item = Instance.new("TextButton")
            item.LayoutOrder = index
            item.BackgroundColor3 = Theme.PanelAlt
            item.BorderSizePixel = 0
            item.Size = UDim2.new(1, 0, 0, 28)
            item.Font = Enum.Font.Gotham
            item.Text = option
            item.TextColor3 = Theme.Text
            item.TextSize = 12
            item.TextXAlignment = Enum.TextXAlignment.Left
            item.TextTruncate = Enum.TextTruncate.AtEnd
            item.Parent = list
            makeCorner(item, 4)
            makePadding(item, 8)

            item.MouseButton1Click:Connect(function()
                currentValue = option
                button.Text = option
                list.Visible = false
                if callback then
                    callback(option)
                    scheduleSaveConfig()
                end
            end)
        end
    end

    rebuildDropdown()

    button.MouseButton1Click:Connect(function()
        list.Visible = not list.Visible
    end)

    return function(value, newOptions, fireCallback)
        if newOptions then
            currentOptions = newOptions
            rebuildDropdown()
        end

        if value == nil or value == "" then
            value = currentOptions[1]
        end

        if value ~= nil and value ~= "" and not hasOption(currentOptions, value) and #currentOptions > 0 then
            value = currentOptions[1]
        end

        currentValue = value
        button.Text = tostring(currentValue or "No items found")

        if fireCallback ~= false and callback and currentValue then
            callback(value)
        end
    end
end

function createMultiSelect(parent, labelText, options, selected, callback)
    local currentOptions = options or {}
    selected = selected or copyArrayToSelected(currentOptions)
    syncSelectedOptions(selected, currentOptions)

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 44)
    container.AutomaticSize = Enum.AutomaticSize.Y
    container.Parent = parent

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 6)
    layout.Parent = container

    local row = createRow(container, 44)
    row.LayoutOrder = 1

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Position = UDim2.fromOffset(12, 0)
    label.Size = UDim2.new(0.35, -12, 1, 0)
    label.Font = Enum.Font.GothamMedium
    label.Text = labelText
    label.TextColor3 = Theme.Text
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextTruncate = Enum.TextTruncate.AtEnd
    label.Parent = row

    local button = Instance.new("TextButton")
    button.AnchorPoint = Vector2.new(1, 0.5)
    button.Position = UDim2.new(1, -10, 0.5, 0)
    button.Size = UDim2.new(0.65, -8, 0, 30)
    button.BackgroundColor3 = Theme.Input
    button.BorderSizePixel = 0
    button.Font = Enum.Font.Gotham
    button.Text = selectedListToText(selected)
    button.TextColor3 = Theme.Text
    button.TextSize = 12
    button.TextXAlignment = Enum.TextXAlignment.Left
    button.TextTruncate = Enum.TextTruncate.AtEnd
    button.Parent = row
    makeCorner(button, 6)
    makeStroke(button, Theme.StrokeSoft, 1)
    makePadding(button, 8)

    local list = Instance.new("ScrollingFrame")
    list.BackgroundColor3 = Theme.Input
    list.BorderSizePixel = 0
    list.Size = UDim2.new(1, 0, 0, optionListHeight(#currentOptions))
    list.ClipsDescendants = true
    list.Visible = false
    list.LayoutOrder = 2
    list.ScrollBarThickness = 4
    list.ScrollBarImageColor3 = Theme.Accent
    list.CanvasSize = UDim2.fromOffset(0, 0)
    list.Parent = container
    makeCorner(list, 7)
    makeStroke(list, Theme.StrokeSoft, 1)
    makePadding(list, 4)

    local listLayout = Instance.new("UIListLayout")
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Padding = UDim.new(0, 4)
    listLayout.Parent = list

    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        list.CanvasSize = UDim2.fromOffset(0, listLayout.AbsoluteContentSize.Y + 8)
    end)

    local itemButtons = {}

    local function clearMultiSelectItems()
        for _, child in ipairs(list:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
    end

    local function refresh()
        syncSelectedOptions(selected, currentOptions)
        button.Text = selectedListToText(selected)
        for option, item in pairs(itemButtons) do
            local active = selected[option] == true
            item.Text = (active and "[x] " or "[ ] ") .. option
            item.BackgroundColor3 = active and Theme.AccentSoft or Theme.PanelAlt
            item.TextColor3 = active and Theme.Text or Theme.Muted
        end
    end

    local function rebuildMultiSelect()
        clearMultiSelectItems()
        itemButtons = {}
        list.Size = UDim2.new(1, 0, 0, optionListHeight(#currentOptions))

        if #currentOptions == 0 then
            local empty = Instance.new("TextButton")
            empty.LayoutOrder = 1
            empty.BackgroundColor3 = Theme.PanelAlt
            empty.BorderSizePixel = 0
            empty.Size = UDim2.new(1, 0, 0, 28)
            empty.AutoButtonColor = false
            empty.Font = Enum.Font.Gotham
            empty.Text = "No items found"
            empty.TextColor3 = Theme.Muted
            empty.TextSize = 12
            empty.TextXAlignment = Enum.TextXAlignment.Left
            empty.Parent = list
            makeCorner(empty, 4)
            makePadding(empty, 8)
            return
        end

        for index, option in ipairs(currentOptions) do
            local item = Instance.new("TextButton")
            item.LayoutOrder = index
            item.BackgroundColor3 = Theme.PanelAlt
            item.BorderSizePixel = 0
            item.Size = UDim2.new(1, 0, 0, 28)
            item.Font = Enum.Font.Gotham
            item.Text = option
            item.TextColor3 = Theme.Text
            item.TextSize = 12
            item.TextXAlignment = Enum.TextXAlignment.Left
            item.TextTruncate = Enum.TextTruncate.AtEnd
            item.Parent = list
            makeCorner(item, 4)
            makePadding(item, 8)
            itemButtons[option] = item

            item.MouseButton1Click:Connect(function()
                selected[option] = not selected[option]
                local petEntry = Inventory.PetsByName[option]
                if petEntry then
                    if selected[option] then
                        for _, uuid in ipairs(petEntry.UUIDs or {}) do
                            selectedTableRememberUuid(selected, uuid)
                        end
                    elseif selected.__uuidKeys then
                        for _, uuid in ipairs(petEntry.UUIDs or {}) do
                            selected.__uuidKeys[uuidCacheKey(uuid)] = nil
                        end
                    end
                end
                refresh()
                if callback then
                    callback(selected)
                    scheduleSaveConfig()
                end
            end)
        end
    end

    button.MouseButton1Click:Connect(function()
        list.Visible = not list.Visible
    end)

    rebuildMultiSelect()
    refresh()

    return function(newSelected, newOptions)
        if newOptions then
            currentOptions = newOptions
        end

        if newSelected then
            selected = newSelected
        end

        rebuildMultiSelect()
        refresh()
    end
end

function parsePriority(text)
    local priority = {}
    for raw in string.gmatch(text or "", "([^,]+)") do
        local value = raw:gsub("^%s+", ""):gsub("%s+$", "")
        if value ~= "" then
            priority[#priority + 1] = value
        end
    end
    return priority
end

function selectedToPriority(selected)
    local priority = {}
    for _, name in ipairs(selected.__order or {}) do
        if selected[name] then
            priority[#priority + 1] = name
        end
    end
    return priority
end

function selectedEggRuleOptions()
    local selectedEggs = selectedToPriority(Config.Hatch.SelectedEggs)
    if #selectedEggs > 0 then
        return selectedEggs
    end

    return OPTIONS.Eggs
end

function eggPetOptions(eggName)
    if not eggName or eggName == "" then
        return {}
    end

    return OPTIONS.EggPetsByEgg[eggName] or {}
end

function normalizeEggPriorityToSelected()
    local selectedEggs = selectedEggRuleOptions()
    local filteredPriority = {}

    for _, eggName in ipairs(Config.Hatch.EggPriority) do
        if hasOption(selectedEggs, eggName) then
            filteredPriority[#filteredPriority + 1] = eggName
        end
    end

    Config.Hatch.EggPriority = filteredPriority
    if #Config.Hatch.EggPriority == 0 and selectedEggs[1] then
        Config.Hatch.EggPriority = {selectedEggs[1]}
    end

    return selectedEggs
end

function refreshInventorySummary()
    if not inventorySummaryLabel then
        return
    end

    inventorySummaryLabel.Text = ("Inventory data: %d pets | %d eggs | %d seeds | %d fruits"):format(
        #OPTIONS.Pets,
        #OPTIONS.Eggs,
        #OPTIONS.Seeds,
        #OPTIONS.Fruits
    )
end

function refreshInventoryOptions(reason)
    local selectedPetUuidKeys = {
        LevelPets = captureSelectedPetUuidKeys(Config.Main.LevelPets),
        FeedPets = captureSelectedPetUuidKeys(Config.Main.FeedPets),
        KgBoosterPets = captureSelectedPetUuidKeys(Config.Main.KgBoosterPets),
        KgTargetPets = captureSelectedPetUuidKeys(Config.Main.KgTargetPets),
        PickAndPlacePets = captureSelectedPetUuidKeys(Config.Main.PickAndPlacePets),
        MutationPets = captureSelectedPetUuidKeys(Config.Mutation.PetsToUse),
        MutationCooldownPets = captureSelectedPetUuidKeys(Config.Mutation.MutationCooldownPets),
        PetMutationGivers = captureSelectedPetUuidKeys(Config.Mutation.PetMutationGivers),
        FavoritePets = captureSelectedPetUuidKeys(Config.Misc.FavoritePets),
        EggReductionPets = captureSelectedPetUuidKeys(Config.Hatch.EggReductionPets),
        HatchSupportPets = captureSelectedPetUuidKeys(Config.Hatch.HatchSupportPets),
        SealPets = captureSelectedPetUuidKeys(Config.Hatch.SealPets),
    }

    scanInventory()
    local placedPetOptions = sortedPlacedPetNames()

    syncSelectedPetOptions(Config.Main.LevelPets, OPTIONS.Pets, selectedPetUuidKeys.LevelPets)
    syncSelectedPetOptions(Config.Main.FeedPets, placedPetOptions, selectedPetUuidKeys.FeedPets)
    syncSelectedPetOptions(Config.Main.KgBoosterPets, OPTIONS.Pets, selectedPetUuidKeys.KgBoosterPets)
    syncSelectedPetOptions(Config.Main.KgTargetPets, OPTIONS.Pets, selectedPetUuidKeys.KgTargetPets)
    syncSelectedPetOptions(Config.Main.PickAndPlacePets, OPTIONS.Pets, selectedPetUuidKeys.PickAndPlacePets)
    syncSelectedOptions(Config.Hatch.SelectedEggs, OPTIONS.Eggs)
    syncSelectedOptions(Config.Hatch.KeepMutations, OPTIONS.Mutations)
    syncSelectedOptions(Config.Mutation.SelectedMutations, OPTIONS.Mutations)
    syncSelectedPetOptions(Config.Mutation.PetsToUse, OPTIONS.Pets, selectedPetUuidKeys.MutationPets)
    syncSelectedPetOptions(Config.Mutation.MutationCooldownPets, OPTIONS.Pets, selectedPetUuidKeys.MutationCooldownPets)
    syncSelectedPetOptions(Config.Mutation.PetMutationGivers, OPTIONS.Pets, selectedPetUuidKeys.PetMutationGivers)
    syncSelectedPetOptions(Config.Misc.FavoritePets, OPTIONS.Pets, selectedPetUuidKeys.FavoritePets)
    syncSelectedPetOptions(Config.Hatch.EggReductionPets, OPTIONS.Pets, selectedPetUuidKeys.EggReductionPets)
    syncSelectedPetOptions(Config.Hatch.HatchSupportPets, OPTIONS.Pets, selectedPetUuidKeys.HatchSupportPets)
    syncSelectedPetOptions(Config.Hatch.SealPets, OPTIONS.Pets, selectedPetUuidKeys.SealPets)
    syncSelectedOptions(Config.Misc.FruitsToCollect, OPTIONS.FruitsToCollect)
    syncSelectedOptions(Config.Misc.FruitsToSell, OPTIONS.FruitsToSell)
    syncSelectedOptions(Config.Misc.SeedsToPlace, OPTIONS.SeedsToPlace)

    local sellEggRuleOptions = normalizeEggPriorityToSelected()

    if Runtime.SelectedSellRuleEgg == "" or not hasOption(sellEggRuleOptions, Runtime.SelectedSellRuleEgg) then
        Runtime.SelectedSellRuleEgg = sellEggRuleOptions[1] or ""
    end

    for _, eggName in ipairs(sellEggRuleOptions) do
        local petOptions = eggPetOptions(eggName)
        Config.Hatch.SellRulesByEgg[eggName] = Config.Hatch.SellRulesByEgg[eggName] or copyArrayToSelected(petOptions)
        syncSelectedOptions(Config.Hatch.SellRulesByEgg[eggName], petOptions)
    end

    for eggName in pairs(Config.Hatch.SellRulesByEgg) do
        if not hasOption(sellEggRuleOptions, eggName) then
            Config.Hatch.SellRulesByEgg[eggName] = nil
        end
    end

    if UIRefresh.EggsToHatch then
        UIRefresh.EggsToHatch(Config.Hatch.SelectedEggs, OPTIONS.Eggs)
    end

    if UIRefresh.EggPriority then
        UIRefresh.EggPriority(Config.Hatch.EggPriority[1], sellEggRuleOptions, false)
    end

    if UIRefresh.EggRule then
        UIRefresh.EggRule(Runtime.SelectedSellRuleEgg, sellEggRuleOptions, false)
    end

    if UIRefresh.SellPets then
        local sellPetOptions = eggPetOptions(Runtime.SelectedSellRuleEgg)
        local currentSellRule = Runtime.SelectedSellRuleEgg ~= ""
            and (Config.Hatch.SellRulesByEgg[Runtime.SelectedSellRuleEgg] or copyArrayToSelected(sellPetOptions))
            or copyArrayToSelected({})
        UIRefresh.SellPets(currentSellRule, sellPetOptions)
    end

    if UIRefresh.SellRuleSummary then
        UIRefresh.SellRuleSummary.Text = "Keep rule: " .. (Runtime.SelectedSellRuleEgg ~= "" and Runtime.SelectedSellRuleEgg or "No eggs found")
    end

    if UIRefresh.FavoritePets then
        UIRefresh.FavoritePets(Config.Misc.FavoritePets, OPTIONS.Pets)
    end

    if UIRefresh.EggReductionPets then
        UIRefresh.EggReductionPets(Config.Hatch.EggReductionPets, OPTIONS.Pets)
    end

    if UIRefresh.HatchSupportPets then
        UIRefresh.HatchSupportPets(Config.Hatch.HatchSupportPets, OPTIONS.Pets)
    end

    if UIRefresh.SealPets then
        UIRefresh.SealPets(Config.Hatch.SealPets, OPTIONS.Pets)
    end

    if UIRefresh.HatchKeepMutations then
        UIRefresh.HatchKeepMutations(Config.Hatch.KeepMutations, OPTIONS.Mutations)
    end

    if UIRefresh.LevelPets then
        UIRefresh.LevelPets(Config.Main.LevelPets, OPTIONS.Pets)
    end

    if UIRefresh.MainLevelPets then
        UIRefresh.MainLevelPets(Config.Main.LevelPets, OPTIONS.Pets)
    end

    if UIRefresh.FeedPets then
        UIRefresh.FeedPets(Config.Main.FeedPets, placedPetOptions)
    end

    if UIRefresh.KgBoosterPets then
        UIRefresh.KgBoosterPets(Config.Main.KgBoosterPets, OPTIONS.Pets)
    end

    if UIRefresh.KgTargetPets then
        UIRefresh.KgTargetPets(Config.Main.KgTargetPets, OPTIONS.Pets)
    end

    if UIRefresh.PickAndPlacePets then
        UIRefresh.PickAndPlacePets(Config.Main.PickAndPlacePets, OPTIONS.Pets)
    end

    if UIRefresh.Mutations then
        UIRefresh.Mutations(Config.Mutation.SelectedMutations, OPTIONS.Mutations)
    end

    if UIRefresh.MutationPets then
        UIRefresh.MutationPets(Config.Mutation.PetsToUse, OPTIONS.Pets)
    end

    if UIRefresh.MutationCooldownPets then
        UIRefresh.MutationCooldownPets(Config.Mutation.MutationCooldownPets, OPTIONS.Pets)
    end

    if UIRefresh.PetMutationGivers then
        UIRefresh.PetMutationGivers(Config.Mutation.PetMutationGivers, OPTIONS.Pets)
    end

    if UIRefresh.FruitsToCollect then
        UIRefresh.FruitsToCollect(Config.Misc.FruitsToCollect, OPTIONS.FruitsToCollect)
    end

    if UIRefresh.FruitsToSell then
        UIRefresh.FruitsToSell(Config.Misc.FruitsToSell, OPTIONS.FruitsToSell)
    end

    if UIRefresh.SeedsToPlace then
        UIRefresh.SeedsToPlace(Config.Misc.SeedsToPlace, OPTIONS.SeedsToPlace)
    end

    refreshInventorySummary()

    if reason then
        log(("Inventory refreshed: %d pets, %d eggs, %d seeds, %d fruits."):format(
            #OPTIONS.Pets,
            #OPTIONS.Eggs,
            #OPTIONS.Seeds,
            #OPTIONS.Fruits
        ))
    end
end

function Actions.AutoLevelPet(enabled)
    log("Auto Lvl Pet " .. (enabled and "enabled" or "disabled") .. " | target " .. tostring(Config.Main.LevelTarget))
end

function Actions.AutoFeedPet(enabled)
    log("Auto Feed Pet " .. (enabled and "enabled" or "disabled") .. " | hunger < " .. tostring(Config.Main.HungerThreshold) .. "%")
end

function feedPetEntry(entry)
    local uuid = firstUuid(entry)
    local instance = firstInstance(entry)

    if not uuid and not instance then
        return false
    end

    local argSets = {}
    if uuid then
        argSets[#argSets + 1] = {"Feed", uuid}
        argSets[#argSets + 1] = {uuid}
        argSets[#argSets + 1] = {"FeedPet", uuid}
    end

    if instance then
        argSets[#argSets + 1] = {"Feed", instance}
        argSets[#argSets + 1] = {instance}
    end

    cachePetEntryName(entry)
    return tryFireGameEventAny("ActivePetService", argSets)
end

function Actions.FeedHungryPetsOnce()
    local threshold = tonumber(Config.Main.HungerThreshold) or 50
    local fedCount = 0

    for _, entry in ipairs(selectedPetEntries(Config.Main.FeedPets)) do
        local uuid = firstUuid(entry)
        if uuid or firstInstance(entry) then
            local hunger = getPetHungerPercent(entry)
            if hunger == nil or hunger < threshold then
                local fired = feedPetEntry(entry)
                if fired then
                    fedCount = fedCount + 1
                    if hunger then
                        log(("Fed %s | hunger %.1f%% < %.1f%%"):format(tostring(entry.Name), hunger, threshold))
                    else
                        log("Fed " .. tostring(entry.Name) .. " | hunger value not exposed")
                    end
                else
                    log("Feed remote did not fire for " .. tostring(entry.Name))
                end
            end
        else
            log("Feed skipped: selected pet has no UUID/tool: " .. tostring(entry.Name))
        end
    end

    if fedCount == 0 then
        log("Feed check complete: no selected pets needed food or feed remote did not fire.")
    end

    return fedCount
end

function getPetLevel(entry)
    for _, instance in ipairs(entry and entry.Instances or {}) do
        local text = tostring(instance.Name)
        local levelText = text:match("%[[Aa]ge%s+(%d+)%]")
            or text:match("%[[Ll]evel%s+(%d+)%]")
            or text:match("[Aa]ge%s+(%d+)")
            or text:match("[Ll]evel%s+(%d+)")

        if levelText then
            return tonumber(levelText)
        end

        local levelValue = readNumericField(instance, {"Age", "Level", "PetLevel"}, {"Max", "Target"})
        if levelValue then
            return levelValue
        end
    end

    return nil
end

function Actions.LevelSelectedPetsOnce()
    local targetLevel = clampNumber(math.floor(tonumber(Config.Main.LevelTarget) or 100), 1, 100)
    local firedCount = 0

    for _, entry in ipairs(selectedPetEntries(Config.Main.LevelPets)) do
        local uuid = firstUuid(entry)
        local level = getPetLevel(entry)

        if uuid and (not level or level < targetLevel) then
            cachePetEntryName(entry)
            local fired = tryFireGameEvent("PetBoostService", "Level", uuid)
                or tryFireGameEvent("PetBoostService", "XP", uuid)
                or tryFireGameEvent("ActivePetService", "Feed", uuid)

            if fired then
                firedCount = firedCount + 1
            end
        end
    end

    if firedCount > 0 then
        log(("Auto Level fired for %d selected pet(s)."):format(firedCount))
    else
        log("Auto Level check complete: no selected pets needed a level pulse.")
    end

    return firedCount
end

function getPetKg(entry)
    local entryKgText = tostring(entry and entry.Name or ""):match("%[(%d+%.?%d*)%s*[Kk][Gg]%]")
        or tostring(entry and entry.Name or ""):match("(%d+%.?%d*)%s*[Kk][Gg]")
    if entryKgText then
        return tonumber(entryKgText)
    end

    for _, instance in ipairs(entry and entry.Instances or {}) do
        local kgText = tostring(instance.Name):match("%[(%d+%.?%d*)%s*[Kk][Gg]%]")
            or tostring(instance.Name):match("(%d+%.?%d*)%s*[Kk][Gg]")
        if kgText then
            return tonumber(kgText)
        end

        local kgValue = readNumericField(instance, {"KG", "Weight", "Mass"}, {"Max", "Target", "Goal"})
        if kgValue then
            return kgValue
        end
    end

    return nil
end

function entryUuidKey(entry)
    local uuid = firstUuid(entry)
    return uuid and uuidCacheKey(uuid) or nil
end

function findPetEntryByUuidKey(key)
    if not key then
        return nil
    end

    for uuid, entry in pairs(Inventory.ItemsByUuid) do
        if uuidCacheKey(uuid) == key then
            return entry
        end
    end

    return nil
end

function captureInventoryPetUuidKeys()
    local keys = {}

    for _, entry in ipairs(Inventory.Pets or {}) do
        for _, uuid in ipairs(entry.UUIDs or {}) do
            keys[uuidCacheKey(uuid)] = true
        end
    end

    return keys
end

function findNewPetEntries(previousUuidKeys)
    local entries = {}
    local seen = {}

    for _, entry in ipairs(Inventory.Pets or {}) do
        for _, uuid in ipairs(entry.UUIDs or {}) do
            local key = uuidCacheKey(uuid)
            if not previousUuidKeys[key] and not seen[key] then
                seen[key] = true
                entries[#entries + 1] = entry
                break
            end
        end
    end

    return entries
end

function isKgBoostTargetDone(entry)
    local key = entryUuidKey(entry)
    if key and Runtime.KgBoostCompleted[key] then
        return true
    end

    local kg = getPetKg(entry)
    local trackedKg = key and Runtime.KgLastLoggedByUuid[key] or nil
    if (kg and kg >= KG_BOOST_TARGET_KG) or (trackedKg and trackedKg >= KG_BOOST_TARGET_KG) then
        return true
    end

    return false
end

function equipPetEntry(entry, slotIndex)
    local uuid = firstUuid(entry)
    if not uuid then
        return false
    end

    cachePetEntryName(entry)
    return fireGameEvent("PetsService", "EquipPet", uuid, getPlacementCFrame(slotIndex))
end

function unequipPetEntry(entry)
    local uuid = firstUuid(entry)
    if not uuid then
        return false
    end

    cachePetEntryName(entry)
    return fireGameEvent("PetsService", "UnequipPet", uuid)
end

function firePetKgBoost(entry)
    local uuid = firstUuid(entry)
    if not uuid then
        return false
    end

    cachePetEntryName(entry)
    return tryFireGameEvent("PetBoostService", "Boost", uuid)
        or tryFireGameEvent("PetBoostService", uuid)
        or tryFireGameEvent("PetBoostService", "KGBoost", uuid)
end

function roundKg(value)
    value = tonumber(value)
    if not value then
        return nil
    end

    return math.floor((value * 10) + 0.5) / 10
end

function getTrackedPetKg(entry)
    local key = entryUuidKey(entry)
    local kg = getPetKg(entry)
    local trackedKg = key and Runtime.KgLastLoggedByUuid[key] or nil

    if kg and trackedKg then
        return math.max(kg, trackedKg)
    elseif kg then
        return kg
    end

    return trackedKg
end

function recordKgBoostProgress(entry, beforeKg, afterKg)
    local key = entryUuidKey(entry)
    if not key then
        return false
    end

    local oldKg = roundKg(beforeKg or Runtime.KgLastLoggedByUuid[key] or getPetKg(entry) or 0)
    local newKg = roundKg(afterKg or (oldKg + KG_BOOST_STEP_KG))
    newKg = math.min(KG_BOOST_TARGET_KG, newKg)

    local lastLogged = Runtime.KgLastLoggedByUuid[key]
    if not lastLogged or newKg >= lastLogged + 0.099 or newKg >= KG_BOOST_TARGET_KG then
        Runtime.KgLastLoggedByUuid[key] = newKg
        log(("%s KG boosted: %.1f -> %.1f KG"):format(tostring(entry.Name), oldKg, newKg))
        sendKgWebhook(entry, oldKg, newKg)
    end

    return newKg >= KG_BOOST_TARGET_KG
end

function getKgBoostTargets(limit, blockedUuidKeys)
    local entries = selectedPetEntries(Config.Main.KgTargetPets)
    local targets = {}
    if #entries == 0 then
        return targets
    end

    local startIndex = tonumber(Runtime.KgBoostIndex) or 1
    for offset = 0, #entries - 1 do
        if #targets >= limit then
            break
        end

        local index = ((startIndex + offset - 1) % #entries) + 1
        local entry = entries[index]
        local key = entryUuidKey(entry)
        Runtime.KgBoostIndex = (index % #entries) + 1

        if key and not blockedUuidKeys[key] and not isKgBoostTargetDone(entry) then
            blockedUuidKeys[key] = true
            targets[#targets + 1] = entry
        end
    end

    return targets
end

function Actions.KgBoostBatchOnce()
    local boosterEntries = selectedPetEntries(Config.Main.KgBoosterPets)
    local blockedUuidKeys = {}
    local equippedBoosters = 0
    local boosterLimit = math.max(0, MAX_PETS_EQUIPPED - 1)

    for _, entry in ipairs(boosterEntries) do
        if equippedBoosters >= boosterLimit then
            break
        end

        local key = entryUuidKey(entry)
        if key and not blockedUuidKeys[key] then
            blockedUuidKeys[key] = true
            equippedBoosters = equippedBoosters + 1
            equipPetEntry(entry, equippedBoosters)
        end
    end

    if equippedBoosters == 0 then
        log("KG Boost skipped: no booster team pets selected.")
        return false
    end

    local targetLimit = math.max(1, MAX_PETS_EQUIPPED - equippedBoosters)
    local targets = getKgBoostTargets(targetLimit, blockedUuidKeys)
    if #targets == 0 then
        log("KG Boost complete: no selected target pets left.")
        return false
    end

    for index, entry in ipairs(targets) do
        equipPetEntry(entry, equippedBoosters + index)
    end

    local boostedCount = 0
    local completedCount = 0

    for _, entry in ipairs(targets) do
        local key = entryUuidKey(entry)
        local beforeKg = getTrackedPetKg(entry)
        local fired = firePetKgBoost(entry)
        if fired then
            boostedCount = boostedCount + 1
        end

        task.wait(0.15)
        scanInventory()

        local latestEntry = findPetEntryByUuidKey(key) or entry
        local afterKg = getPetKg(latestEntry)
        if fired and beforeKg and (not afterKg or afterKg <= beforeKg + 0.001) then
            afterKg = beforeKg + KG_BOOST_STEP_KG
        end
        local reachedTarget = false
        if fired or (afterKg and beforeKg and afterKg > beforeKg) then
            reachedTarget = recordKgBoostProgress(latestEntry, beforeKg, afterKg)
        else
            log("KG boost remote did not fire for " .. tostring(latestEntry.Name))
        end

        if key and reachedTarget then
            Runtime.KgBoostCompleted[key] = true
            completedCount = completedCount + 1
            unequipPetEntry(latestEntry)
            log(("%s reached %.1f KG and was removed from KG queue."):format(tostring(latestEntry.Name), KG_BOOST_TARGET_KG))
        end
    end

    log(("KG Boost cycle: %d booster(s), %d target(s), %d boost call(s), %d completed."):format(
        equippedBoosters,
        #targets,
        boostedCount,
        completedCount
    ))
    return true
end

function Actions.CollectSelectedFruitOnce(maxTargets)
    local targets = {}
    local seen = {}

    maxTargets = math.max(1, tonumber(maxTargets) or 12)

    for _, entry in ipairs(selectedFruitCollectEntries(Config.Misc.FruitsToCollect)) do
        for _, target in ipairs(getFruitCollectTargets(entry)) do
            addUniqueInstance(targets, seen, target)
            if #targets >= maxTargets then
                break
            end
        end
        if #targets >= maxTargets then
            break
        end
    end

    if #targets == 0 then
        local now = os.clock()
        if now - Runtime.FruitCollectLastEmptyLog > 8 then
            Runtime.FruitCollectLastEmptyLog = now
            log("Fruit pickup skipped: no selected farm fruit found.")
        end
        return 0
    end

    local firedCount = 0
    for _, target in ipairs(targets) do
        if Config.Misc.AutoPickupFruit == false then
            break
        end

        local firedHarvest = tryFireGameEventAny("HarvestRemote", {
            {target},
            {{target}},
            {target.Parent},
            {target.Name},
            {target, localPlayer},
        })
        local firedCollect = tryFireGameEvent("CollectFruit", {target})

        if firedHarvest or firedCollect then
            firedCount = firedCount + 1
        end
    end

    if firedCount > 0 then
        log(("Fruit pickup fired for %d target(s)."):format(firedCount))
    end
    return firedCount
end

function Actions.SellSelectedFruitOnce()
    local soldCount = 0

    for _, entry in ipairs(selectedFruitEntries(Config.Misc.FruitsToSell)) do
        local tool = firstToolInstance(entry)
        if tool and equipToolInstance(tool) then
            task.wait(0.1)
            if tryFireGameEvent("SellItem") then
                soldCount = soldCount + 1
            end
        end
    end

    if soldCount == 0 then
        if tryFireGameEvent("SellItem") then
            log("Sell_Item fired without a selected fruit tool.")
        else
            log("Auto Sell Fruit skipped: Sell_Item remote not found.")
        end
    else
        log(("Auto Sell Fruit sold %d selected fruit stack(s)."):format(soldCount))
    end

    return soldCount
end

function Actions.FavoriteSelectedPetsOnce()
    local desired = Config.Misc.FavoriteMode == "Favorite"
    local changedCount = 0

    for _, entry in ipairs(selectedPetEntries(Config.Misc.FavoritePets)) do
        local uuid = firstUuid(entry)
        local instance = firstInstance(entry)
        local current = readBooleanField(instance, {"Favorite", "Favorited", "IsFavorite", "Locked"})
        local uuidKey = uuid and uuidCacheKey(uuid) or tostring(entry.Name)
        local appliedKey = uuidKey .. ":" .. tostring(desired)

        if current ~= desired and (current ~= nil or not Runtime.FavoriteAppliedByUuid[appliedKey]) then
            cachePetEntryName(entry)
            local favoriteArgs = {}
            if uuid then
                favoriteArgs[#favoriteArgs + 1] = {uuid, desired}
                favoriteArgs[#favoriteArgs + 1] = {uuid}
                favoriteArgs[#favoriteArgs + 1] = {desired and "Favorite" or "Unfavorite", uuid}
            end
            if instance then
                favoriteArgs[#favoriteArgs + 1] = {instance, desired}
                favoriteArgs[#favoriteArgs + 1] = {instance}
                favoriteArgs[#favoriteArgs + 1] = {desired and "Favorite" or "Unfavorite", instance}
            end

            local fired = false
            if #favoriteArgs > 0 then
                for _, remoteName in ipairs({"FavoriteItem", "FavoritePet", "ToggleFavorite", "SetFavorite"}) do
                    if tryFireGameEventAny(remoteName, favoriteArgs) then
                        fired = true
                        break
                    end
                end
            end

            if not fired then
                local directArgs = {}
                if uuid then
                    directArgs[#directArgs + 1] = {uuid}
                    directArgs[#directArgs + 1] = {uuid, desired}
                end
                if instance then
                    directArgs[#directArgs + 1] = {instance}
                    directArgs[#directArgs + 1] = {instance, desired}
                end
                if #directArgs > 0 then
                    local directRemoteNames = desired
                        and {"FavoriteItem", "FavoritePet"}
                        or {"UnfavoriteItem", "UnfavoritePet"}
                    for _, remoteName in ipairs(directRemoteNames) do
                        if tryFireGameEventAny(remoteName, directArgs) then
                            fired = true
                            break
                        end
                    end
                end
            end

            if fired then
                changedCount = changedCount + 1
                Runtime.FavoriteAppliedByUuid[appliedKey] = true
                log((desired and "Favorited " or "Unfavorited ") .. tostring(entry.Name))
            end
        end
    end

    if changedCount == 0 then
        log("Favorite check complete: no selected pet needed a change or remote did not fire.")
    end

    return changedCount
end

function getSelectedNames(selected)
    local names = {}
    for _, name in ipairs(selected and selected.__order or {}) do
        if isSelectedName(selected, name) then
            names[#names + 1] = name
        end
    end
    return names
end

