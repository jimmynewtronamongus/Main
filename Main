function getGameEventRemote(name)
    local path = RemotePaths[name]
    if not path then
        return nil
    end

    local node = ReplicatedStorage:WaitForChild("GameEvents", 9e9)
    for _, childName in ipairs(path) do
        node = node:WaitForChild(childName, 9e9)
    end
    return node
end

function fireGameEvent(name, ...)
    local remote = getGameEventRemote(name)
    if remote and remote:IsA("RemoteEvent") then
        remote:FireServer(...)
        return true
    end
    if remote and remote:IsA("RemoteFunction") then
        local ok = pcall(function(...)
            return remote:InvokeServer(...)
        end, ...)
        return ok
    end
    return false
end

function findGameEventRemote(name)
    local path = RemotePaths[name]
    if not path then
        return nil
    end

    local root = ReplicatedStorage:FindFirstChild("GameEvents")
    local node = root
    for _, childName in ipairs(path) do
        node = node and node:FindFirstChild(childName)
        if not node then
            break
        end
    end

    if node then
        return node
    end

    local fallbackName = path[#path]
    if root and fallbackName then
        for _, descendant in ipairs(root:GetDescendants()) do
            if descendant.Name == fallbackName
                and (descendant:IsA("RemoteEvent") or descendant:IsA("RemoteFunction"))
            then
                return descendant
            end
        end
    end

    return nil
end

function tryFireGameEvent(name, ...)
    local remote = findGameEventRemote(name)
    if not remote then
        return false
    end

    if remote:IsA("RemoteEvent") then
        remote:FireServer(...)
        return true
    end

    if remote:IsA("RemoteFunction") then
        local ok = pcall(function(...)
            return remote:InvokeServer(...)
        end, ...)
        return ok
    end

    return false
end

function callWithArgs(callback, args)
    args = args or {}
    local count = #args

    if count == 0 then
        return callback()
    elseif count == 1 then
        return callback(args[1])
    elseif count == 2 then
        return callback(args[1], args[2])
    elseif count == 3 then
        return callback(args[1], args[2], args[3])
    elseif count == 4 then
        return callback(args[1], args[2], args[3], args[4])
    elseif count == 5 then
        return callback(args[1], args[2], args[3], args[4], args[5])
    end

    return callback(args[1], args[2], args[3], args[4], args[5], args[6])
end

function clampNumber(value, minValue, maxValue)
    value = tonumber(value) or 0
    minValue = tonumber(minValue) or value
    maxValue = tonumber(maxValue) or value

    if value < minValue then
        return minValue
    end

    if value > maxValue then
        return maxValue
    end

    return value
end

function tryFireGameEventAny(name, argSets)
    for _, args in ipairs(argSets) do
        if callWithArgs(function(...)
            return tryFireGameEvent(name, ...)
        end, args) then
            return true
        end
    end

    return false
end

function fireGameEventAll(name, argSets, delaySeconds)
    local firedCount = 0

    for _, args in ipairs(argSets) do
        if callWithArgs(function(...)
            return tryFireGameEvent(name, ...)
        end, args) then
            firedCount = firedCount + 1
            if delaySeconds and delaySeconds > 0 then
                task.wait(delaySeconds)
            end
        end
    end

    return firedCount
end

function callGameEvent(name, ...)
    local remote = findGameEventRemote(name)
    if not remote then
        return false, nil
    end

    if remote:IsA("RemoteFunction") then
        local ok, result = pcall(function(...)
            return remote:InvokeServer(...)
        end, ...)
        return ok, result
    end

    if remote:IsA("RemoteEvent") then
        remote:FireServer(...)
        return true, nil
    end

    return false, nil
end

function trimText(text)
    return tostring(text or ""):gsub("^%s+", ""):gsub("%s+$", "")
end

function stripStackData(name)
    local cleaned = tostring(name or "")
    cleaned = cleaned:gsub("%s*%b[]", "")
    cleaned = cleaned:gsub("%s+x%d+$", "")
    cleaned = cleaned:gsub("%s*%(%d+%)$", "")
    return trimText(cleaned)
end

function stripSeedSuffix(name)
    local cleaned = stripStackData(name)
    cleaned = cleaned:gsub("%s+[Ss]eeds?$", "")
    return trimText(cleaned)
end

function canonicalizeUuid(value)
    local text = tostring(value or "")
    local uuid = text:match("{(%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x)}")
        or text:match("(%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x)")

    if uuid then
        return "{" .. uuid:lower() .. "}"
    end

    return nil
end

function uuidCacheKey(uuid)
    return tostring(uuid or ""):gsub("[{}]", ""):lower()
end

function isUuidOnlyName(name)
    local text = trimText(name)
    return canonicalizeUuid(text) ~= nil and not text:find("%s")
end

function getInstanceUuid(instance)
    local attributeNames = {
        "UUID",
        "Uuid",
        "uuid",
        "ItemUUID",
        "ItemUuid",
        "PetUUID",
        "PetUuid",
    }

    for _, attributeName in ipairs(attributeNames) do
        local ok, value = pcall(function()
            return instance:GetAttribute(attributeName)
        end)

        if ok and value ~= nil and tostring(value) ~= "" then
            local uuid = canonicalizeUuid(value)
            if uuid then
                return uuid
            end

            return tostring(value)
        end
    end

    return canonicalizeUuid(instance.Name)
end

function getAttributeText(instance)
    local parts = {instance.Name, instance.ClassName}
    local ok, attributes = pcall(function()
        return instance:GetAttributes()
    end)

    if ok and type(attributes) == "table" then
        for key, value in pairs(attributes) do
            parts[#parts + 1] = tostring(key)
            parts[#parts + 1] = tostring(value)
        end
    end

    for _, descendant in ipairs(instance:GetDescendants()) do
        parts[#parts + 1] = descendant.Name
        parts[#parts + 1] = descendant.ClassName

        if descendant:IsA("StringValue")
            or descendant:IsA("NumberValue")
            or descendant:IsA("IntValue")
            or descendant:IsA("BoolValue")
        then
            parts[#parts + 1] = tostring(descendant.Value)
        elseif descendant:IsA("ObjectValue") and descendant.Value then
            parts[#parts + 1] = descendant.Value.Name
            parts[#parts + 1] = descendant.Value.ClassName
        end

        local okDescAttributes, descAttributes = pcall(function()
            return descendant:GetAttributes()
        end)

        if okDescAttributes and type(descAttributes) == "table" then
            for key, value in pairs(descAttributes) do
                parts[#parts + 1] = tostring(key)
                parts[#parts + 1] = tostring(value)
            end
        end
    end

    return table.concat(parts, " "):lower()
end

function hasAnyKeyword(text, keywords)
    for _, keyword in ipairs(keywords) do
        if text:find(keyword, 1, true) then
            return true
        end
    end
    return false
end

function metadataKeyMatchesAny(key, names)
    local normalized = tostring(key or ""):lower():gsub("[^%w]", "")

    for _, name in ipairs(names) do
        local wanted = tostring(name or ""):lower():gsub("[^%w]", "")
        if normalized == wanted
            or (wanted ~= "name" and wanted ~= "type" and normalized:find(wanted, 1, true))
        then
            return true
        end
    end

    return false
end

function getMetadataTextField(instance, names)
    local ok, attributes = pcall(function()
        return instance:GetAttributes()
    end)

    if ok and type(attributes) == "table" then
        for key, value in pairs(attributes) do
            if type(value) == "string" and metadataKeyMatchesAny(key, names) then
                local cleaned = stripStackData(value)
                if cleaned ~= "" and not isUuidOnlyName(cleaned) then
                    return cleaned
                end
            end
        end
    end

    for _, descendant in ipairs(instance:GetDescendants()) do
        if descendant:IsA("StringValue") and metadataKeyMatchesAny(descendant.Name, names) then
            local cleaned = stripStackData(descendant.Value)
            if cleaned ~= "" and not isUuidOnlyName(cleaned) then
                return cleaned
            end
        elseif descendant:IsA("ObjectValue") and descendant.Value and metadataKeyMatchesAny(descendant.Name, names) then
            local cleaned = stripStackData(descendant.Value.Name)
            if cleaned ~= "" and not isUuidOnlyName(cleaned) then
                return cleaned
            end
        end
    end

    return nil
end

local KNOWN_EGG_NAMES = {
    "common egg", "uncommon egg", "rare egg", "legendary egg", "mythical egg",
    "bug egg", "bee egg", "night egg", "paradise egg", "oasis egg", "anti bee egg",
    "premium egg", "exotic egg", "dinosaur egg", "primal egg", "zen egg", "gourmet egg",
}

function isLikelyEggName(name)
    local lower = tostring(name or ""):gsub("(%l)(%u)", "%1 %2"):lower()
    lower = lower:gsub("%s+", " ")

    if lower:find(" pet egg", 1, true)
        or lower:match("^egg%s")
        or lower:match("%segg$")
        or lower == "egg"
    then
        return true
    end

    for _, eggName in ipairs(KNOWN_EGG_NAMES) do
        if lower == eggName or lower:find(eggName, 1, true) then
            return true
        end
    end

    return false
end

function normalizeEggDisplayName(name)
    local cleaned = stripStackData(tostring(name or ""):gsub("(%l)(%u)", "%1 %2"))
    if cleaned == "" then
        return cleaned
    end

    if not cleaned:lower():find("egg", 1, true) then
        cleaned = cleaned .. " Egg"
    end

    return cleaned
end

local scanReplicatedEggModelOptions
local scanPetEggRegistryOptions

do
function addUniqueOption(list, seen, value)
    local cleaned = stripStackData(value)
    if cleaned == "" then
        return
    end

    if not seen[cleaned] then
        seen[cleaned] = true
        list[#list + 1] = cleaned
    end
end

function addEggOptionFromName(names, seen, value)
    if isLikelyEggName(value) then
        addUniqueOption(names, seen, normalizeEggDisplayName(value))
    end
end

local PET_REGISTRY_SKIP_NAMES = {
    common = true,
    uncommon = true,
    rare = true,
    legendary = true,
    mythical = true,
    divine = true,
    prismatic = true,
    chance = true,
    weight = true,
    rarity = true,
    pets = true,
    rewards = true,
    pool = true,
    list = true,
    data = true,
}

function addPetOptionFromRegistry(names, seen, value)
    local cleaned = stripStackData(value)
    local lower = cleaned:lower()
    if cleaned == ""
        or tonumber(cleaned) ~= nil
        or PET_REGISTRY_SKIP_NAMES[lower]
        or isLikelyEggName(cleaned)
    then
        return
    end

    addUniqueOption(names, seen, cleaned)
end

function extractPetRegistryValue(value, names, seen, depth, keyHint)
    if depth > 8 then
        return
    end

    if type(value) == "string" then
        local keyText = tostring(keyHint or ""):lower()
        if keyText == ""
            or keyText:find("pet", 1, true)
            or keyText:find("name", 1, true)
            or keyText:find("reward", 1, true)
        then
            addPetOptionFromRegistry(names, seen, value)
        end
        return
    end

    if type(value) == "table" then
        for key, childValue in pairs(value) do
            extractPetRegistryValue(childValue, names, seen, depth + 1, key)
        end
        return
    end

    if type(typeof) == "function" and typeof(value) == "Instance" then
        for key, attribute in pairs(value:GetAttributes()) do
            extractPetRegistryValue(attribute, names, seen, depth + 1, key)
        end

        if value:IsA("StringValue") then
            extractPetRegistryValue(value.Value, names, seen, depth + 1, value.Name)
        end

        for _, child in ipairs(value:GetChildren()) do
            addPetOptionFromRegistry(names, seen, child.Name)
            extractPetRegistryValue(child, names, seen, depth + 1, child.Name)
        end
    end
end

function sortedUniqueOptions(names)
    table.sort(names)
    return names
end

scanReplicatedEggModelOptions = function()
    local names = {}
    local seen = {}
    local assets = ReplicatedStorage:FindFirstChild("Assets")
    local models = assets and assets:FindFirstChild("Models")

    if not models then
        return names
    end

    for _, child in ipairs(models:GetChildren()) do
        addEggOptionFromName(names, seen, child.Name)
    end
    for _, descendant in ipairs(models:GetDescendants()) do
        addEggOptionFromName(names, seen, descendant.Name)
    end

    return sortedUniqueOptions(names)
end

function getPetEggRegistryRoot()
    local data = ReplicatedStorage:FindFirstChild("Data")
    local petRegistry = data and data:FindFirstChild("PetRegistry")
    return petRegistry and petRegistry:FindFirstChild("PetEggs") or nil
end

scanPetEggRegistryOptions = function()
    local byEgg = {}
    local eggNames = {}
    local eggSeen = {}
    local root = getPetEggRegistryRoot()

    if not root then
        return eggNames, byEgg
    end

    local function addEggPets(eggName, value)
        local normalizedEgg = normalizeEggDisplayName(eggName)
        if normalizedEgg == "" then
            return
        end

        addUniqueOption(eggNames, eggSeen, normalizedEgg)
        byEgg[normalizedEgg] = byEgg[normalizedEgg] or {}
        local petSeen = {}
        for _, petName in ipairs(byEgg[normalizedEgg]) do
            petSeen[petName] = true
        end

        extractPetRegistryValue(value, byEgg[normalizedEgg], petSeen, 0, normalizedEgg)
        table.sort(byEgg[normalizedEgg])
    end

    if root:IsA("ModuleScript") then
        if type(require) == "function" then
            local ok, registryData = pcall(function()
                return require(root)
            end)
            if ok and type(registryData) == "table" then
                local function scanRegistryTable(value, depth)
                    if type(value) ~= "table" or depth > 6 then
                        return
                    end

                    for key, childValue in pairs(value) do
                        if isLikelyEggName(key) then
                            addEggPets(key, childValue)
                        else
                            scanRegistryTable(childValue, depth + 1)
                        end
                    end
                end

                scanRegistryTable(registryData, 0)
            end
        end
    else
        for _, eggNode in ipairs(root:GetChildren()) do
            if isLikelyEggName(eggNode.Name) then
                addEggPets(eggNode.Name, eggNode)
            end
        end
    end

    return sortedUniqueOptions(eggNames), byEgg
end
end

local KNOWN_FRUIT_NAMES = {
    "apple", "avocado", "banana", "beanstalk", "bell pepper", "blood banana",
    "blueberry", "cacao", "cactus", "candy blossom", "candy sunflower",
    "carrot", "cauliflower", "coconut", "corn", "cranberry", "cucumber",
    "daffodil", "dragon fruit", "durian", "eggplant", "feijoa", "grape",
    "green apple", "kiwi", "lemon", "lime", "loquat", "mango", "mint",
    "moon blossom", "moon mango", "mushroom", "nectarine", "orange tulip",
    "papaya", "passionfruit", "peach", "pear", "pepper", "pineapple",
    "pitcher plant", "prickly pear", "pumpkin", "rafflesia", "raspberry",
    "rose", "soul fruit", "starfruit", "strawberry", "sugar apple",
    "tomato", "venus fly trap", "watermelon",
}

function isLikelyFruitName(name)
    local lower = tostring(name or ""):lower()
    lower = lower:gsub("%s+fruit$", "")
    for _, fruitName in ipairs(KNOWN_FRUIT_NAMES) do
        if lower == fruitName or lower:find(fruitName, 1, true) then
            return true
        end
    end
    return false
end

function classifyInventoryItem(instance)
    local rawName = tostring(instance.Name)
    local displayName = stripStackData(rawName)
    local lowerRawName = rawName:lower()
    local lowerName = displayName:lower()
    local infoText = getAttributeText(instance)
    local eggMetadataName = getMetadataTextField(instance, {
        "EggName",
        "EggType",
        "PetEgg",
        "PetEggName",
        "PetEggType",
        "ItemName",
        "DisplayName",
    })

    if eggMetadataName and isLikelyEggName(eggMetadataName) then
        return "Eggs", normalizeEggDisplayName(eggMetadataName)
    end

    if hasAnyKeyword(infoText, {"petegg", "pet egg", "eggname", "eggtype", "egg name", "egg type"})
        or lowerName:find(" egg", 1, true)
        or lowerName:match("^egg ")
        or lowerName:match("egg$")
        or isLikelyEggName(displayName)
    then
        return "Eggs", normalizeEggDisplayName(eggMetadataName or displayName)
    end

    if hasAnyKeyword(infoText, {"seed", "seedname"}) or lowerName:find(" seed", 1, true) or lowerName:match("^seed ") then
        return "Seeds", stripSeedSuffix(displayName)
    end

    local likelyGear = hasAnyKeyword(lowerName, {
        "gear",
        "tool",
        "shovel",
        "sprinkler",
        "watering can",
        "rod",
        "crate",
        "cosmetic",
        "shard",
        "mutation",
        "spray",
        "ticket",
        "toy",
        "treat",
        "lollipop",
        "wrench",
        "trowel",
        "cleaning",
        "favorite",
        "harvest tool",
    })

    if likelyGear then
        return nil, displayName
    end

    if hasAnyKeyword(infoText, {"fruit", "crop", "harvest"})
        or (hasAnyKeyword(infoText, {"plant"}) and isLikelyFruitName(displayName))
    then
        return "Fruits", displayName
    end

    if hasAnyKeyword(infoText, {"pettype", "petuuid", "petdata"})
        or lowerRawName:find("[age", 1, true)
        or (lowerRawName:find(" kg", 1, true) and getInstanceUuid(instance) ~= nil)
    then
        return "Pets", displayName
    end

    if instance:IsA("Tool") and isLikelyFruitName(displayName) then
        return "Fruits", displayName
    end

    return nil, displayName
end

function formatPetDisplayName(baseName, kg)
    local cleanedName = stripStackData(baseName)
    cleanedName = cleanedName:gsub("%s*%[%d+%.?%d*%s*[Kk][Gg]%]", "")
    cleanedName = trimText(cleanedName)
    if cleanedName == "" or cleanedName:match("^Placed Pet ") or isUuidOnlyName(cleanedName) then
        cleanedName = "Pet"
    end

    if kg then
        return ("%s [%.2f KG]"):format(cleanedName, kg)
    end

    return cleanedName
end

function loadPetNameMemory()
    if type(readfile) ~= "function" or type(isfile) ~= "function" or not isfile(PET_NAME_MEMORY_FILE) then
        return
    end

    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(PET_NAME_MEMORY_FILE))
    end)

    if ok and type(decoded) == "table" then
        for key, value in pairs(decoded) do
            local cacheName = petBaseNameForCache(value)
            if cacheName then
                PetDisplayNamesByUuid[tostring(key)] = cacheName
            end
        end
    end
end

function savePetNameMemory()
    if type(writefile) ~= "function" then
        return
    end

    pcall(function()
        writefile(PET_NAME_MEMORY_FILE, HttpService:JSONEncode(PetDisplayNamesByUuid))
    end)
end

function petBaseNameForCache(displayName)
    local cleanedName = stripStackData(displayName)
    cleanedName = cleanedName:gsub("%s*%[%d+%.?%d*%s*[Kk][Gg]%]", "")
    cleanedName = trimText(cleanedName)

    if cleanedName == "" or cleanedName == "Unknown Pet" or cleanedName:match("^Placed Pet ") or isUuidOnlyName(cleanedName) then
        return nil
    end

    return cleanedName
end

loadPetNameMemory()

function rememberPetName(uuid, name)
    local key = uuid and uuidCacheKey(uuid) or nil
    local cacheName = petBaseNameForCache(name)
    if key and key ~= "" and cacheName then
        PetDisplayNamesByUuid[key] = PetDisplayNamesByUuid[key] or cacheName
        savePetNameMemory()
        return PetDisplayNamesByUuid[key]
    end

    return nil
end

function resetInventory()
    Inventory.Eggs = {}
    Inventory.Pets = {}
    Inventory.InventoryPets = {}
    Inventory.Fruits = {}
    Inventory.FarmFruits = {}
    Inventory.Seeds = {}
    Inventory.EggsByName = {}
    Inventory.PetsByName = {}
    Inventory.InventoryPetsByName = {}
    Inventory.FruitsByName = {}
    Inventory.FarmFruitsByName = {}
    Inventory.SeedsByName = {}
    Inventory.ItemsByUuid = {}
end

function isPlacedPetInstance(instance)
    if not instance then
        return false
    end

    local petsPhysical = Workspace:FindFirstChild("PetsPhysical")
    return petsPhysical ~= nil and instance:IsDescendantOf(petsPhysical)
end

function addInventoryEntry(category, displayName, instance)
    if not category or not displayName or displayName == "" then
        return
    end

    local uuid = getInstanceUuid(instance)
    if category == "Pets" and uuid then
        local cachedName = PetDisplayNamesByUuid[uuidCacheKey(uuid)]
        if cachedName and cachedName ~= "" and (isUuidOnlyName(displayName) or tostring(displayName):match("^Placed Pet ")) then
            displayName = cachedName
        end
    end

    local byName = Inventory[category .. "ByName"]
    local bucket = Inventory[category]
    if not byName or not bucket then
        return
    end

    local entry = byName[displayName]
    if not entry then
        entry = {
            Name = displayName,
            Instances = {},
            UUIDs = {},
        }
        byName[displayName] = entry
        bucket[#bucket + 1] = entry
    end

    entry.Instances[#entry.Instances + 1] = instance
    if category == "Pets" and isPlacedPetInstance(instance) then
        entry.Placed = true
    end

    if uuid then
        entry.UUIDs[#entry.UUIDs + 1] = uuid
        if category == "Pets" then
            Inventory.ItemsByUuid[uuid] = entry
        elseif category ~= "InventoryPets" then
            Inventory.ItemsByUuid[uuid] = Inventory.ItemsByUuid[uuid] or entry
        end

        if category == "Pets" then
            rememberPetName(uuid, displayName)
        end
    end
end

function scanInventoryContainer(container)
    if not container then
        return
    end

    for _, instance in ipairs(container:GetChildren()) do
        local category, displayName = classifyInventoryItem(instance)
        addInventoryEntry(category, displayName, instance)
        if category == "Pets" then
            addInventoryEntry("InventoryPets", displayName, instance)
        end
    end
end

function inventoryKeyMatchesAny(key, names)
    local normalized = tostring(key or ""):lower():gsub("[^%w]", "")

    for _, name in ipairs(names) do
        local wanted = tostring(name or ""):lower():gsub("[^%w]", "")
        if normalized == wanted
            or (wanted ~= "name" and wanted ~= "type" and normalized:find(wanted, 1, true))
        then
            return true
        end
    end

    return false
end

function getTextField(instance, names)
    if not instance then
        return nil
    end

    local ok, attributes = pcall(function()
        return instance:GetAttributes()
    end)

    if ok and type(attributes) == "table" then
        for key, value in pairs(attributes) do
            if type(value) == "string" and inventoryKeyMatchesAny(key, names) then
                local cleaned = stripStackData(value)
                if cleaned ~= "" and not isUuidOnlyName(cleaned) then
                    return cleaned
                end
            end
        end
    end

    for _, child in ipairs(instance:GetChildren()) do
        if child:IsA("StringValue") and inventoryKeyMatchesAny(child.Name, names) then
            local cleaned = stripStackData(child.Value)
            if cleaned ~= "" and not isUuidOnlyName(cleaned) then
                return cleaned
            end
        elseif child:IsA("ObjectValue") and child.Value and inventoryKeyMatchesAny(child.Name, names) then
            local cleaned = stripStackData(child.Value.Name)
            if cleaned ~= "" and not isUuidOnlyName(cleaned) then
                return cleaned
            end
        end
    end

    return nil
end

function getNumericFieldFromInstance(root, names, excludedNames)
    if not root then
        return nil
    end

    excludedNames = excludedNames or {}
    local function normalize(value)
        return tostring(value or ""):lower():gsub("[^%w]", "")
    end
    local function keyMatches(key, wantedNames)
        local normalized = normalize(key)
        for _, name in ipairs(wantedNames or {}) do
            local wanted = normalize(name)
            if wanted ~= "" and normalized:find(wanted, 1, true) then
                return true
            end
        end
        return false
    end

    local okAttributes, attributes = pcall(function()
        return root:GetAttributes()
    end)
    if okAttributes and type(attributes) == "table" then
        for key, value in pairs(attributes) do
            if type(value) == "number" and keyMatches(key, names) and not keyMatches(key, excludedNames) then
                return value
            end
        end
    end

    for _, descendant in ipairs(root:GetDescendants()) do
        if (descendant:IsA("NumberValue") or descendant:IsA("IntValue"))
            and keyMatches(descendant.Name, names)
            and not keyMatches(descendant.Name, excludedNames)
        then
            return descendant.Value
        end
    end

    return nil
end

function getPetModelKg(petModel)
    local nameText = tostring(petModel and petModel.Name or "")
    local kgText = nameText:match("%[(%d+%.?%d*)%s*[Kk][Gg]%]")
        or nameText:match("(%d+%.?%d*)%s*[Kk][Gg]")
    if kgText then
        return tonumber(kgText)
    end

    return getNumericFieldFromInstance(petModel, {
        "KG",
        "Weight",
        "Mass",
        "BaseWeight",
        "BaseKG",
        "BaseMass",
    }, {
        "Max",
        "Target",
        "Goal",
        "Boost",
    })
end

function findPetBaseNameInText(text)
    local normalizedText = tostring(text or ""):lower():gsub("[^%w]", "")
    local bestName

    for _, petName in ipairs(OPTIONS.Pets or {}) do
        local cleaned = stripStackData(petName)
        local normalized = cleaned:lower():gsub("[^%w]", "")
        if normalized ~= "" and normalizedText:find(normalized, 1, true) then
            if not bestName or #cleaned > #bestName then
                bestName = cleaned
            end
        end
    end

    for _, petOptions in pairs(OPTIONS.EggPetsByEgg or {}) do
        for _, petName in ipairs(petOptions or {}) do
            local cleaned = stripStackData(petName)
            local normalized = cleaned:lower():gsub("[^%w]", "")
            if normalized ~= "" and normalizedText:find(normalized, 1, true) then
                if not bestName or #cleaned > #bestName then
                    bestName = cleaned
                end
            end
        end
    end

    return bestName
end

function getPhysicalPetDisplayName(petModel, uuid)
    local cachedName = PetDisplayNamesByUuid[uuidCacheKey(uuid)]
    local kg = getPetModelKg(petModel)
    if cachedName and cachedName ~= "" then
        return formatPetDisplayName(cachedName, kg)
    end

    local directName = getTextField(petModel, {
        "PetName",
        "PetType",
        "DisplayName",
        "Name",
        "Type",
    })

    if directName then
        directName = petBaseNameForCache(directName)
        if directName then
            return formatPetDisplayName(rememberPetName(uuid, directName) or directName, kg)
        end
    end

    for _, descendant in ipairs(petModel:GetDescendants()) do
        local descendantName = getTextField(descendant, {
            "PetName",
            "PetType",
            "DisplayName",
            "Name",
            "Type",
        })

        if descendantName then
            descendantName = petBaseNameForCache(descendantName)
            if descendantName then
                return formatPetDisplayName(rememberPetName(uuid, descendantName) or descendantName, kg)
            end
        end
    end

    local bestName = findPetBaseNameInText(getAttributeText(petModel))

    if bestName then
        return formatPetDisplayName(rememberPetName(uuid, bestName) or bestName, kg)
    end

    return formatPetDisplayName(nil, kg)
end

function isLocalPlacedPet(petModel, uuid)
    local sawOwner = false
    local ownerNames = {
        "Owner",
        "OwnerName",
        "Player",
        "PlayerName",
        "Username",
        "UserName",
    }
    local ownerIds = {
        "OwnerId",
        "UserId",
        "PlayerId",
        "PlayerUserId",
    }

    local ok, attributes = pcall(function()
        return petModel:GetAttributes()
    end)

    if ok and type(attributes) == "table" then
        for key, value in pairs(attributes) do
            if inventoryKeyMatchesAny(key, ownerNames) then
                sawOwner = true
                if tostring(value):lower() == localPlayer.Name:lower() then
                    return true
                end
            elseif inventoryKeyMatchesAny(key, ownerIds) then
                sawOwner = true
                if tonumber(value) == localPlayer.UserId then
                    return true
                end
            end
        end
    end

    return not sawOwner
        or PetDisplayNamesByUuid[uuidCacheKey(uuid)] ~= nil
        or (type(isTrackedPetUuid) == "function" and isTrackedPetUuid(uuid))
end

function scanPlacedPets()
    local petsPhysical = Workspace:FindFirstChild("PetsPhysical")
    local petMover = petsPhysical and petsPhysical:FindFirstChild("PetMover")
    if not petMover then
        return
    end

    for _, petModel in ipairs(petMover:GetChildren()) do
        local uuid = getInstanceUuid(petModel)
        if uuid and isLocalPlacedPet(petModel, uuid) then
            addInventoryEntry("Pets", getPhysicalPetDisplayName(petModel, uuid), petModel)
        end
    end
end

function scanFarmFruitOptions()
    local farmRoot = Workspace:FindFirstChild("Farm")
    if not farmRoot then
        return
    end

    for _, farm in ipairs(farmRoot:GetChildren()) do
        local important = farm:FindFirstChild("Important")
        local plants = important and important:FindFirstChild("Plants_Physical")

        if plants then
            for _, plant in ipairs(plants:GetChildren()) do
                addInventoryEntry("FarmFruits", stripStackData(plant.Name), plant)
            end
        end
    end
end

function scanFarmEggOptions()
    local farmRoot = Workspace:FindFirstChild("Farm")
    if not farmRoot then
        return
    end

    for _, farm in ipairs(farmRoot:GetChildren()) do
        local important = farm:FindFirstChild("Important")
        local objects = important and important:FindFirstChild("Objects_Physical")

        if objects then
            for _, object in ipairs(objects:GetChildren()) do
                local metadataName = getMetadataTextField(object, {
                    "EggName",
                    "EggType",
                    "PetEgg",
                    "PetEggName",
                    "PetEggType",
                    "DisplayName",
                    "Name",
                    "Type",
                })
                local displayName = metadataName or stripStackData(object.Name)
                local infoText = getAttributeText(object)

                if isLikelyEggName(displayName)
                    or hasAnyKeyword(infoText, {"petegg", "pet egg", "eggname", "eggtype", "egg name", "egg type"})
                then
                    addInventoryEntry("Eggs", normalizeEggDisplayName(displayName), object)
                end
            end
        end
    end
end

function sortedNamesFromByName(byName)
    local names = {}
    for name in pairs(byName or {}) do
        names[#names + 1] = name
    end
    table.sort(names)
    return names
end

function sortedPlacedPetNames()
    local names = {}
    for _, entry in ipairs(Inventory.Pets or {}) do
        if entry.Placed then
            names[#names + 1] = entry.Name
        end
    end
    table.sort(names)
    return names
end

function mergeSortedOptions(...)
    local seen = {}
    local merged = {}
    for _, options in ipairs({...}) do
        for _, option in ipairs(options or {}) do
            if not seen[option] then
                seen[option] = true
                merged[#merged + 1] = option
            end
        end
    end
    table.sort(merged)
    return merged
end

function sortInventoryOptions()
    for _, category in ipairs({"Eggs", "Pets", "InventoryPets", "Fruits", "FarmFruits", "Seeds"}) do
        local names = {}
        local byName = Inventory[category .. "ByName"]

        for name in pairs(byName) do
            names[#names + 1] = name
        end

        table.sort(names)
        OPTIONS[category] = names
    end

    local modelEggOptions = scanReplicatedEggModelOptions()
    local registryEggOptions, eggPetsByEgg = scanPetEggRegistryOptions()
    OPTIONS.Eggs = mergeSortedOptions(modelEggOptions, registryEggOptions, OPTIONS.Eggs)
    OPTIONS.EggPetsByEgg = eggPetsByEgg
    OPTIONS.EggRules = OPTIONS.Eggs
    OPTIONS.PetsToSell = sortedNamesFromByName(Inventory.InventoryPetsByName)
    OPTIONS.FruitsToSell = sortedNamesFromByName(Inventory.FruitsByName)
    OPTIONS.FruitsToCollect = mergeSortedOptions(OPTIONS.FarmFruits, OPTIONS.FruitsToSell)
    OPTIONS.SeedsToPlace = sortedNamesFromByName(Inventory.SeedsByName)
end

function scanInventory()
    resetInventory()
    scanInventoryContainer(backpack)
    scanInventoryContainer(character)
    scanPlacedPets()
    scanFarmEggOptions()
    scanFarmFruitOptions()
    sortInventoryOptions()
end

scanInventory()

function addMutationOption(names, seen, value)
    local name = stripStackData(value)
    if name ~= "" and not seen[name] then
        seen[name] = true
        names[#names + 1] = name
    end
end

function extractMutationOptions(value, names, seen)
    if type(value) == "string" then
        addMutationOption(names, seen, value)
    elseif type(value) == "table" then
        for key, childValue in pairs(value) do
            if type(key) == "string" and childValue == true then
                addMutationOption(names, seen, key)
            end

            extractMutationOptions(childValue, names, seen)
        end
    end
end

function refreshMutationOptionsFromRemote()
    local ok, result = callGameEvent("GetPetMutationNames")
    if not ok then
        return false
    end

    local names = {}
    local seen = {}
    extractMutationOptions(result, names, seen)
    for mutationName in pairs(PET_GIVEN_MUTATIONS) do
        addMutationOption(names, seen, mutationName)
    end
    table.sort(names)

    if #names == 0 then
        return false
    end

    OPTIONS.Mutations = names
    return true
end

refreshMutationOptionsFromRemote()

