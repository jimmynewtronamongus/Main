function Actions.SetAntiLag(enabled)
    callRemote("SettingsService", "SetSetting", "PerformanceMode", enabled == true)
    log("Anti Lag " .. (enabled and "enabled" or "disabled"))
end

function Actions.SetTexturesRemoved(enabled)
    local changed = 0
    for _, descendant in ipairs(Workspace:GetDescendants()) do
        if descendant:IsA("Texture") or descendant:IsA("Decal") then
            descendant.Transparency = enabled and 1 or 0
            changed += 1
        elseif descendant:IsA("BasePart") then
            descendant.Material = enabled and Enum.Material.SmoothPlastic or descendant.Material
        end
    end
    log(("Textures %s across %d visual(s)."):format(enabled and "hidden" or "restored", changed))
end

