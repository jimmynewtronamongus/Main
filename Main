    logScrollFrame.BorderSizePixel = 0
    logScrollFrame.Size = UDim2.new(1, 0, 0, 420)
    logScrollFrame.CanvasSize = UDim2.fromOffset(0, 420)
    logScrollFrame.ScrollBarThickness = 6
    logScrollFrame.ScrollingDirection = Enum.ScrollingDirection.Y
    logScrollFrame.Parent = logsSection
    makeCorner(logScrollFrame, 6)
    makePadding(logScrollFrame, 10)

    logList = Instance.new("TextLabel")
    logList.BackgroundTransparency = 1
    logList.BorderSizePixel = 0
    logList.Size = UDim2.new(1, -18, 0, 400)
    logList.Font = Enum.Font.Code
    logList.Text = table.concat(Runtime.Logs, "\n")
    logList.TextColor3 = Theme.Text
    logList.TextSize = 12
    logList.TextXAlignment = Enum.TextXAlignment.Left
    logList.TextYAlignment = Enum.TextYAlignment.Top
    logList.TextWrapped = false
    logList.Parent = logScrollFrame

    createButton(logsSection, "Clear Logs", function()
        Runtime.Logs = {}
        logList.Text = ""
        logList.Size = UDim2.new(1, -18, 0, 400)
        logScrollFrame.CanvasSize = UDim2.fromOffset(0, 420)
    end)
end
buildLogsPage()

function startRuntimeBindings()
local dragging = false
local dragStart
local startPosition

topbar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPosition = window.Position
    end
end)

topbar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        window.Position = UDim2.new(
            startPosition.X.Scale,
            startPosition.X.Offset + delta.X,
            startPosition.Y.Scale,
            startPosition.Y.Offset + delta.Y
        )
    end
end)

minimizeBtn.MouseButton1Click:Connect(function()
    Runtime.Minimized = not Runtime.Minimized
    body.Visible = not Runtime.Minimized
    window.Size = Runtime.Minimized and UDim2.fromOffset(WINDOW_WIDTH, TOPBAR_HEIGHT) or UDim2.fromOffset(WINDOW_WIDTH, WINDOW_HEIGHT)
    minimizeBtn.Text = Runtime.Minimized and "+" or "-"
end)

closeBtn.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then
        return
    end

    if input.KeyCode == Enum.KeyCode.RightShift then
        window.Visible = not window.Visible
    end
end)

local inventoryRefreshQueued = false
queueInventoryRefresh = function(reason)
    if inventoryRefreshQueued then
        return
    end

    inventoryRefreshQueued = true
    task.delay(0.25, function()
        inventoryRefreshQueued = false
        if screenGui.Parent then
            refreshInventoryOptions(reason)
        end
    end)
end

function bindCharacterInventory(newCharacter)
    character = newCharacter
    if not character then
        return
    end

    character.ChildAdded:Connect(function()
        queueInventoryRefresh("character item added")
    end)

    character.ChildRemoved:Connect(function()
        queueInventoryRefresh("character item removed")
    end)

    queueInventoryRefresh("character loaded")
end

backpack.ChildAdded:Connect(function()
    queueInventoryRefresh("backpack item added")
end)

backpack.ChildRemoved:Connect(function()
    queueInventoryRefresh("backpack item removed")
end)

if character then
    bindCharacterInventory(character)
end

localPlayer.CharacterAdded:Connect(bindCharacterInventory)

function shouldRefreshForFarmNode(instance)
    return instance.Name == "Plants_Physical"
        or instance.Name == "Objects_Physical"
        or (instance.Parent and instance.Parent.Name == "Plants_Physical")
        or (instance.Parent and instance.Parent.Name == "Objects_Physical")
end

function bindFarmInventoryRefresh(farmRoot)
    if not farmRoot then
        return
    end

    farmRoot.DescendantAdded:Connect(function(instance)
        if shouldRefreshForFarmNode(instance) then
            queueInventoryRefresh("farm plants changed")
        end
    end)

    farmRoot.DescendantRemoving:Connect(function(instance)
        if shouldRefreshForFarmNode(instance) then
            queueInventoryRefresh("farm plants changed")
        end
    end)
end

bindFarmInventoryRefresh(Workspace:FindFirstChild("Farm"))
Workspace.ChildAdded:Connect(function(child)
    if child.Name == "Farm" then
        bindFarmInventoryRefresh(child)
        queueInventoryRefresh("farm loaded")
    end
end)

local boundPetMovers = {}
local boundPetsPhysicalRoots = {}

function bindPetMoverInventoryRefresh(petMover)
    if not petMover or boundPetMovers[petMover] then
        return
    end

    boundPetMovers[petMover] = true

    petMover.ChildAdded:Connect(function()
        queueInventoryRefresh("placed pet added")
    end)

    petMover.ChildRemoved:Connect(function()
        queueInventoryRefresh("placed pet removed")
    end)
end

function bindPlacedPetInventoryRefresh(petsPhysical)
    if not petsPhysical then
        return
    end

    bindPetMoverInventoryRefresh(petsPhysical:FindFirstChild("PetMover"))

    if boundPetsPhysicalRoots[petsPhysical] then
        return
    end

    boundPetsPhysicalRoots[petsPhysical] = true

    petsPhysical.ChildAdded:Connect(function(child)
        if child.Name == "PetMover" then
            bindPetMoverInventoryRefresh(child)
            queueInventoryRefresh("placed pet mover loaded")
        end
    end)
end

bindPlacedPetInventoryRefresh(Workspace:FindFirstChild("PetsPhysical"))
Workspace.ChildAdded:Connect(function(child)
    if child.Name == "PetsPhysical" then
        bindPlacedPetInventoryRefresh(child)
        queueInventoryRefresh("placed pets loaded")
    end
end)

local automationTimers = {
    Hatch = 0,
    PlaceEggs = 0,
    Level = 0,
    Feed = 0,
    KgBoost = 0,
    Favorite = 0,
    PickupFruit = 0,
    SellFruit = 0,
    Buy = 0,
    PlaceSeeds = 0,
    Rebirth = 0,
    PickAndPlace = 0,
    Mutation = 0,
    EggEsp = 0,
}

local automationBusy = {
    Level = false,
    Feed = false,
    KgBoost = false,
    Favorite = false,
    PickupFruit = false,
    Buy = false,
    PlaceSeeds = false,
    PickAndPlace = false,
    Mutation = false,
    PlaceEggs = false,
}

task.spawn(function()
    while screenGui.Parent do
        local now = os.clock()

        if Config.Hatch.AutoHatch and now - automationTimers.Hatch >= 1.5 then
            automationTimers.Hatch = now
            Actions.HatchOnce()
        end

        if Config.Hatch.AutoPlaceEggs
            and not automationBusy.PlaceEggs
            and now - automationTimers.PlaceEggs >= (tonumber(Config.Hatch.PlaceEggInterval) or 8)
        then
            automationTimers.PlaceEggs = now
            automationBusy.PlaceEggs = true
            task.spawn(function()
                Actions.PlaceSelectedEggsOnce()
                automationBusy.PlaceEggs = false
            end)
        end

        if Config.Main.AutoLevelPet
            and not automationBusy.Level
            and now - automationTimers.Level >= 5
        then
            automationTimers.Level = now
            automationBusy.Level = true
            task.spawn(function()
                Actions.LevelSelectedPetsOnce()
                automationBusy.Level = false
            end)
        end

        if Config.Main.AutoFeedPet
            and not automationBusy.Feed
            and now - automationTimers.Feed >= (tonumber(Config.Main.FeedInterval) or 2)
        then
            automationTimers.Feed = now
            automationBusy.Feed = true
            task.spawn(function()
                Actions.FeedHungryPetsOnce()
                automationBusy.Feed = false
            end)
        end

        if Config.Main.AutoKgBoost
            and not automationBusy.KgBoost
            and now - automationTimers.KgBoost >= KG_BOOST_INTERVAL
        then
            automationTimers.KgBoost = now
            automationBusy.KgBoost = true
            task.spawn(function()
                local ranBatch = Actions.KgBoostBatchOnce()
                if not ranBatch then
                    automationTimers.KgBoost = os.clock() + 30
                end
                automationBusy.KgBoost = false
            end)
        end

        if Config.Misc.AutoFavorite
            and not automationBusy.Favorite
            and now - automationTimers.Favorite >= 6
        then
            automationTimers.Favorite = now
            automationBusy.Favorite = true
            task.spawn(function()
                Actions.FavoriteSelectedPetsOnce()
                automationBusy.Favorite = false
            end)
        end

        if Config.Misc.AutoPickupFruit
            and not automationBusy.PickupFruit
            and now - automationTimers.PickupFruit >= math.max(2, tonumber(Config.Misc.FruitCollectInterval) or 2)
        then
            automationTimers.PickupFruit = now
            automationBusy.PickupFruit = true
            task.spawn(function()
                if Config.Misc.AutoPickupFruit then
                    pcall(Actions.CollectSelectedFruitOnce, 12)
                end
                automationBusy.PickupFruit = false
            end)
        end

        if Config.Misc.AutoSellFruit and now - automationTimers.SellFruit >= 10 then
            automationTimers.SellFruit = now
            Actions.SellSelectedFruitOnce()
        end

        if Config.Misc.AutoBuy
            and not automationBusy.Buy
            and now - automationTimers.Buy >= 3
        then
            automationTimers.Buy = now
            automationBusy.Buy = true
            task.spawn(function()
                Actions.AutoBuySelectedShopsOnce()
                automationBusy.Buy = false
            end)
        end

        if Config.Misc.AutoPlaceSeeds
            and not automationBusy.PlaceSeeds
            and now - automationTimers.PlaceSeeds >= 0.6
        then
            automationTimers.PlaceSeeds = now
            automationBusy.PlaceSeeds = true
            task.spawn(function()
                Actions.PlaceSelectedSeedsOnce()
                automationBusy.PlaceSeeds = false
            end)
        end

        if Config.Misc.AutoRebirth and now - automationTimers.Rebirth >= 10 then
            automationTimers.Rebirth = now
            Actions.RebirthOnce()
        end

        if Config.Main.PickAndPlace
            and not automationBusy.PickAndPlace
            and now - automationTimers.PickAndPlace >= 2
        then
            automationTimers.PickAndPlace = now
            automationBusy.PickAndPlace = true
            task.spawn(function()
                Actions.PickAndPlaceOnce()
                automationBusy.PickAndPlace = false
            end)
        end

        if Config.Mutation.AutoMutation
            and not automationBusy.Mutation
            and now - automationTimers.Mutation >= 8
        then
            automationTimers.Mutation = now
            automationBusy.Mutation = true
            task.spawn(function()
                Actions.AutoMutationOnce()
                automationBusy.Mutation = false
            end)
        end

        if Config.Hatch.EggEsp and Actions.RefreshEggEsp and now - automationTimers.EggEsp >= 1 then
            automationTimers.EggEsp = now
            Actions.RefreshEggEsp(true)
        end

        task.wait(0.2)
    end
end)

task.spawn(function()
    while screenGui.Parent do
        local activeCount = 0

        if Config.Main.AutoLevelPet then activeCount = activeCount + 1 end
        if Config.Main.AutoFeedPet then activeCount = activeCount + 1 end
        if Config.Main.AutoKgBoost then activeCount = activeCount + 1 end
        if Config.Main.PickAndPlace then activeCount = activeCount + 1 end
        if Config.Hatch.AutoHatch then activeCount = activeCount + 1 end
        if Config.Hatch.AutoPlaceEggs then activeCount = activeCount + 1 end
        if Config.Hatch.AutoSellPets then activeCount = activeCount + 1 end
        if Config.Hatch.EggEsp then activeCount = activeCount + 1 end
        if Config.Mutation.AutoMutation then activeCount = activeCount + 1 end
        if Config.Misc.AutoFavorite then activeCount = activeCount + 1 end
        if Config.Misc.AutoPickupFruit then activeCount = activeCount + 1 end
        if Config.Misc.AutoSellFruit then activeCount = activeCount + 1 end
        if Config.Misc.AutoBuy then activeCount = activeCount + 1 end
        if Config.Misc.AutoPlaceSeeds then activeCount = activeCount + 1 end
        if Config.Misc.AutoReconnect then activeCount = activeCount + 1 end
        if Config.Misc.AutoRebirth then activeCount = activeCount + 1 end

        if activeCount > 0 then
            setStatus(tostring(activeCount) .. " enabled")
        else
            setStatus("Idle")
        end

        RunService.Heartbeat:Wait()
    end
end)
end

startRuntimeBindings()

refreshInventoryOptions("initial")
switchTab("Main")
if Config.Misc.AntiLag then
    fireGameEvent("SettingsService", "SetSetting", "PerformanceMode", true)
end
if Config.Misc.RemoveTextures then
    Actions.SetTexturesRemoved(true)
end
log("Main GUI loaded. Backpack-driven options active. Wire automation loops inside the Actions table.")
