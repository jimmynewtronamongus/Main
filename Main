createWindowShell()

function log(message)
    local line = os.date("%H:%M:%S") .. "  " .. tostring(message)
    Runtime.Logs[#Runtime.Logs + 1] = line
    if #Runtime.Logs > 120 then
        table.remove(Runtime.Logs, 1)
    end

    if logList then
        logList.Text = table.concat(Runtime.Logs, "\n")
        task.defer(function()
            if logScrollFrame and logScrollFrame.Parent and logList and logList.Parent then
                local height = math.max(360, logList.TextBounds.Y + 28)
                logList.Size = UDim2.new(1, -18, 0, height)
                logScrollFrame.CanvasSize = UDim2.fromOffset(0, height)
                logScrollFrame.CanvasPosition = Vector2.new(0, math.max(0, height - logScrollFrame.AbsoluteWindowSize.Y))
            end
        end)
    end

    print("[GAG Main] " .. tostring(message))
end

function setStatus(text)
    statusLabel.Text = tostring(text)
end

function sendWebhookPayload(payload)
    local url = trimText(Config.Misc.WebhookUrl)
    if url == "" then
        return false
    end

    local body = HttpService:JSONEncode(payload)
    local env = (type(getgenv) == "function" and getgenv()) or _G
    local requestFn = type(env) == "table" and (env.request or env.http_request or env.httpRequest) or nil

    if not requestFn and type(syn) == "table" then
        requestFn = syn.request
    end

    if type(requestFn) == "function" then
        local ok = pcall(requestFn, {
            Url = url,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json",
            },
            Body = body,
        })
        return ok
    end

    local ok = pcall(function()
        HttpService:PostAsync(url, body, Enum.HttpContentType.ApplicationJson, false)
    end)
    return ok
end

function sendKgWebhook(entry, oldKg, newKg)
    if not Config.Misc.WebhookKgLogs then
        return
    end

    local petName = entry and entry.Name or "Pet"
    local description = ("%s reached %.1f KG"):format(tostring(petName), newKg)
    if oldKg then
        description = ("%s went from %.1f KG to %.1f KG"):format(tostring(petName), oldKg, newKg)
    end

    sendWebhookPayload({
        username = "GAG Main",
        embeds = {{
            title = "KG Boost Update",
            description = description,
            color = 4115621,
            fields = {
                {
                    name = "Target",
                    value = ("%.1f KG"):format(KG_BOOST_TARGET_KG),
                    inline = true,
                },
                {
                    name = "Player",
                    value = localPlayer.Name,
                    inline = true,
                },
            },
        }},
    })
end

function sendHatchWebhook(eggName, petEntry)
    if not Config.Misc.WebhookHatchLogs then
        return
    end

    sendWebhookPayload({
        username = "GAG Main",
        embeds = {{
            title = "Pet Hatched",
            description = ("%s hatched from %s"):format(
                tostring(petEntry and petEntry.Name or "Unknown pet"),
                tostring(eggName or "an egg")
            ),
            color = 15183616,
            fields = {
                {
                    name = "Player",
                    value = localPlayer.Name,
                    inline = true,
                },
            },
        }},
    })
end

function makeCorner(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 6)
    corner.Parent = parent
    return corner
end

function makeStroke(parent, color, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or Theme.Stroke
    stroke.Thickness = thickness or 1
    stroke.Parent = parent
    return stroke
end

function makePadding(parent, amount)
    local padding = Instance.new("UIPadding")
    padding.PaddingTop = UDim.new(0, amount)
    padding.PaddingBottom = UDim.new(0, amount)
    padding.PaddingLeft = UDim.new(0, amount)
    padding.PaddingRight = UDim.new(0, amount)
    padding.Parent = parent
    return padding
end

function createPage(name)
    local page = Instance.new("ScrollingFrame")
    page.Name = name .. "Page"
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.Position = UDim2.fromOffset(18, 14)
    page.Size = UDim2.new(1, -34, 1, -28)
    page.ScrollBarThickness = 5
    page.ScrollBarImageColor3 = Theme.Accent
    page.CanvasSize = UDim2.fromOffset(0, 0)
    page.Visible = false
    page.Parent = content

    local padding = Instance.new("UIPadding")
    padding.PaddingBottom = UDim.new(0, 12)
    padding.Parent = page

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 10)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = page

    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 20)
    end)

    pages[name] = page
    return page
end

function switchTab(name)
    Runtime.ActiveTab = name

    for pageName, page in pairs(pages) do
        page.Visible = pageName == name
    end

    for buttonName, button in pairs(navButtons) do
        local active = buttonName == name
        button.BackgroundColor3 = active and Theme.Accent or Theme.Nav
        button.TextColor3 = active and Theme.ActiveText or Theme.Text
        local accent = button:FindFirstChild("Accent")
        if accent then
            accent.Visible = active
        end
    end
end

