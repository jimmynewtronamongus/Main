local function copyList(list)
    local out = {}
    for _, value in ipairs(list or {}) do
        out[#out + 1] = value
    end
    return out
end

local function selectedFrom(list)
    local selected = {__order = {}}
    for _, value in ipairs(list or {}) do
        selected[value] = true
        selected.__order[#selected.__order + 1] = value
    end
    return selected
end

local function selectedNames(selected)
    local names = {}
    for _, name in ipairs((selected and selected.__order) or {}) do
        if selected[name] then
            names[#names + 1] = name
        end
    end
    return names
end

local function hasSelection(selected, name)
    local order = selected and selected.__order
    if not order or #order == 0 then
        return true
    end
    return selected[name] == true
end

local function mergeConfig(target, source)
    if type(target) ~= "table" or type(source) ~= "table" then
        return
    end
    for key, value in pairs(source) do
        if type(target[key]) == "table" and type(value) == "table" then
            mergeConfig(target[key], value)
        elseif target[key] ~= nil then
            target[key] = value
        end
    end
end

local function loadConfig()
    if type(readfile) ~= "function" or type(isfile) ~= "function" or not isfile(CONFIG_FILE) then
        return
    end
    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_FILE))
    end)
    if ok and type(decoded) == "table" then
        mergeConfig(Config, decoded)
    end
end

local saveQueued = false
local function saveConfigSoon()
    if saveQueued then
        return
    end
    saveQueued = true
    task.delay(0.5, function()
        saveQueued = false
        if type(writefile) ~= "function" then
            return
        end
        pcall(function()
            writefile(CONFIG_FILE, HttpService:JSONEncode(Config))
        end)
    end)
end

loadConfig()

