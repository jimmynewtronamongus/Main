local function page(name)
    local p = Instance.new("ScrollingFrame")
    p.Name = name .. "Page"
    p.BackgroundTransparency = 1
    p.Size = UDim2.new(1, -28, 1, -28)
    p.Position = UDim2.fromOffset(14, 14)
    p.ScrollBarThickness = 6
    p.ScrollBarImageColor3 = Theme.Accent
    p.Visible = false
    p.CanvasSize = UDim2.fromOffset(0, 0)
    p.Parent = content

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 10)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = p
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        p.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 20)
    end)
    pages[name] = p
    return p
end

local function switch(name)
    State.ActiveTab = name
    for pageName, p in pairs(pages) do
        p.Visible = pageName == name
    end
    for buttonName, button in pairs(navButtons) do
        local active = buttonName == name
        button.BackgroundColor3 = active and Theme.Accent or Theme.Panel
        local title = button:FindFirstChild("Title")
        if title then
            title.TextColor3 = active and Theme.Background or Theme.Text
        end
        local sub = button:FindFirstChild("Sub")
        if sub then
            sub.TextColor3 = active and Color3.fromRGB(27, 41, 34) or Theme.Muted
        end
    end
end

local function navButton(name, order, description)
    local b = Instance.new("TextButton")
    b.Name = name .. "Tab"
    b.LayoutOrder = order
    b.Size = UDim2.new(1, 0, 0, 52)
    b.BackgroundColor3 = Theme.Panel
    b.BorderSizePixel = 0
    b.Text = ""
    b.AutoButtonColor = true
    b.Parent = nav
    corner(b, 8)
    stroke(b, Theme.StrokeSoft, 1)

    local title = Instance.new("TextLabel")
    title.Name = "Title"
    title.BackgroundTransparency = 1
    title.Position = UDim2.fromOffset(12, 8)
    title.Size = UDim2.new(1, -24, 0, 16)
    title.Font = Enum.Font.GothamBold
    title.Text = name
    title.TextColor3 = Theme.Text
    title.TextSize = 12
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.TextTruncate = Enum.TextTruncate.AtEnd
    title.Parent = b

    local sub = Instance.new("TextLabel")
    sub.Name = "Sub"
    sub.BackgroundTransparency = 1
    sub.Position = UDim2.fromOffset(12, 27)
    sub.Size = UDim2.new(1, -24, 0, 16)
    sub.Font = Enum.Font.Gotham
    sub.Text = description or ""
    sub.TextColor3 = Theme.Muted
    sub.TextSize = 10
    sub.TextXAlignment = Enum.TextXAlignment.Left
    sub.TextTruncate = Enum.TextTruncate.AtEnd
    sub.Parent = b

    b.MouseButton1Click:Connect(function()
        switch(name)
    end)
    navButtons[name] = b
end

local function section(parent, name)
    local s = Instance.new("Frame")
    s.Name = name:gsub("%s+", "") .. "Section"
    s.Size = UDim2.new(1, -4, 0, 10)
    s.AutomaticSize = Enum.AutomaticSize.Y
    s.BackgroundColor3 = Theme.Panel
    s.BorderSizePixel = 0
    s.Parent = parent
    corner(s, 10)
    stroke(s, Theme.StrokeSoft, 1)
    pad(s, 14)

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 10)
    layout.Parent = s

    local heading = Instance.new("TextLabel")
    heading.BackgroundTransparency = 1
    heading.Size = UDim2.new(1, 0, 0, 22)
    heading.Font = Enum.Font.GothamBold
    heading.Text = name
    heading.TextColor3 = Theme.Accent
    heading.TextSize = 15
    heading.TextXAlignment = Enum.TextXAlignment.Left
    heading.Parent = s

    local description = SectionDescriptions[name]
    if description then
        local note = Instance.new("TextLabel")
        note.BackgroundTransparency = 1
        note.Size = UDim2.new(1, 0, 0, 34)
        note.Font = Enum.Font.Gotham
        note.Text = description
        note.TextColor3 = Theme.Muted
        note.TextSize = 12
        note.TextWrapped = true
        note.TextXAlignment = Enum.TextXAlignment.Left
        note.TextYAlignment = Enum.TextYAlignment.Top
        note.Parent = s
    end
    return s
end

local function row(parent, height)
    local r = Instance.new("Frame")
    r.Size = UDim2.new(1, 0, 0, height or 46)
    r.BackgroundColor3 = Theme.Panel2
    r.BackgroundTransparency = 0.02
    r.BorderSizePixel = 0
    r.Parent = parent
    corner(r, 8)
    stroke(r, Theme.StrokeSoft, 1)
    return r
end

local function button(parent, text, callback)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, 0, 0, 40)
    b.BackgroundColor3 = Theme.Accent2
    b.BorderSizePixel = 0
    b.Font = Enum.Font.GothamBold
    b.Text = text
    b.TextColor3 = Theme.Background
    b.TextSize = 12
    b.Parent = parent
    corner(b, 8)
    stroke(b, Color3.fromRGB(255, 224, 147), 1)
    b.MouseButton1Click:Connect(function()
        if callback then callback() end
    end)
    return b
end

local function toggle(parent, text, value, callback)
    local r = row(parent, 46)
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Position = UDim2.fromOffset(14, 0)
    label.Size = UDim2.new(1, -94, 1, 0)
    label.Font = Enum.Font.GothamMedium
    label.Text = text
    label.TextColor3 = Theme.Text
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = r

    local b = Instance.new("TextButton")
    b.AnchorPoint = Vector2.new(1, 0.5)
    b.Position = UDim2.new(1, -12, 0.5, 0)
    b.Size = UDim2.fromOffset(62, 26)
    b.BorderSizePixel = 0
    b.Font = Enum.Font.GothamBold
    b.TextSize = 10
    b.Parent = r
    corner(b, 13)
    stroke(b, Theme.StrokeSoft, 1)

    local on = value == true
    local function render(fire)
        b.Text = on and "ON" or "OFF"
        b.TextColor3 = on and Theme.Background or Theme.Text
        TweenService:Create(b, TweenInfo.new(0.1), {
            BackgroundColor3 = on and Theme.Accent or Theme.Input,
        }):Play()
        if fire and callback then
            callback(on)
            saveConfigSoon()
        end
    end
    b.MouseButton1Click:Connect(function()
        on = not on
        render(true)
    end)
    render(false)
end

local function input(parent, text, default, callback)
    local r = row(parent, 46)
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Position = UDim2.fromOffset(14, 0)
    label.Size = UDim2.new(0.45, -16, 1, 0)
    label.Font = Enum.Font.GothamMedium
    label.Text = text
    label.TextColor3 = Theme.Text
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = r

    local box = Instance.new("TextBox")
    box.AnchorPoint = Vector2.new(1, 0.5)
    box.Position = UDim2.new(1, -12, 0.5, 0)
    box.Size = UDim2.new(0.55, -10, 0, 30)
    box.BackgroundColor3 = Theme.Input
    box.BorderSizePixel = 0
    box.ClearTextOnFocus = false
    box.Text = tostring(default or "")
    box.TextColor3 = Theme.Text
    box.TextSize = 12
    box.Font = Enum.Font.Gotham
    box.TextXAlignment = Enum.TextXAlignment.Left
    box.Parent = r
    corner(box, 7)
    stroke(box, Theme.StrokeSoft, 1)
    pad(box, 8)
    box.FocusLost:Connect(function()
        if callback then callback(box.Text) end
        saveConfigSoon()
    end)
end

local function multiselect(parent, text, optionGetter, selected, callback)
    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 42)
    container.AutomaticSize = Enum.AutomaticSize.Y
    container.Parent = parent

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 6)
    layout.Parent = container

    local r = row(container, 48)
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Position = UDim2.fromOffset(14, 0)
    label.Size = UDim2.new(0.35, -12, 1, 0)
    label.Font = Enum.Font.GothamMedium
    label.Text = text
    label.TextColor3 = Theme.Text
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = r

    local open = Instance.new("TextButton")
    open.AnchorPoint = Vector2.new(1, 0.5)
    open.Position = UDim2.new(1, -12, 0.5, 0)
    open.Size = UDim2.new(0.65, -10, 0, 30)
    open.BackgroundColor3 = Theme.Input
    open.BorderSizePixel = 0
    open.Font = Enum.Font.Gotham
    open.TextColor3 = Theme.Text
    open.TextSize = 12
    open.TextXAlignment = Enum.TextXAlignment.Left
    open.Parent = r
    corner(open, 7)
    stroke(open, Theme.StrokeSoft, 1)
    pad(open, 8)

    local list = Instance.new("ScrollingFrame")
    list.Size = UDim2.new(1, 0, 0, 220)
    list.BackgroundColor3 = Theme.Input
    list.BorderSizePixel = 0
    list.ScrollBarThickness = 4
    list.Visible = false
    list.Parent = container
    corner(list, 8)
    stroke(list, Theme.StrokeSoft, 1)
    pad(list, 8)

    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 4)
    listLayout.Parent = list
    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        list.CanvasSize = UDim2.fromOffset(0, listLayout.AbsoluteContentSize.Y + 8)
    end)

    local function textValue()
        local names = selectedNames(selected)
        if #names == 0 then
            return "All items"
        end
        if #names > 2 then
            return tostring(#names) .. " selected"
        end
        return table.concat(names, ", ")
    end

    local function rebuild()
        for _, child in ipairs(list:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        open.Text = textValue()

        local all = Instance.new("TextButton")
        all.Size = UDim2.new(1, -16, 0, 30)
        all.BackgroundColor3 = Theme.Panel2
        all.BorderSizePixel = 0
        all.Font = Enum.Font.GothamBold
        all.Text = "Use all items"
        all.TextColor3 = Theme.Accent
        all.TextSize = 12
        all.TextXAlignment = Enum.TextXAlignment.Left
        all.Parent = list
        corner(all, 5)
        pad(all, 8)
        all.MouseButton1Click:Connect(function()
            for key in pairs(selected) do
                if key ~= "__order" then
                    selected[key] = nil
                end
            end
            selected.__order = {}
            rebuild()
            if callback then callback() end
            saveConfigSoon()
        end)

        for _, option in ipairs(optionGetter()) do
            local item = Instance.new("TextButton")
            item.Size = UDim2.new(1, -16, 0, 30)
            item.BackgroundColor3 = selected[option] and Theme.Accent or Theme.Panel2
            item.BorderSizePixel = 0
            item.Font = Enum.Font.Gotham
            item.Text = option
            item.TextColor3 = selected[option] and Theme.Background or Theme.Text
            item.TextSize = 12
            item.TextXAlignment = Enum.TextXAlignment.Left
            item.TextTruncate = Enum.TextTruncate.AtEnd
            item.Parent = list
            corner(item, 5)
            pad(item, 8)
            item.MouseButton1Click:Connect(function()
                selected[option] = not selected[option]
                if selected[option] then
                    local exists = false
                    for _, name in ipairs(selected.__order or {}) do
                        if name == option then exists = true end
                    end
                    if not exists then
                        selected.__order[#selected.__order + 1] = option
                    end
                end
                rebuild()
                if callback then callback() end
                saveConfigSoon()
            end)
        end
    end

    open.MouseButton1Click:Connect(function()
        list.Visible = not list.Visible
        if list.Visible then rebuild() end
    end)

    refreshers[#refreshers + 1] = rebuild
    rebuild()
end

