    row.BackgroundColor3 = Theme.PanelAlt
    row.BackgroundTransparency = 0.06
    row.BorderSizePixel = 0
    row.Size = UDim2.new(1, 0, 0, height or 44)
    row.Parent = parent
    makeCorner(row, 7)
    makeStroke(row, Theme.StrokeSoft, 1)
    return row
end

function createToggle(parent, text, default, callback)
    local row = createRow(parent, 44)

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Position = UDim2.fromOffset(12, 0)
    label.Size = UDim2.new(1, -86, 1, 0)
    label.Font = Enum.Font.GothamMedium
    label.Text = text
    label.TextColor3 = Theme.Text
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextTruncate = Enum.TextTruncate.AtEnd
    label.Parent = row

    local button = Instance.new("TextButton")
    button.AnchorPoint = Vector2.new(1, 0.5)
    button.Position = UDim2.new(1, -12, 0.5, 0)
    button.Size = UDim2.fromOffset(50, 24)
    button.BackgroundColor3 = default and Theme.Accent or Theme.Off
    button.BorderSizePixel = 0
    button.Font = Enum.Font.GothamBold
    button.Text = default and "ON" or "OFF"
    button.TextColor3 = default and Color3.fromRGB(14, 18, 24) or Theme.Text
    button.TextSize = 10
    button.Parent = row
    makeCorner(button, 6)

    local enabled = default == true
    local function setEnabled(value, fire)
        enabled = value == true
        button.Text = enabled and "ON" or "OFF"
        button.TextColor3 = enabled and Color3.fromRGB(14, 18, 24) or Theme.Text
        TweenService:Create(button, TweenInfo.new(0.12), {
            BackgroundColor3 = enabled and Theme.Accent or Theme.Off,
        }):Play()

        if fire and callback then
            callback(enabled)
            scheduleSaveConfig()
        end
    end

    button.MouseButton1Click:Connect(function()
        setEnabled(not enabled, true)
    end)

    row.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            setEnabled(not enabled, true)
        end
    end)

    return setEnabled
end

function createButton(parent, text, callback)
    local button = Instance.new("TextButton")
    button.BackgroundColor3 = Theme.AccentAlt
